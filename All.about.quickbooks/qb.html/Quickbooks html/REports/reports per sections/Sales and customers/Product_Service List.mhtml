0px; height: 200px; }

.clip.left, .clip.right { left: 96px; }

.left .circle, .right .circle { left: -100px; }

.circle { border-radius: 100px; width: 200px; height: 200px; border: 4px so=
lid transparent; }

.track { border-color: rgb(244, 245, 248); }

.track-fill { border-color: rgb(44, 160, 28); }

