body.handheld.mobile.no-overscroll { overflow: visible; }

body.handheld.tablet.no-overscroll { overflow: visible; position: fixed; }

ha-tooltip { max-width: 250px; top: -1000px; left: -1000px; position: absol=
ute; padding: 13px 15px 12px; opacity: 0; z-index: 790; pointer-events: non=
e; border-radius: 4px; background-color: rgb(57, 58, 61); color: rgb(255, 2=
55, 255); font-size: 12px; line-height: 14.4px; animation: 0.5s ease 0s 1 n=
ormal none running ha-fade-in; }

ha-tooltip.visible { opacity: 1; pointer-events: all; display: block; }

ha-tooltip.no-transition { transition: none; }

ha-tooltip.leave { animation: 0.5s ease 0s 1 normal none running ha-fade-ou=
t; }

ha-tooltip > div { position: relative; }

ha-tooltip > div .btn-icon-only { margin-top: -7px; margin-right: -9px; dis=
play: none; padding: 3px 4px 1px 3px; float: right; border: 1px solid trans=
parent; background: 0px 0px; box-shadow: none; font-size: 12px; }

ha-tooltip > div .btn-icon-only::before { color: rgb(186, 190, 197); }

