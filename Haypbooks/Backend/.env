# ──────────────────────────────────────────────────────────────────────────────
# HaypBooks Backend — environment variables template
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to source control.
# ──────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# URL of the Next.js frontend (used in email links and CORS)
FRONTEND_URL=http://localhost:3000

# Enable test/debug endpoints in non-production environments
ALLOW_TEST_ENDPOINTS=true

# Auto-login after email verification link click (dev convenience)
ENABLE_AUTO_VERIFY_LOGIN=false

# Return OTP codes in API responses for local dev/testing ONLY — NEVER set true in production/staging
DEV_SHOW_OTP=true

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:Ninetails45@localhost:5432/haypbooks_dev

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be a long, randomly generated secret in production
JWT_SECRET=my-local-dev-secret-123456789
JWT_REFRESH_SECRET=dev-local-refresh-secret-for-testing-only

# ── Security / HMAC ───────────────────────────────────────────────────────────
# Used to hash phone numbers before storage; must be set in production
HMAC_KEY=my-local-hmac-key-987654321

# ── Phone / Locale ────────────────────────────────────────────────────────────
# Default country for phone normalisation (ISO 3166-1 alpha-2)
DEFAULT_PHONE_COUNTRY=PH

# ── Email — SendGrid (preferred for production) ───────────────────────────────
# Set SENDGRID_API_KEY to enable SendGrid.  Leave blank to fall through to SMTP.
SENDGRID_API_KEY=
SENDGRID_FROM=noreply@haypbooks.com

# ── Email — SMTP (fallback / local dev) ──────────────────────────────────────
# Used when SENDGRID_API_KEY is not set.
# For local dev use MailHog (http://localhost:8025) or Mailtrap.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=HaypBooks <noreply@haypbooks.com>

