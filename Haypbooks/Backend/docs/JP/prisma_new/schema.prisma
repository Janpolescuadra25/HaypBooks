model Prediction {
  id           String   @id @default(uuid())
  workspaceId  String   @map("tenantId")
  companyId    String

  predictionType PredictionType
  entityType   String
  entityId     String?

  predictionDate DateTime
  targetDate    DateTime

  predictedValue Decimal @db.Decimal(20, 4)
  lowerBound    Decimal? @db.Decimal(20, 4)
  upperBound    Decimal? @db.Decimal(20, 4)
  confidence    Decimal  @db.Decimal(5, 2)

  actualValue   Decimal? @db.Decimal(20, 4)
  accuracy      Decimal? @db.Decimal(5, 2)

  modelId      String?
  modelVersion String?
  features     Json?

  status       PredictionStatus @default(ACTIVE)
