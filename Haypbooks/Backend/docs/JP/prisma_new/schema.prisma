}

model ExternalEntity {
  id         String                  @id @default(uuid())
  integrationConfigId String?
  localEntityType String?            // Invoice, Customer, Vendor, etc.
  localEntityId   String?
  entityType String                  // INVOICE, CUSTOMER, VENDOR, etc.
  externalId String
  systemType IntegrationType
  data       Json
  syncedAt   DateTime?
  lastLocalUpdate    DateTime?
  lastExternalUpdate DateTime?
  conflictResolution IntegrationConflictResolution?
  conflictNotes      String?
  status     ExternalEntitySyncStatus @default(PENDING)

  integration ExternalSystemConfig? @relation(fields: [integrationConfigId], references: [id], onDelete: SetNull)

  @@index([entityType, externalId])
  @@index([entityType, systemType])
  @@index([systemType])
  @@index([status])
  @@index([integrationConfigId])
  @@unique([localEntityType, localEntityId])
}
