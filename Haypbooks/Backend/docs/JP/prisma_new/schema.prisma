  templateId    String?
  userId        String?  // who triggered the render (user id)
  renderedBy    String?
  renderedAt    DateTime @default(now())
  format        String   // PDF, HTML, PNG
  outputUrl     String?
  status        String   // SUCCESS, FAILED, PENDING
  errorMessage  String?
  renderAttempts Int     @default(0)
  durationMs    Int?
  meta          Json?
  deletedAt     DateTime?
  deletedBy     String?
  createdAt     DateTime @default(now())
  lastAttemptAt DateTime?
  durationMs    Int?
  meta          Json?
  deletedAt     DateTime?
  deletedBy     String?
  createdAt     DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  company   Company?  @relation(fields: [companyId], references: [id])

  @@index([workspaceId, companyId])
  @@index([workspaceId, companyId, renderedAt])
  @@index([workspaceId, userId, renderedAt])
  @@index([templateId])
  @@index([workspaceId, documentType, documentId])
  @@index([documentType, documentId])
  @@index([status])
  @@index([status, renderedAt])
  @@index([userId])
  @@index([deletedAt])

  @@index([templateId, documentType])
}

