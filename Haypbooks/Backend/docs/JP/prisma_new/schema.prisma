model Dimension {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  code        String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  values  DimensionValue[]

  @@unique([companyId, name])
  @@index([companyId, isActive])
}

model DimensionValue {
  id          String   @id @default(uuid())
  companyId   String
  dimensionId String
  code        String
  name        String
  parentId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  dimension Dimension  @relation(fields: [dimensionId], references: [id], onDelete: Cascade)
  parent    DimensionValue? @relation("dimensionValue_children", fields: [parentId], references: [id])
  children  DimensionValue[] @relation("dimensionValue_children")
  entityLinks EntityDimensionValue[]

  @@unique([dimensionId, code])
  @@index([companyId, dimensionId])
  @@index([parentId])
}

model EntityDimensionValue {
  id               String   @id @default(uuid())
  companyId         String
  dimensionValueId  String
  entityType        String
  entityId          String
  effectiveFrom     DateTime?
  effectiveTo       DateTime?
  createdAt         DateTime @default(now())

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  dimensionValue DimensionValue @relation(fields: [dimensionValueId], references: [id], onDelete: Cascade)

  @@index([companyId, entityType, entityId])
  @@index([dimensionValueId])
}

model DataQualityScore {
  id          String   @id @default(uuid())
  workspaceId String?  @map("tenantId")
  companyId   String?
  datasetType String
  entityType  String?
  entityId    String?
  score       Decimal  @db.Decimal(5, 2)
  issues      Json?
  measuredAt  DateTime
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  company   Company?   @relation(fields: [companyId], references: [id])

  @@index([workspaceId, datasetType, measuredAt])
  @@index([companyId, datasetType, measuredAt])
  @@index([entityType, entityId])
}


// --------------------
// Non-Profit Module (Fund Accounting)
// --------------------

model Fund {
  id             String   @id @default(uuid())
  workspaceId    String   @map("tenantId")
  companyId      String
  
  name           String   // e.g. "General Operating Fund", "Scholarship Fund"
  code           String   @unique // e.g., "100", "200"
  type           String   // UNRESTRICTED, TEMPORARILY_RESTRICTED, PERMANENTLY_RESTRICTED
  
  description    String?
  startDate      DateTime?
  endDate        DateTime? // If grant-specific
  
  balance        Decimal  @default(0) @db.Decimal(20, 4)
  isActive       Boolean  @default(true)
  
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  company        Company   @relation(fields: [companyId], references: [id])
  
  allocations    FundAllocation[]
  segments       AccountSegment[] // Linking GL accounts to Funds (Fund Accounting)

  @@index([companyId, type])
}

model FundAllocation {
  id             String   @id @default(uuid())
  fundId         String
  transactionId  String   // Polymorphic (Invoice, Bill, JournalEntry)
  transactionType String  // INVOICE, BILL, JOURNAL
  
  amount         Decimal  @db.Decimal(20, 4)
  percentage     Decimal? @db.Decimal(5, 2)
  
  fund           Fund     @relation(fields: [fundId], references: [id])
  
  @@index([transactionId, transactionType])
  @@index([fundId])
}

model Donation {
  id             String   @id @default(uuid())
  workspaceId    String   @map("tenantId")
  companyId      String
  
  donorId        String   // Links to Customer/Contact
  fundId         String?  // Designated fund
  
  amount         Decimal  @db.Decimal(20, 4)
  date           DateTime
  type           String   // CASH, PLEDGE, IN_KIND
  status         String   // RECEIVED, PLEDGED, WRITTEN_OFF
  
  campaign       String?  // e.g., "2025 Annual Appeal"
  restriction    String?  // Notes on restrictions
  
  acknowledgmentSent Boolean @default(false)
  receiptNumber  String?
  
  createdAt      DateTime @default(now())

  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  company        Company   @relation(fields: [companyId], references: [id])
  donor          Customer  @relation(fields: [donorId], references: [contactId])
  matchedFund    Fund?     @relation(fields: [fundId], references: [id])

  @@index([companyId, date])
  @@index([donorId])
}

model Pledge {
  id             String   @id @default(uuid())
  companyId      String
  donorId        String
  
  totalAmount    Decimal  @db.Decimal(20, 4)
  startDate      DateTime
  endDate        DateTime
  installmentFreq String  // MONTHLY, QUARTERLY, ANNUALLY
  
  amountPaid     Decimal  @default(0) @db.Decimal(20, 4)
  status         String   // ACTIVE, FULFILLED, CANCELLED
  
  company        Company   @relation(fields: [companyId], references: [id])
  donor          Customer  @relation(fields: [donorId], references: [contactId])

  @@index([donorId])
}

// --------------------
// Property Management (Real Estate)
// --------------------

model Property {
  id             String   @id @default(uuid())
  workspaceId    String   @map("tenantId")
  companyId      String
  
  name           String   // "Sunset Apartments"
  address        String
  type           String   // RESIDENTIAL, COMMERCIAL, INDUSTRIAL
  
  units          PropertyUnit[]
  
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  company        Company   @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
}

model PropertyUnit {
  id             String   @id @default(uuid())
  propertyId     String
  
  unitNumber     String   // "Apt 101"
  status         String   // VACANT, OCCUPIED, MAINTENANCE
  marketRent     Decimal  @db.Decimal(20, 4)
  
  currentLeaseId String?
  
  property       Property @relation(fields: [propertyId], references: [id])
  leases         Lease[]

  @@unique([propertyId, unitNumber])
}

model Lease {
  id             String   @id @default(uuid())
  unitId         String
  tenantId       String   // Links to Customer
  
  startDate      DateTime
  endDate        DateTime
  rentAmount     Decimal  @db.Decimal(20, 4)
  securityDeposit Decimal @db.Decimal(20, 4)
  
  status         String   // ACTIVE, TERMINATED, RENEWED
  
  unit           PropertyUnit @relation(fields: [unitId], references: [id])
  tenant         Customer     @relation(fields: [tenantId], references: [contactId])
  
  @@index([tenantId])
  @@index([unitId])
}

// --------------------
// Construction & Project Industry Features
// --------------------

model ContractRetention {
  id             String   @id @default(uuid())
  workspaceId    String   @map("tenantId")
  companyId      String
  projectId      String
  
  // The general retention policy for this project
  retentionPercent Decimal @db.Decimal(5, 2) // e.g., 10%
  totalWithheld    Decimal @default(0) @db.Decimal(20, 4)
  totalReleased    Decimal @default(0) @db.Decimal(20, 4)
  
  // Status
  status         String   @default("ACTIVE") // ACTIVE, CLOSED, RELEASED
  createdAt      DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  company   Company   @relation(fields: [companyId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id])
  entries   RetentionEntry[]

  @@unique([projectId])
  @@index([companyId])
}

model RetentionEntry {
  id             String   @id @default(uuid())
  retentionId    String
  invoiceId      String?  // Source invoice (AR)
  billId         String?  // Source bill (AP)
  
  amount         Decimal  @db.Decimal(20, 4)
  date           DateTime
  type           String   // WITHHELD, RELEASED
  description    String?

  retention ContractRetention @relation(fields: [retentionId], references: [id])
  
  @@index([retentionId])
  @@index([invoiceId])
  @@index([billId])
}

// --------------------
// Retail Industry Features
// --------------------

model GiftCard {
  id             String   @id @default(uuid())
  workspaceId    String   @map("tenantId")
  companyId      String
  
  code           String   // Hashed or encrypted in real app? Or last 4 + separate lookup
  initialBalance Decimal  @db.Decimal(20, 4)
  currentBalance Decimal  @db.Decimal(20, 4)
  
  issuedAt       DateTime @default(now())
  expiresAt      DateTime?
  status         String   @default("ACTIVE") // ACTIVE, REDEEMED, VOID
  
  recipientEmail String?
  
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  company   Company   @relation(fields: [companyId], references: [id])

  @@unique([companyId, code])
  @@index([companyId, status])
}

model LoyaltyProgram {
  id             String   @id @default(uuid())
  workspaceId    String   @map("tenantId")
  companyId      String
  
  name           String   // e.g. "Gold Rewards"
  pointsPerDollar Decimal @db.Decimal(10, 2) // Earn rate
  redemptionRatio Decimal @db.Decimal(10, 2) // Points needed for $1 off
  
  isActive       Boolean  @default(true)
  company   Company   @relation(fields: [companyId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  accounts  LoyaltyAccount[]

  @@index([companyId])
}

model LoyaltyAccount {
  id             String   @id @default(uuid())
  programId      String
  customerId     String
  
  pointsBalance  Int      @default(0)
  lifetimePoints Int      @default(0)
  currentTier    String?  // BRONZE, SILVER, GOLD
  
  updatedAt      DateTime @updatedAt
  
  program   LoyaltyProgram @relation(fields: [programId], references: [id])
  customer  Customer       @relation(fields: [customerId], references: [contactId])

  @@unique([programId, customerId])
}

model Currency {
  code     String  @id
  name     String
  symbol   String
  decimals Int     @default(2)
  isActive Boolean @default(true)
}

model PaymentTerm {
  id           String  @id @default(uuid())
  workspaceId  String
  name         String  // e.g., "Net 30"
  dueDays      Int
  discountDays Int?    // e.g., 10 (for 2/10 Net 30)
  discountPct  Decimal? @db.Decimal(5, 2)
  isDefault    Boolean @default(false)
  isActive     Boolean @default(true)

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  customers Customer[]
  vendors   Vendor[]
  invoices  Invoice[]
  bills     Bill[]

  @@index([workspaceId])
}

enum PaymentMethodType {
  CASH
  CHECK
  CARD
  BANK
  OTHER
}

model PaymentMethod {
  id          String @id @default(uuid())
  workspaceId String
  name        String // e.g., "Check", "Wire", "Credit Card"
  type        PaymentMethodType // CASH, CHECK, CARD, BANK, OTHER
  isActive    Boolean @default(true)

  workspace       Workspace         @relation(fields: [workspaceId], references: [id])
  paymentsReceived PaymentReceived[]

  @@index([workspaceId])
} 

model ExchangeRate {
  id           String   @id @default(uuid())
  baseCurrency String
  toCurrency   String
  rate         Decimal  @db.Decimal(28, 12)
  date         DateTime
  source       String?

  @@unique([baseCurrency, toCurrency, date])
}

model ForeignCurrencyGainLoss {
  id              String   @id @default(uuid())
  companyId        String
  transactionId    String
  transactionType  String   // INVOICE, BILL, PAYMENT
  originalAmount   Decimal  @db.Decimal(20, 4)
  originalCurrency String
  baseAmount       Decimal  @db.Decimal(20, 4)
  baseCurrency     String
  exchangeRate     Decimal  @db.Decimal(28, 12)
  gainLoss         Decimal  @db.Decimal(20, 4)
  realizedAt       DateTime?

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, realizedAt])
  @@index([transactionType, transactionId])
}

model AccountSubType {
  id        Int       @id @default(autoincrement())
  name      String
  typeId    Int
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  accounts  Account[]

  @@index([companyId, typeId])
} 

model AccountBalance {
  id             String   @id @default(uuid())
  accountId      String
  companyId      String
  yearMonth      String
  balance        Decimal  @db.Decimal(20, 4)
  balanceForeign Decimal? @db.Decimal(20, 4)

  company Company @relation(fields: [companyId], references: [id])
  @@unique([companyId, accountId, yearMonth])
  @@index([companyId, yearMonth])
  @@index([companyId, yearMonth, accountId])
  @@index([companyId, yearMonth, balance])
  @@index([accountId, yearMonth])
} 

model AccountBalanceAudit {
  id           String   @id @default(uuid())
  companyId    String
  accountId    String
  period       String   // 2024-12
  oldBalance   Decimal  @db.Decimal(20, 4)
  newBalance   Decimal  @db.Decimal(20, 4)
  changeReason String   // JOURNAL_ENTRY, ADJUSTMENT, CLOSING
  referenceId  String?
  changedBy    String?
  changedAt    DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  account Account @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([companyId, accountId, period])
}

model OpeningBalance {
  id        String   @id @default(uuid())
  companyId String
  accountId String
  amount    Decimal  @db.Decimal(20, 4)
  asOfDate  DateTime
  createdAt DateTime @default(now())
  account   Account  @relation(fields: [accountId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, accountId])
} 

model Class {
  id                       String                     @id @default(uuid())
  companyId                String
  name                     String
  parentId                 String?
  isActive                 Boolean                    @default(true)
  createdAt                DateTime                   @default(now())
  BudgetLine               BudgetLine[]
  JournalEntryLine         JournalEntryLine[]
  InventoryTransactionLine InventoryTransactionLine[]
  InvoiceLine              InvoiceLine[]
  BillLine                 BillLine[]
  company                  Company                    @relation(fields: [companyId], references: [id])

  @@unique([companyId, name])
} 

model Location {
  id                       String                     @id @default(uuid())
  companyId                String
  name                     String
  address                  String?
  isActive                 Boolean                    @default(true)
  JournalEntryLine         JournalEntryLine[]
  InventoryTransactionLine InventoryTransactionLine[]
  InvoiceLine              InvoiceLine[]
  BillLine                 BillLine[]
  company                  Company                    @relation(fields: [companyId], references: [id])

  @@unique([companyId, name])
} 

model Project {
  id           String    @id @default(uuid())
  companyId    String
  customerId   String?
  name         String
  description  String?
  startDate    DateTime?
  endDate      DateTime?
  status       String    @default("ACTIVE")
  budgetAmount Decimal?  @db.Decimal(20, 4)
  createdAt    DateTime  @default(now())

  timeEntries              TimeEntry[]
  JournalEntryLine         JournalEntryLine[]
  InventoryTransactionLine InventoryTransactionLine[]
  InvoiceLine              InvoiceLine[]
  BillLine                 BillLine[]
  company                  Company    @relation(fields: [companyId], references: [id])

  @@index([companyId, status])
} 

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum PostingStatus {
  DRAFT
  POSTED
  VOIDED
}

enum PeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

enum ApprovalType {
  REFUND
  WRITEOFF
}

enum PostingModule {
  JOURNAL_ENTRY
  INVOICE
  BILL
  BANK_DEPOSIT
  INVENTORY
  PAYROLL
}

model Timesheet {
  id         String          @id @default(uuid())
  workspaceId String         @map("tenantId")
  employeeId String
  weekStart  DateTime
  status     TimesheetStatus @default(DRAFT)
  notes      String?
  createdAt  DateTime        @default(now())

  entries   TimeEntry[]
  approvals TimesheetApproval[]

  workspace Workspace   @relation(fields: [workspaceId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([workspaceId, employeeId])
}

model TimeEntry {
  id          String   @id @default(uuid())
  workspaceId String   @map("tenantId")
  timesheetId String
  employeeId  String
  projectId   String?
  date        DateTime
  hours       Decimal  @db.Decimal(6, 2)
  description String?
  createdAt   DateTime @default(now())

  timesheet Timesheet @relation(fields: [timesheetId], references: [id])
  employee  Employee  @relation(fields: [employeeId], references: [id])
  project   Project?  @relation(fields: [projectId], references: [id])
  workspace Workspace    @relation(fields: [workspaceId], references: [id])

  @@index([timesheetId])
  @@index([employeeId])
  @@index([workspaceId])
}

model TimesheetApproval {
  id          String   @id @default(uuid())
  timesheetId String
  approverId  String
  approvedAt  DateTime
  comment     String?
  createdAt   DateTime @default(now())

  timesheet Timesheet @relation(fields: [timesheetId], references: [id])
  approver  User      @relation(fields: [approverId], references: [id])
  workspaceId String @map("tenantId")
  workspace Workspace    @relation(fields: [workspaceId], references: [id])

  @@index([timesheetId])
  @@index([workspaceId])
}

enum BudgetScenario {
  ACTUAL
  BUDGET
  FORECAST
  WHAT_IF
}

enum BudgetStatus {
  DRAFT
  APPROVED
  LOCKED
}

model Budget {
  id          String         @id @default(uuid())
  workspaceId String         @map("tenantId")
  name        String
  scenario    BudgetScenario @default(ACTUAL)
  status      BudgetStatus   @default(DRAFT)
  fiscalYear  Int
  totalAmount Decimal?       @db.Decimal(20, 4)
  createdAt   DateTime       @default(now())

  workspace Workspace       @relation(fields: [workspaceId], references: [id])
  lines  BudgetLine[]

  @@index([workspaceId, fiscalYear])
}

model BudgetLine {
  id        String   @id @default(uuid())
  budgetId  String
  workspaceId String @map("tenantId")
  accountId String?
  classId   String?
  month     Int?
  amount    Decimal  @db.Decimal(20, 4)
  createdAt DateTime @default(now())

  budget  Budget   @relation(fields: [budgetId], references: [id])
  account Account? @relation(fields: [accountId], references: [id])
  class   Class?   @relation(fields: [classId], references: [id])
  workspace Workspace   @relation(fields: [workspaceId], references: [id])

  @@index([budgetId])
  @@index([accountId])
  @@index([workspaceId])
}

// -----------------------------
// Added: Governance + Accounting missing domains
// -----------------------------

model AccountingPeriod {
  id        String       @id @default(uuid())
  workspaceId String     @map("tenantId")
  startDate DateTime
  endDate   DateTime
  status    PeriodStatus
  closedAt  DateTime?
  closedBy  String?
  createdAt DateTime     @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, startDate])
}

model ApprovalThreshold {
  id            String       @id @default(uuid())
  companyId     String
  type          ApprovalType
  minAmount     Decimal?     @db.Decimal(20, 4)
  maxAmount     Decimal?     @db.Decimal(20, 4)
  approverCount Int          @default(1)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId, type])
  @@index([companyId, isActive])
}

model PostingLock {
  id          String        @id @default(uuid())
  workspaceId String        @map("tenantId")
  companyId   String
  module      PostingModule
  startDate   DateTime
  endDate     DateTime
  reason      String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId, module, isActive])
  @@index([workspaceId, startDate, endDate])
}

model Reversal {
  id            String   @id @default(uuid())
  workspaceId   String   @map("tenantId")
  originalType  String
  originalId    String
  reversalEntry String
  reason        String?
  // Whether the user is an accountant (can manage multiple clients)
  isAccountant Boolean @default(false)

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
}

model FinancialStatementSnapshot {
  id          String   @id @default(uuid())
  workspaceId String   @map("tenantId")
  type        String
  period      String
  data        Json
  generatedAt DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, type, period])
}

model CurrencyRevaluation {
  id             String   @id @default(uuid())
  companyId      String
  period         String   // e.g., 2024-12
  status         String   @default("DRAFT")
  totalGainLoss  Decimal? @db.Decimal(20, 4)
  journalEntryId String?
  createdAt      DateTime @default(now())

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])
  entries      CurrencyRevaluationEntry[]

  @@index([companyId, period])
}

model CurrencyRevaluationEntry {
  id                  String   @id @default(uuid())
  revaluationId       String
  accountId           String
  foreignBalance      Decimal  @db.Decimal(20, 4)
  exchangeRate        Decimal  @db.Decimal(28, 12)
  baseBalance         Decimal  @db.Decimal(20, 4)
  unrealizedGainLoss  Decimal? @db.Decimal(20, 4)

  revaluation CurrencyRevaluation @relation(fields: [revaluationId], references: [id], onDelete: Cascade)
  account     Account             @relation(fields: [accountId], references: [id])

  @@index([revaluationId])
  @@index([accountId])
}

model CashFlowCategory {
  id        String   @id @default(uuid())
  companyId String
  code      String   // e.g., OPERATING:AR, INVESTING:CAPEX
  name      String
  section   CashFlowSection
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  accounts Account[]

  @@unique([companyId, code])
  @@index([companyId, section])
}

model CashFlowStatementSnapshot {
  id          String   @id @default(uuid())
  companyId   String
  period      String
  method      String   // DIRECT, INDIRECT
  data        Json
  generatedAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId, period])
}

model FinancialStatementTemplate {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  type        String   // BALANCE_SHEET, INCOME_STATEMENT, CASH_FLOW, RETAINED_EARNINGS
  structure   Json
  isDefault   Boolean  @default(false)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  company   Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  sections  ReportSection[]

  @@unique([companyId, type, name])
  @@index([companyId, type])
}

model ReportSection {
  id          String   @id @default(uuid())
  templateId  String
  name        String
  order       Int
  type        String   // HEADER, ACCOUNT_GROUP, CALCULATION, TOTAL
  config      Json

  template FinancialStatementTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, order])
}

model FinancialStatementLine {
  id            String   @id @default(uuid())
  companyId     String
  statementType String   // BALANCE_SHEET, INCOME_STATEMENT, CASH_FLOW
  lineNumber    Int
  label         String
  accountIds    String[]
  calculation   String?
  isTotal       Boolean  @default(false)
  order         Int
  createdAt     DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, statementType, lineNumber])
  @@index([companyId, statementType])
}

model DocumentSequence {
  id             String   @id @default(uuid())
  companyId      String
  documentType   String   // INVOICE, BILL, JOURNAL_ENTRY, QUOTE
  prefix         String?
  nextNumber     Int      @default(1)
  format         String?  // e.g., "INV-{year}-{number}"
  resetFrequency String?  // NEVER, YEARLY, MONTHLY
  lastUsed       DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, documentType])
}

model ClosingEntry {
  id            String   @id @default(uuid())
  companyId     String
  period        String   // e.g., 2024-12
  type          String   // INCOME_SUMMARY, RETAINED_EARNINGS, DIVIDENDS
  status        String   @default("DRAFT") // DRAFT, POSTED
  postedAt      DateTime?
  createdAt     DateTime @default(now())
  journalEntryId String?

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@unique([companyId, period, type])
  @@index([companyId, period])
}

model YearEndClose {
  id            String   @id @default(uuid())
  companyId     String
  fiscalYear    Int
  status        String   @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED
  startedAt     DateTime?
  completedAt   DateTime?
  journalEntryId String?
  retainedEarningsAccountId String?
  incomeSummaryAccountId     String?
  createdAt     DateTime @default(now())

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])
  retainedEarningsAccount Account? @relation("YearEndClose_RE", fields: [retainedEarningsAccountId], references: [id])
  incomeSummaryAccount    Account? @relation("YearEndClose_IS", fields: [incomeSummaryAccountId], references: [id])

  @@unique([companyId, fiscalYear])
  @@index([companyId, status])
}

model EquityAccount {
  id        String   @id @default(uuid())
  companyId String
  type      String   // COMMON_STOCK, PREFERRED_STOCK, RETAINED_EARNINGS, APIC, TREASURY_STOCK, OWNER_DRAW
  accountId String
  parValue  Decimal? @db.Decimal(20, 4)
  shares    Decimal? @db.Decimal(20, 4)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  account Account @relation(fields: [accountId], references: [id])

  @@unique([companyId, type])
  @@index([companyId])
}

model Dividend {
  id              String   @id @default(uuid())
  companyId       String
  declarationDate DateTime
  recordDate      DateTime?
  paymentDate     DateTime?
  amountPerShare  Decimal? @db.Decimal(20, 4)
  totalAmount     Decimal  @db.Decimal(20, 4)
  status          String   // DECLARED, PAID
  journalEntryId  String?
  createdAt       DateTime @default(now())

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@index([companyId, paymentDate])
}

model PayrollTaxReturn {
  id          String   @id @default(uuid())
  companyId   String
  workspaceId String   @map("tenantId")
  period      String   // e.g., 2024-Q1
  formType    String   // 941, 940, STATE
  status      String   @default("DRAFT") // DRAFT, FILED
  filedAt     DateTime?
  totalTax    Decimal  @db.Decimal(20, 4)
  createdAt   DateTime @default(now())

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([companyId, period, formType])
  @@index([companyId, period])
}

model PayrollTaxLiability {
  id           String   @id @default(uuid())
  companyId    String
  type         String   // FEDERAL_WITHHOLDING, FICA, MEDICARE, STATE_WITHHOLDING, SUI
  jurisdiction String?
  period       String   // 2024-Q1
  amount       Decimal  @db.Decimal(20, 4)
  dueDate      DateTime
  paidAmount   Decimal  @default(0) @db.Decimal(20, 4)
  status       String   // OPEN, PARTIAL, PAID, OVERDUE
  accountId    String?
  createdAt    DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  account  Account? @relation(fields: [accountId], references: [id])
  payments PayrollTaxPayment[]

  @@unique([companyId, type, jurisdiction, period])
  @@index([companyId, period])
}

model PayrollTaxPayment {
  id             String   @id @default(uuid())
  companyId      String
  liabilityId    String
  paymentDate    DateTime
  amount         Decimal  @db.Decimal(20, 4)
  method         String
  referenceNumber String?
  journalEntryId String?
  createdAt      DateTime @default(now())

  company      Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  liability    PayrollTaxLiability @relation(fields: [liabilityId], references: [id], onDelete: Cascade)
  journalEntry JournalEntry?      @relation(fields: [journalEntryId], references: [id])

  @@index([liabilityId])
  @@index([companyId, paymentDate])
}

model AccrualSchedule {
  id              String   @id @default(uuid())
  companyId       String
  type            String   // PREPAID_EXPENSE, DEFERRED_REVENUE, ACCRUED_EXPENSE, ACCRUED_REVENUE
  accountId       String
  offsetAccountId String?
  description     String
  totalAmount     Decimal  @db.Decimal(20, 4)
  startDate       DateTime
  endDate         DateTime
  monthlyAmount   Decimal  @db.Decimal(20, 4)
  remainingAmount Decimal  @db.Decimal(20, 4)
  status          String   // ACTIVE, COMPLETED
  createdAt       DateTime @default(now())

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  account       Account  @relation(fields: [accountId], references: [id])
  offsetAccount Account? @relation(fields: [offsetAccountId], references: [id])
  entries       AccrualEntry[]

  @@index([companyId, status])
}

model AccrualEntry {
  id             String   @id @default(uuid())
  scheduleId     String
  periodStart    DateTime
  periodEnd      DateTime
  amount         Decimal  @db.Decimal(20, 4)
  journalEntryId String?
  postedAt       DateTime?

  schedule     AccrualSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  journalEntry JournalEntry?  @relation(fields: [journalEntryId], references: [id])

  @@unique([scheduleId, periodStart])
  @@index([journalEntryId])
}

model BankReconciliation {
  id             String   @id @default(uuid())
  workspaceId    String   @map("tenantId")
  bankAccountId  String
  statementDate  DateTime
  closingBalance Decimal  @db.Decimal(20, 4)
  status         BankReconciliationStatus   @default(DRAFT)
  createdAt      DateTime @default(now())

  workspace              Workspace                @relation(fields: [workspaceId], references: [id])
  bankAccount            BankAccount              @relation(fields: [bankAccountId], references: [id])
  BankReconciliationLine BankReconciliationLine[]

  @@index([workspaceId, bankAccountId, statementDate])
}

model BankReconciliationLine {
  id                   String   @id @default(uuid())
  workspaceId          String   @map("tenantId")
  bankReconciliationId String
  bankTransactionId    String
  matched              Boolean  @default(false)
  matchType            String   @default("MANUAL") // AUTO, MANUAL, ADJUSTMENT
  
  // Link to Internal Books (The "Match")
  journalEntryLineId   String?
  createdAt            DateTime @default(now())

  bankReconciliation BankReconciliation @relation(fields: [bankReconciliationId], references: [id])
  bankTransaction    BankTransaction    @relation(fields: [bankTransactionId], references: [id])
  journalEntryLine   JournalEntryLine?  @relation(fields: [journalEntryLineId], references: [id])
  workspace          Workspace          @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, bankReconciliationId])
  @@index([bankTransactionId])
  @@index([journalEntryLineId])
  @@index([bankReconciliationId, bankTransactionId])
}

model ContactAddress {
  id         String  @id @default(uuid())
  contactId  String
  workspaceId   String @map("tenantId")
  type       String
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String  @default("US")
  workspace   Workspace  @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, contactId])
}

model ContactCustomField {
  id         String @id @default(uuid())
  contactId  String
  workspaceId String @map("tenantId")
  fieldName  String
  fieldValue String
  workspace  Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, contactId])
}

model AccountType {
  id         Int        @id @default(autoincrement())
  name       String
  category   AccountCategory?
  normalSide NormalSide @default(DEBIT) // Normal balance side for this account type
  accounts   Account[]
}

model AccountSegment {
  id             String   @id @default(uuid())
  companyId      String
  
  segmentName    String   // e.g., "Fund", "Department", "Project", "Location"
  segmentValue   String   // e.g., "100 - General Fund"
  
  // Link to core account if this is a sub-account structure
  parentAccountId String?
  parentAccount   Account? @relation(fields: [parentAccountId], references: [id])
  
  // For Fund Accounting
  fundId         String?
  fund           Fund?    @relation(fields: [fundId], references: [id])
  
  company        Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, segmentName, segmentValue])
}

model Account {
  id        String   @id @default(uuid())
  companyId String
  code      String
  name      String
  typeId    Int
  parentId  String?
  currency  String   @default("USD")
  isActive  Boolean  @default(true)
  isSystem  Boolean  @default(false)
  cashFlowType String? // OPERATING, INVESTING, FINANCING
  cashFlowCategoryId String?
  normalSide NormalSide? // optional override of the AccountType normalSide
  balance   Decimal  @default(0) @db.Decimal(20, 4)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company                  Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  type                     AccountType          @relation(fields: [typeId], references: [id], onDelete: Restrict)
  cashFlowCategory          CashFlowCategory?   @relation(fields: [cashFlowCategoryId], references: [id])
  children                 Account[]            @relation("acct_children")
  parent                   Account?             @relation("acct_children", fields: [parentId], references: [id], onDelete: SetNull)
  journalLines             JournalEntryLine[]
  AccountSubType           AccountSubType?      @relation(fields: [accountSubTypeId], references: [id])
  accountSubTypeId         Int?
  OpeningBalance           OpeningBalance[]
  TaxCodeAccount           TaxCodeAccount[]
  BillLine                 BillLine[]
  VendorCreditLine         VendorCreditLine[]
  BudgetLine               BudgetLine[]
  CustomerCreditLine       CustomerCreditLine[]
  fixedAssetAsAssetAccount FixedAsset[]         @relation("FixedAsset_assetAccount")
  fixedAssetAsAccumAccount FixedAsset[]         @relation("FixedAsset_accumAccount")

  @@unique([companyId, code])
  @@index([companyId, name])
} 

model JournalEntry {
  id            String        @id @default(uuid())
  workspaceId   String        @map("tenantId")
  companyId     String
  entryNumber   String?       @unique
  date          DateTime
  description   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  createdById    String?
  updatedById    String?
  createdBy      User?         @relation("JournalEntry_createdBy", fields: [createdById], references: [id])
  updatedBy      User?         @relation("JournalEntry_updatedBy", fields: [updatedById], references: [id])
  postingStatus PostingStatus @default(DRAFT)
  currency      String?
  exchangeRate  Decimal?      @db.Decimal(28, 12)
  baseTotal     Decimal?      @db.Decimal(20, 4)
  deletedAt     DateTime?

  workspace             Workspace                @relation(fields: [workspaceId], references: [id])
  lines                 JournalEntryLine[]
  company               Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  invoices              Invoice[]              @relation("JournalEntry_Invoices")
  bills                 Bill[]                 @relation("JournalEntry_Bills")
  paymentsReceived      PaymentReceived[]      @relation("JournalEntry_PaymentsReceived")
  billPayments          BillPayment[]          @relation("JournalEntry_BillPayments")
  inventoryTransactions InventoryTransaction[] @relation("JournalEntry_InventoryTransactions")
  revenueSchedules      RevenueSchedule[]      @relation("JournalEntry_RevenueSchedules")
  bankDeposits          BankDeposit[]          @relation("JournalEntry_BankDeposits")
  customerRefunds       CustomerRefund[]       @relation("JournalEntry_CustomerRefunds")
  vendorRefunds         VendorRefund[]         @relation("JournalEntry_VendorRefunds")
  writeOffs             WriteOff[]             @relation("JournalEntry_WriteOffs")

  @@index([workspaceId, date])
  @@index([companyId, date])
  @@index([companyId, postingStatus])
  @@index([companyId, postingStatus, date])
  @@index([deletedAt])
  @@index([companyId, date, postingStatus, deletedAt])
  @@index([createdById])
  @@index([updatedById])
} 

model JournalEntryLine {
  id          String  @id @default(uuid())
  journalId   String
  companyId   String
  accountId   String
  debit       Decimal @default(0) @db.Decimal(20, 4)
  credit      Decimal @default(0) @db.Decimal(20, 4)
  description String?
  workspaceId    String @map("tenantId")

  journal    JournalEntry @relation(fields: [journalId], references: [id])
  account    Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)
  workspace  Workspace    @relation(fields: [workspaceId], references: [id])
  company    Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  classId    String?
  class      Class?       @relation(fields: [classId], references: [id])
  locationId String? 
  location   Location?    @relation(fields: [locationId], references: [id])
  
  // Relations
  bankReconciliationLines BankReconciliationLine[]
  projectId  String?
  project    Project?     @relation(fields: [projectId], references: [id])

  @@index([journalId])
  @@index([workspaceId])
  @@index([workspaceId, accountId])
  @@index([workspaceId, accountId, journalId])
  @@index([companyId, accountId, journalId])
}

model Contact {
  id          String   @id @default(uuid())
  workspaceId String   @map("tenantId")
  type        String
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace    Workspace      @relation(fields: [workspaceId], references: [id])
  customer      Customer?
  vendor        Vendor?
  contactEmails ContactEmail[]
  contactPhones ContactPhone[]

  @@index([workspaceId, id])
}

model ContactEmail {
  id        String   @id @default(uuid())
  contactId String
  email     String   @db.VarChar(320)
  type      String   @default("WORK")
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id])

  @@unique([contactId, email])
  @@index([contactId])
}

model ContactPhone {
  id        String   @id @default(uuid())
  contactId String
  phone     String
  type      String   @default("WORK")
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id])

  @@index([contactId])
}

model Customer {
  contactId        String             @id
  workspaceId      String             @map("tenantId")
  // terms            String? -- Deprecated, use paymentTermId
  paymentTermId    String?
  paymentTerm      PaymentTerm?       @relation(fields: [paymentTermId], references: [id])
  priceListId      String?
  priceList        PriceList?         @relation(fields: [priceListId], references: [id])
  
  creditLimit      Decimal?           @db.Decimal(12, 2)
  contact          Contact            @relation(fields: [contactId], references: [id])
  Invoice          Invoice[]
  PaymentReceived  PaymentReceived[]
  RecurringInvoice RecurringInvoice[]
  CustomerCredit   CustomerCredit[]

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
}

model Vendor {
  contactId           String                @id
  workspaceId         String                @map("tenantId")
  
  paymentTermId       String?
  paymentTerm         PaymentTerm?          @relation(fields: [paymentTermId], references: [id])
  
  contact             Contact               @relation(fields: [contactId], references: [id])
  Bill                Bill[]
  PurchaseOrder       PurchaseOrder[]
  VendorCredit        VendorCredit[]
  VendorPaymentMethod VendorPaymentMethod[]
  // Philippine-specific withholding tax relations
  withholdingTaxes    WithholdingTaxDeduction[]
  finalTaxes          FinalTaxDeduction[]

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
}

// --------------------
// Contractors & 1099 (US)
// --------------------

model Contractor {
  id          String   @id @default(uuid())
  workspaceId String   @map("tenantId")
  companyId   String
  vendorId    String
  taxId       String?  @db.VarChar(50)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  vendor    Vendor    @relation(fields: [vendorId], references: [contactId])
  payments  ContractorPayment[]
  forms     Form1099[]

  @@unique([companyId, vendorId])
  @@index([workspaceId])
}

model ContractorPayment {
  id            String   @id @default(uuid())
  workspaceId   String   @map("tenantId")
  companyId     String
  contractorId  String
  vendorId      String
  billPaymentId String?
  paymentDate   DateTime
  amount        Decimal  @db.Decimal(20, 4)
  taxYear       Int
  method        String?
  referenceNumber String?
  createdAt     DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  contractor Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  vendor    Vendor    @relation(fields: [vendorId], references: [contactId])
  billPayment BillPayment? @relation(fields: [billPaymentId], references: [id])

  @@index([companyId, paymentDate])
  @@index([contractorId, taxYear])
  @@index([vendorId])
}

model Form1099 {
  id            String   @id @default(uuid())
  workspaceId   String   @map("tenantId")
  companyId     String
  contractorId  String
  taxYear       Int
  formType      String   @default("1099-NEC") // 1099-NEC, 1099-MISC
  status        Form1099Status   @default(DRAFT) // DRAFT, FILED, VOID
  filedAt       DateTime?
  totalAmount   Decimal  @db.Decimal(20, 4)
  createdAt     DateTime @default(now())

  workspace  Workspace  @relation(fields: [workspaceId], references: [id])
  company    Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  contractor Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  boxes      Form1099Box[]

  @@unique([companyId, contractorId, taxYear, formType])
  @@index([workspaceId, taxYear])
}

model Form1099Box {
  id        String  @id @default(uuid())
  formId    String
  boxNumber String  // e.g., "1", "4", "7"
  amount    Decimal @db.Decimal(20, 4)

  form Form1099 @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([formId, boxNumber])
}

model Item {
  id                      String                     @id @default(uuid())
  companyId               String
  sku                     String?
  name                    String
  type                    String
  salesPrice              Decimal?                   @db.Decimal(20, 4) // Base sales price
  purchaseCost            Decimal?                   @db.Decimal(20, 4) // Base purchase cost
  standardCost            Decimal?                   @db.Decimal(20, 4) // Standard cost for variance analysis
  discountAllowed         Boolean                    @default(true)
  maxDiscountPercent      Decimal?                   @db.Decimal(5, 2)
  
  trackingType            String?                    @default("NONE") // NONE, SERIAL, LOT
  createdAt               DateTime                   @default(now())
  inventoryAssetAccountId String?
  cogsAccountId           String?
  inventoryReserveAccountId String?
  costMethod              String?                    @default("FIFO")
  InvoiceLine             InvoiceLine[]
  BillLine                BillLine[]
  PurchaseOrderLine       PurchaseOrderLine[]
  stockLevels             StockLevel[]
  inventoryLines          InventoryTransactionLine[]
  costLayers              InventoryCostLayer[]
  priceListItems          PriceListItem[]
  // Assembly relations
  assemblyBuilds          AssemblyBuild[]      @relation("ItemBuilt")
  assemblyComponents      AssemblyComponent[]  @relation("ItemComponent")
  cogsAccount             Account?                   @relation("Item_cogsAccount", fields: [cogsAccountId], references: [id])
  inventoryReserveAccount Account?                   @relation("Item_inventoryReserve", fields: [inventoryReserveAccountId], references: [id])
  company                 Company                    @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId])
}

model PriceList {
  id          String   @id @default(uuid())
  workspaceId String
  name        String   // e.g., "Wholesale", "Retail"
  currency    String
  isDefault   Boolean  @default(false)
  
  workspace   Workspace       @relation(fields: [workspaceId], references: [id])
  items       PriceListItem[]
  customers   Customer[]

  @@index([workspaceId])
  @@unique([workspaceId, name])
}

model PriceListItem {
  id          String  @id @default(uuid())
  priceListId String
  itemId      String
  price       Decimal @db.Decimal(20, 4)

  priceList PriceList @relation(fields: [priceListId], references: [id])
  item      Item      @relation(fields: [itemId], references: [id])

  @@unique([priceListId, itemId])
} 

model InventoryCostLayer {
  id                String   @id @default(uuid())
  companyId         String
  itemId            String
  inventoryTxLineId String? // link back to the transaction line that created this layer
  quantity          Decimal  @db.Decimal(28, 6)
  remainingQty      Decimal  @db.Decimal(28, 6)
  unitCost          Decimal  @db.Decimal(28, 6)
  createdAt         DateTime @default(now())

  item    Item                      @relation(fields: [itemId], references: [id])
  txLine  InventoryTransactionLine? @relation("tx_line_costlayers", fields: [inventoryTxLineId], references: [id])
  company Company                   @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId, itemId])
} 

model StockLocation {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  stockLevels      StockLevel[]
  transactionLines InventoryTransactionLine[]
  company          Company                   @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId, name])
} 

// --------------------
// Payroll (Phase 1 MVP - US)
// --------------------

model Employee {
  id              String    @id @default(uuid())
  companyId       String
  contactId       String? // optional link to Contact
  employeeNumber  String?
  firstName       String
  lastName        String
  taxId           String?
  ssnHash         String?   @db.Text
  hireDate        DateTime?
  terminationDate DateTime?
  payRate         Decimal?  @db.Decimal(12, 2) // default hourly/salary rate
  payType         String? // SALARY | HOURLY
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company               Company               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  // back-references for payroll relations
  payrollRunEmployees   PayrollRunEmployee[]
  paychecks             Paycheck[]
  // Time tracking back-relations
  timesheets            Timesheet[]
  timeEntries           TimeEntry[]
  taxInfo               EmployeeTaxInfo?
  i9Form                FormI9?
  // Philippine-specific deductions
  payrollDeductions     PhilippinePayrollDeduction[]
  employeeLoans         EmployeeLoan[]
  loanPayments          EmployeeLoanPayment[]
  timeOffBalances       TimeOffBalance[]
  timeOffRequests       TimeOffRequest[]
  thirteenthMonthPays   ThirteenthMonthPay[]
  governmentContributionPayments GovernmentContributionPayment[]

  @@index([companyId])
  @@unique([companyId, employeeNumber])
  @@unique([companyId, taxId])
  @@unique([companyId, ssnHash])
}

model PaySchedule {
  id        String   @id @default(uuid())
  companyId String
  name      String
  frequency PayrollFrequency
  createdAt DateTime @default(now())

  company     Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  payrollRuns PayrollRun[]

  @@index([companyId])
} 

model PayrollRun {
  id            String    @id @default(uuid())
  companyId     String
  payScheduleId String?
  startDate     DateTime
  endDate       DateTime
  status        PayrollRunStatus    @default(DRAFT) // DRAFT | SUBMITTED | POSTED | VOID
  createdAt     DateTime  @default(now())
  submittedAt   DateTime?
  deletedAt     DateTime?

  company       Company               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  paySchedule   PaySchedule?         @relation(fields: [payScheduleId], references: [id])
  employees     PayrollRunEmployee[]
  paychecks     Paycheck[] 
  postingStatus PostingStatus        @default(DRAFT)

  @@index([companyId, status])
  @@index([deletedAt])
  @@unique([companyId, startDate, endDate])
}

model PayrollRunEmployee {
  id           String   @id @default(uuid())
  companyId    String
  payrollRunId String
  employeeId   String
  grossAmount  Decimal  @db.Decimal(20, 4)
  netAmount    Decimal  @db.Decimal(20, 4)
  createdAt    DateTime @default(now())

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id])
  employee   Employee   @relation(fields: [employeeId], references: [id])

  @@index([companyId])
  @@index([employeeId])
}

model Paycheck {
  id           String    @id @default(uuid())
  companyId    String
  payrollRunId String?
  employeeId   String
  checkNumber  String?
  date         DateTime
  grossAmount  Decimal   @db.Decimal(20, 4)
  netAmount    Decimal   @db.Decimal(20, 4)
  createdAt    DateTime  @default(now())
  postedAt     DateTime?
  deletedAt    DateTime?
  templateId   String?

  company    Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  taxInfo               EmployeeTaxInfo?
  i9Form                FormI9?
  payrollRun PayrollRun? @relation(fields: [payrollRunId], references: [id])
  employee   Employee    @relation(fields: [employeeId], references: [id])
  template   DocumentTemplate? @relation(fields: [templateId], references: [id])

  paycheckLines PaycheckLine[]
  paycheckTaxes PaycheckTax[]
  expenseClaims ExpenseClaim[]

  @@index([companyId, employeeId])
  @@index([companyId, templateId])
  @@index([deletedAt])
} 

// (Payroll reverse relations are defined on the original Employee model)

model PaycheckLine {
  id          String  @id @default(uuid())
  paycheckId  String
  lineType    String // EARNING, DEDUCTION, TAX
  description String?
  amount      Decimal @db.Decimal(20, 4)
  companyId    String

  paycheck Paycheck @relation(fields: [paycheckId], references: [id])
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([paycheckId])
  @@index([companyId])
}

model PaycheckTax {
  id           String   @id @default(uuid())
  paycheckId   String
  companyId    String
  amount       Decimal  @db.Decimal(20, 4)
  createdAt    DateTime @default(now())

  paycheck Paycheck @relation(fields: [paycheckId], references: [id])
  company   Company   @relation(fields: [companyId], references: [id])

  @@index([paycheckId])
  @@index([companyId])
}

model EmployeeLoan {
  id           String   @id @default(uuid())
  companyId    String
  employeeId   String
  loanNumber   String
  principalAmount Decimal @db.Decimal(20, 4)
  interestRate Decimal? @db.Decimal(10, 6)
  startDate    DateTime
  endDate      DateTime?
  balance      Decimal @db.Decimal(20, 4)
  status       String  @default("ACTIVE") // ACTIVE, CLOSED, DEFAULTED
  createdAt    DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee Employee @relation(fields: [employeeId], references: [id])
  payments EmployeeLoanPayment[]

  @@unique([companyId, loanNumber])
  @@index([companyId, status])
  @@index([employeeId])
}

model EmployeeLoanPayment {
  id          String   @id @default(uuid())
  companyId   String
  employeeId  String
  loanId      String
  paymentDate DateTime
  amount      Decimal  @db.Decimal(20, 4)
  interestAmount Decimal? @db.Decimal(20, 4)
  principalAmount Decimal? @db.Decimal(20, 4)
  createdAt   DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee Employee @relation(fields: [employeeId], references: [id])
  loan     EmployeeLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([companyId, employeeId, paymentDate])
  @@index([loanId])
}

model TimeOffBalance {
  id          String   @id @default(uuid())
  companyId   String
  employeeId  String
  timeOffType TimeOffType
  balance     Decimal  @db.Decimal(12, 4)
  accrualRate Decimal? @db.Decimal(12, 6)
  updatedAt   DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([companyId, employeeId, timeOffType])
  @@index([companyId, employeeId])
}

model TimeOffRequest {
  id          String   @id @default(uuid())
  companyId   String
  employeeId  String
  timeOffType TimeOffType
  startDate   DateTime
  endDate     DateTime
  hours       Decimal? @db.Decimal(12, 4)
  status      TimeOffRequestStatus @default(PENDING)
  requestedAt DateTime @default(now())
  approvedAt  DateTime?
  approverId  String?

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee Employee @relation(fields: [employeeId], references: [id])
  approver User?    @relation(fields: [approverId], references: [id])

  @@index([companyId, status])
  @@index([employeeId, status])
  @@index([approverId])
}

model ThirteenthMonthPay {
  id          String   @id @default(uuid())
  companyId   String
  employeeId  String
  taxYear     Int
  amount      Decimal  @db.Decimal(20, 4)
  releasedAt  DateTime?
  createdAt   DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([companyId, employeeId, taxYear])
  @@index([companyId, taxYear])
}

model GovernmentContributionPayment {
  id          String   @id @default(uuid())
  companyId   String
  employeeId  String?
  contributionType GovernmentContributionType
  period      String
  amount      Decimal  @db.Decimal(20, 4)
  paidAt      DateTime?
  referenceNumber String?
  createdAt   DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee Employee? @relation(fields: [employeeId], references: [id])

  @@index([companyId, period, contributionType])
  @@index([employeeId])
}

model PayrollAccrual {
  id             String   @id @default(uuid())
  companyId      String
  employeeId     String
  type           String   // WAGES, PTO, BONUS, COMMISSION
  periodStart    DateTime
  periodEnd      DateTime
  amount         Decimal  @db.Decimal(20, 4)
  accountId      String?
  status         String   // ACCRUED, PAID
  journalEntryId String?
  createdAt      DateTime @default(now())

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee     Employee      @relation(fields: [employeeId], references: [id])
  account      Account?      @relation(fields: [accountId], references: [id])
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@index([companyId, periodEnd])
  @@index([employeeId])
  @@index([journalEntryId])
}

model StockLevel {
  id              String   @id @default(uuid())
  companyId       String?
  itemId          String
  stockLocationId String
  quantity        Decimal  @db.Decimal(28, 6)
  reserved        Decimal  @default(0) @db.Decimal(28, 6)
  updatedAt       DateTime @updatedAt

  company        Company?      @relation(fields: [companyId], references: [id])
  item          Item          @relation(fields: [itemId], references: [id])
  stockLocation StockLocation @relation(fields: [stockLocationId], references: [id])

  @@unique([companyId, itemId, stockLocationId])
  @@index([companyId, itemId])
}

model InventoryTransaction {
  id                String   @id @default(uuid())
  workspaceId       String   @map("tenantId")
  companyId         String?
  transactionNumber String?
  type              String // RECEIPT, SHIPMENT, TRANSFER, ADJUSTMENT
  reference         String?
  createdAt         DateTime @default(now())
  deletedAt         DateTime?

  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  workspace       Workspace                  @relation(fields: [workspaceId], references: [id])
  lines          InventoryTransactionLine[]
  postingStatus  PostingStatus              @default(DRAFT)
  company        Company?                   @relation(fields: [companyId], references: [id])
  journalEntryId String?
  journalEntry   JournalEntry?              @relation("JournalEntry_InventoryTransactions", fields: [journalEntryId], references: [id])
  invoiceId      String?
  invoice        Invoice?                   @relation(fields: [invoiceId], references: [id])

  @@index([workspaceId, transactionNumber])
  @@index([workspaceId, createdAt])
  @@index([journalEntryId])
  @@index([deletedAt])
}

model InventoryTransactionLine {
  id              String   @id @default(uuid())
  workspaceId     String   @map("tenantId")
  companyId       String?
  transactionId   String
  itemId          String
  stockLocationId String?
  qty             Decimal  @db.Decimal(28, 6)
  unitCost        Decimal? @db.Decimal(28, 6)
  lineType        String?
  serialNumber    String?
  lotNumber       String?
  expirationDate  DateTime?

  workspace     Workspace               @relation(fields: [workspaceId], references: [id])
  transaction   InventoryTransaction @relation(fields: [transactionId], references: [id])
  item          Item                 @relation(fields: [itemId], references: [id])
  stockLocation StockLocation?       @relation(fields: [stockLocationId], references: [id])
  costLayers    InventoryCostLayer[] @relation("tx_line_costlayers")
  company       Company?             @relation(fields: [companyId], references: [id])
  classId       String?
  class         Class?               @relation(fields: [classId], references: [id])
  locationId    String?
  location      Location?            @relation(fields: [locationId], references: [id])
  projectId     String?
  project       Project?             @relation(fields: [projectId], references: [id])

  @@index([workspaceId, itemId])
  @@index([workspaceId, transactionId])
  @@index([companyId, itemId])
  @@index([itemId, stockLocationId])
  @@index([transactionId, itemId])
  @@index([serialNumber])
  @@index([lotNumber])
  @@index([expirationDate])
  @@unique([itemId, serialNumber], name: "item_serial_unique")
}

model InventoryReserve {
  id          String   @id @default(uuid())
  companyId   String
  itemId      String?
  reserveType String   // OBSOLETE, SLOW_MOVING, DAMAGED
  amount      Decimal  @db.Decimal(20, 4)
  reason      String?
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  item    Item?   @relation(fields: [itemId], references: [id])

  @@index([companyId, itemId])
}

model COGSRecognition {
  id                String   @id @default(uuid())
  companyId         String
  invoiceLineId     String?
  inventoryTxLineId String?
  itemId            String
  quantity          Decimal  @db.Decimal(28, 6)
  unitCost          Decimal  @db.Decimal(28, 6)
  totalCost         Decimal  @db.Decimal(20, 4)
  journalEntryId    String?
  recognizedAt      DateTime @default(now())

  company          Company                  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  invoiceLine      InvoiceLine?             @relation(fields: [invoiceLineId], references: [id])
  inventoryTxLine  InventoryTransactionLine? @relation(fields: [inventoryTxLineId], references: [id])
  item             Item                     @relation(fields: [itemId], references: [id])
  journalEntry     JournalEntry?            @relation(fields: [journalEntryId], references: [id])

  @@index([companyId, recognizedAt])
  @@index([invoiceLineId])
  @@index([inventoryTxLineId])
  @@index([journalEntryId])
}

model InventoryAdjustmentRequest {
  id           String   @id @default(uuid())
  workspaceId  String   @map("tenantId")
  companyId    String
  transactionId String?
  requestedById String
  reason       String?
  status       InventoryAdjustmentStatus @default(PENDING) // PENDING, APPROVED, REJECTED
  requestedAt  DateTime @default(now())

  workspace   Workspace           @relation(fields: [workspaceId], references: [id])
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  transaction InventoryTransaction? @relation(fields: [transactionId], references: [id])
  requestedBy User                @relation(fields: [requestedById], references: [id])
  approvals   InventoryAdjustmentApproval[]

  @@index([workspaceId, status])
  @@index([companyId, status])
  @@index([transactionId])
}

model InventoryAdjustmentApproval {
  id         String   @id @default(uuid())
  requestId  String
  approverId String
  status     InventoryAdjustmentStatus   @default(PENDING) // PENDING, APPROVED, REJECTED
  note       String?
  createdAt  DateTime @default(now())

  request  InventoryAdjustmentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approver User                     @relation(fields: [approverId], references: [id])

  @@index([requestId])
  @@index([approverId])
}

// --------------------
// Manufacturing / Assembly
// --------------------

model AssemblyBuild {
  id              String   @id @default(uuid())
  companyId       String
  inventoryTxId   String?  // Links to the Stock adjustment (InventoryTransaction)
  itemId          String   // The item being built (e.g., "Bike")
  quantity        Decimal  @db.Decimal(12, 4)
  date            DateTime @default(now())
  status          String   @default("COMPLETED") // PENDING, COMPLETED, VOID
  
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  item            Item     @relation("ItemBuilt", fields: [itemId], references: [id])
  components      AssemblyComponent[]

  @@index([companyId])
  @@index([itemId])
}

model AssemblyComponent {
  id              String  @id @default(uuid())
  assemblyBuildId String
  itemId          String  // Raw material (e.g., "Wheel")
  quantityUsed    Decimal @db.Decimal(12, 4)
  
  assemblyBuild   AssemblyBuild @relation(fields: [assemblyBuildId], references: [id], onDelete: Cascade)
  item            Item          @relation("ItemComponent", fields: [itemId], references: [id])

  @@index([assemblyBuildId])
  @@index([itemId])
}

model ProductionRun {
  id             String   @id @default(uuid())
  companyId      String
  itemId         String
  quantity       Decimal  @db.Decimal(12, 4)
  standardCost   Decimal? @db.Decimal(20, 4)
  actualCost     Decimal? @db.Decimal(20, 4)
  varianceAmount Decimal? @db.Decimal(20, 4)
  varianceAccountId String?
  status         String   @default("COMPLETED") // PLANNED, IN_PROGRESS, COMPLETED, VOID
  journalEntryId String?
  createdAt      DateTime @default(now())

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  item          Item          @relation(fields: [itemId], references: [id])
  varianceAccount Account?    @relation(fields: [varianceAccountId], references: [id])
  journalEntry  JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@index([companyId, itemId])
  @@index([journalEntryId])
}

// NOTE: legacy alias models removed; code should prefer `tenant` and `account` models.

// --------------------
// Taxation & Jurisdictions
// --------------------

model TaxJurisdiction {
  id        String   @id @default(uuid())
  countryId String
  name      String
  region    String? // state/province
  code      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  country   Country  @relation(fields: [countryId], references: [id])
  taxRates  TaxRate[]

  @@unique([countryId, region, code])
  @@index([countryId])
}

model TaxAuthority {
  id               String   @id @default(uuid())
  countryId        String
  name             String   // e.g., BIR, IRS, HMRC
  code             String?
  jurisdictionType TaxAuthorityJurisdictionType
  contactInfo      Json?
  filingMethods    TaxFilingMethod[]
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  country  Country   @relation(fields: [countryId], references: [id])
  returns  TaxReturn[]
  communications TaxAuthorityCommunication[]
  obligations TaxObligation[]
  auditCases  TaxAuditCase[]
  advancePricingAgreements AdvancePricingAgreement[]
  uncertainTaxPositions UncertainTaxPosition[]
  taxClearanceCertificates TaxClearanceCertificate[]

  @@unique([countryId, name])
  @@index([countryId])
}

model TaxObligation {
  id          String   @id @default(uuid())
  companyId   String
  authorityId String
  formType    String
  periodStart DateTime
  periodEnd   DateTime
  dueDate     DateTime
  status      TaxObligationStatus @default(PENDING)
  filedAt     DateTime?
  paidAt      DateTime?
  taxReturnId String?
  createdAt   DateTime @default(now())

  company   Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  authority TaxAuthority @relation(fields: [authorityId], references: [id])
  taxReturn TaxReturn?   @relation(fields: [taxReturnId], references: [id])

  @@unique([companyId, authorityId, formType, periodStart])
  @@index([companyId, dueDate, status])
  @@index([authorityId, status])
}

model TaxAuditCase {
  id          String   @id @default(uuid())
  companyId   String
  authorityId String
  taxReturnId String?
  caseNumber  String?
  scope       String?
  periodStart DateTime?
  periodEnd   DateTime?
  status      TaxAuditStatus @default(OPEN)
  openedAt    DateTime @default(now())
  closedAt    DateTime?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())

  company   Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  authority TaxAuthority @relation(fields: [authorityId], references: [id])
  taxReturn TaxReturn?   @relation(fields: [taxReturnId], references: [id])

  @@index([companyId, status])
  @@index([authorityId, status])
}

model TaxAuthorityCommunication {
  id          String   @id @default(uuid())
  companyId   String
  authorityId String
  type        TaxAuthorityCommunicationType
  subject     String
  content     Json
  sentAt      DateTime?
  receivedAt  DateTime?
  status      TaxAuthorityCommunicationStatus @default(DRAFT)
  createdAt   DateTime @default(now())

  company   Company      @relation(fields: [companyId], references: [id])
  authority TaxAuthority @relation(fields: [authorityId], references: [id])

  @@index([companyId, authorityId])
  @@index([authorityId, status])
}

model TaxOptimizationSuggestion {
  id               String   @id @default(uuid())
  companyId        String
  suggestionType   TaxOptimizationSuggestionType
  description      String
  potentialSavings Decimal @db.Decimal(20, 4)
  confidence       Decimal @db.Decimal(5, 2)
  status           TaxOptimizationStatus @default(PENDING)
  createdAt        DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, status])
}

model TaxRiskScore {
  id            String   @id @default(uuid())
  companyId     String
  period        String   // 2024-Q4
  overallScore  Decimal  @db.Decimal(5, 2)
  components    Json     // { transferPricing: 85, vatCompliance: 92, ... }
  createdAt     DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, period])
  @@index([companyId, period])
}

model TaxReturn {
  id               String   @id @default(uuid())
  companyId        String
  authorityId      String
  formType         String   // 2550Q, 941, VAT100, GST-7
  periodStart      DateTime
  periodEnd        DateTime
  filingDeadline   DateTime
  status           FilingStatus @default(DRAFT)
  filedAt          DateTime?
  dueDate          DateTime?
  totalTax         Decimal  @db.Decimal(20, 4)
  totalPenalty     Decimal? @db.Decimal(20, 4)
  totalInterest    Decimal? @db.Decimal(20, 4)
  paymentDeadline  DateTime?
  referenceNumber  String?
  efilingReference String?
  efilingStatus    String?
  efilingSubmittedAt DateTime?
  efilingResponse  Json?
  attachmentId     String?
  filingMethod     TaxFilingMethod?
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  company   Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  authority TaxAuthority @relation(fields: [authorityId], references: [id])
  attachment Attachment? @relation(fields: [attachmentId], references: [id])
  lines     TaxReturnLine[]
  payments  TaxPayment[]
  amendments TaxReturnAmendment[]

  @@unique([companyId, authorityId, formType, periodStart])
  @@index([companyId, periodStart, periodEnd])
  @@index([filingDeadline])
  @@index([attachmentId])
}

model TaxReturnLine {
  id          String   @id @default(uuid())
  taxReturnId String
  taxRateId   String?
  jurisdictionId String?
  taxableAmount Decimal? @db.Decimal(20, 4)
  taxAmount    Decimal  @db.Decimal(20, 4)

  taxReturn   TaxReturn      @relation(fields: [taxReturnId], references: [id], onDelete: Cascade)
  taxRate     TaxRate?        @relation(fields: [taxRateId], references: [id])
  jurisdiction TaxJurisdiction? @relation(fields: [jurisdictionId], references: [id])

  @@index([taxReturnId])
  @@index([taxRateId])
  @@index([jurisdictionId])
}

model TaxPayment {
  id          String   @id @default(uuid())
  taxReturnId String
  paymentDate DateTime
  amount      Decimal  @db.Decimal(20, 4)
  method      String?
  referenceNumber String?
  createdAt   DateTime @default(now())

  taxReturn TaxReturn @relation(fields: [taxReturnId], references: [id], onDelete: Cascade)

  @@index([taxReturnId, paymentDate])
}

model TaxReturnAmendment {
  id              String   @id @default(uuid())
  taxReturnId     String
  amendmentNumber Int      @default(1)
  reason          String
  changes         Json
  filedAt         DateTime?
  createdAt       DateTime @default(now())

  taxReturn TaxReturn @relation(fields: [taxReturnId], references: [id], onDelete: Cascade)

  @@unique([taxReturnId, amendmentNumber])
}

model TaxCalculationAudit {
  id               String   @id @default(uuid())
  companyId        String
  calculationId    String
  calculationType  String   // INVOICE_TAX, WITHHOLDING, VAT
  inputs           Json
  rulesApplied     Json
  result           Json
  calculatedAt     DateTime @default(now())
  calculatedById   String?

  company      Company @relation(fields: [companyId], references: [id])
  calculatedBy User?   @relation(fields: [calculatedById], references: [id])

  @@index([companyId, calculatedAt])
  @@index([calculationType, calculationId])
  @@index([calculatedById])
}

model TaxPeriodLock {
  id        String   @id @default(uuid())
  companyId String
  countryId String
  taxType   String   // VAT, INCOME_TAX, WITHHOLDING
  period    String   // 2024-Q1
  lockedAt  DateTime @default(now())
  lockedById String?
  reason    String?

  company Company @relation(fields: [companyId], references: [id])
  country Country @relation(fields: [countryId], references: [id])
  lockedBy User?  @relation(fields: [lockedById], references: [id])

  @@unique([companyId, countryId, taxType, period])
  @@index([companyId, period])
  @@index([countryId, taxType, period])
}

model TaxFilingPackage {
  id           String   @id @default(uuid())
  companyId    String
  filingId     String
  packageType  String   // PRIMARY, AMENDMENT, SUPPORTING_DOCS
  documents    Json
  generatedAt  DateTime @default(now())
  submittedAt  DateTime?
  acknowledgementNumber String?

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, submittedAt])
  @@index([companyId, packageType])
}

model WithholdingTaxCertificate {
  id                String   @id @default(uuid())
  companyId         String
  vendorId          String
  certificateType   String   // 2307, 2316
  certificateNumber String
  periodCovered     String
  amount            Decimal  @db.Decimal(20, 4)
  dateIssued        DateTime
  dateReceived      DateTime?
  status            String

  company Company @relation(fields: [companyId], references: [id])
  vendor  Vendor  @relation(fields: [vendorId], references: [contactId])

  @@unique([companyId, certificateNumber])
  @@index([vendorId, periodCovered])
}

model TaxCalendar {
  id           String   @id @default(uuid())
  companyId    String
  countryId    String
  taxType      String
  obligation   String   // FILING, PAYMENT, RENEWAL
  dueDate      DateTime
  completedAt  DateTime?
  reminderSent Boolean  @default(false)

  company Company @relation(fields: [companyId], references: [id])
  country Country @relation(fields: [countryId], references: [id])

  @@index([companyId, dueDate, completedAt])
  @@index([countryId, taxType, dueDate])
}

model UserActionAudit {
  id          String   @id @default(uuid())
  userId      String
  companyId   String?
  actionType  String   // VIEW, CREATE, UPDATE, DELETE, APPROVE
  entityType  String
  entityId    String?
  ipAddress   String?
  userAgent   String?
  timestamp   DateTime @default(now())
  details     Json?

  user    User     @relation(fields: [userId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])

  @@index([userId, timestamp])
  @@index([companyId, timestamp])
}

model TaxFilingBatch {
  id          String   @id @default(uuid())
  companyId   String
  batchType   String   // VAT, WITHHOLDING, INCOME_TAX
  period      String   // 2024-Q4
  status      String   @default("PENDING")
  totalForms  Int      @default(0)
  processed   Int      @default(0)
  failed      Int      @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, batchType, period])
}

model ComplianceDeadline {
  id           String   @id @default(uuid())
  companyId    String
  countryId    String
  deadlineType String   // TAX_FILING, TAX_PAYMENT, ANNUAL_REPORT, LICENSE_RENEWAL
  description  String
  dueDate      DateTime
  reminderDays Int[]
  status       String   @default("PENDING")
  completedAt  DateTime?

  company Company @relation(fields: [companyId], references: [id])
  country Country @relation(fields: [countryId], references: [id])

  @@index([companyId, dueDate, status])
  @@index([countryId, deadlineType, dueDate])
}

model TaxClearanceCertificate {
  id                String   @id @default(uuid())
  companyId         String
  certificateNumber String
  authorityId       String
  issueDate         DateTime
  expiryDate        DateTime
  status            String   @default("ACTIVE")
  fileUrl           String?

  company   Company      @relation(fields: [companyId], references: [id])
  authority TaxAuthority @relation(fields: [authorityId], references: [id])

  @@unique([companyId, certificateNumber])
  @@index([companyId, expiryDate])
}

model BusinessPermit {
  id               String   @id @default(uuid())
  companyId         String
  permitNumber      String
  issuingAuthority  String
  permitType        String   // MAYORS_PERMIT, SEC_REGISTRATION, DTI
  issueDate         DateTime
  expiryDate        DateTime
  renewalDeadline   DateTime?
  status            String   @default("ACTIVE")
  fileUrl           String?

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, permitNumber])
  @@index([companyId, expiryDate])
}

model TaxAttributeCarryforward {
  id              String   @id @default(uuid())
  companyId       String
  surrenderedToCompanyId String?
  countryId       String?
  jurisdictionId  String?
  attributeType   TaxAttributeType
  taxType         String?
  originPeriod    String
  expiryDate      DateTime?
  originalAmount  Decimal  @db.Decimal(20, 4)
  remainingAmount Decimal  @db.Decimal(20, 4)
  surrenderedAmount Decimal? @db.Decimal(20, 4)
  status          TaxAttributeStatus @default(ACTIVE)
  createdAt       DateTime @default(now())

  company      Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  surrenderedToCompany Company? @relation("TaxAttributeSurrenderedTo", fields: [surrenderedToCompanyId], references: [id])
  country      Country?         @relation(fields: [countryId], references: [id])
  jurisdiction TaxJurisdiction? @relation(fields: [jurisdictionId], references: [id])

  @@index([companyId, attributeType, status])
  @@index([countryId, jurisdictionId])
}

model UncertainTaxPosition {
  id                  String   @id @default(uuid())
  companyId           String
  period              String
  description         String
  probableAmount      Decimal  @db.Decimal(20, 4)
  possibleRangeLow    Decimal? @db.Decimal(20, 4)
  possibleRangeHigh   Decimal? @db.Decimal(20, 4)
  recognitionStatus   String   // RECOGNIZED, NOT_RECOGNIZED
  taxAuthorityId      String?
  createdAt           DateTime @default(now())

  company   Company      @relation(fields: [companyId], references: [id])
  authority TaxAuthority? @relation(fields: [taxAuthorityId], references: [id])

  @@index([companyId, period])
  @@index([taxAuthorityId])
}

model TaxIncentive {
  id             String   @id @default(uuid())
  companyId      String
  countryId      String
  incentiveType  String   // BOI, PEZA, SEZ, R&D_CREDIT
  referenceNumber String?
  effectiveDate  DateTime
  expiryDate     DateTime?
  reducedRate    Decimal? @db.Decimal(10, 6)
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  country Country @relation(fields: [countryId], references: [id])

  @@unique([companyId, incentiveType, effectiveDate])
  @@index([companyId, status])
  @@index([countryId])
}

model TransferPricingDocument {
  id             String   @id @default(uuid())
  companyId      String
  relatedPartyId String?
  fiscalYear     Int
  documentType   TransferPricingDocumentType
  fileUrl        String?
  armLengthTestResult Json?
  riskLevel      String?
  complianceStatus String?
  reviewedAt     DateTime?
  referenceNumber String?
  description    String?
  attachmentId   String?
  createdAt      DateTime @default(now())

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  relatedParty  RelatedParty? @relation(fields: [relatedPartyId], references: [id])
  attachment    Attachment?   @relation(fields: [attachmentId], references: [id])

  @@unique([companyId, relatedPartyId, fiscalYear, documentType])
  @@index([companyId, fiscalYear])
  @@index([relatedPartyId])
}

model AdvancePricingAgreement {
  id                  String   @id @default(uuid())
  companyId           String
  taxAuthorityId      String
  agreementNumber     String
  effectiveDate       DateTime
  expirationDate      DateTime
  coveredTransactions Json
  terms               Json
  status              String   // ACTIVE, EXPIRED, RENEWED
  renewalDeadline     DateTime?
  createdAt           DateTime @default(now())

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  taxAuthority TaxAuthority @relation(fields: [taxAuthorityId], references: [id])

  @@unique([companyId, taxAuthorityId, agreementNumber])
  @@index([companyId, status])
}

model DeferredTax {
  id                   String   @id @default(uuid())
  companyId            String
  period               String   // 2024-Q4
  temporaryDifference  Decimal  @db.Decimal(20, 4)
  taxRate              Decimal  @db.Decimal(10, 6)
  deferredAmount       Decimal  @db.Decimal(20, 4)
  type                 DeferredTaxType
  isPermanent          Boolean  @default(false)
  description          String?
  sourceType           String?  // DEPRECIATION, WARRANTY, BAD_DEBT, INVENTORY
  sourceId             String?
  reversalPeriod       String?
  accountId            String?
  createdAt            DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  account Account? @relation(fields: [accountId], references: [id])

  @@unique([companyId, period, sourceType, sourceId])
  @@index([companyId, period])
  @@index([companyId, type])
  @@index([companyId, reversalPeriod])
}

model FinancialRatio {
  id              String   @id @default(uuid())
  companyId       String
  period          String   // 2024-12
  ratioType       String   // CURRENT_RATIO, QUICK_RATIO, DEBT_TO_EQUITY, GROSS_MARGIN
  value           Decimal  @db.Decimal(10, 4)
  benchmark       Decimal? @db.Decimal(10, 4)
  industryAverage Decimal? @db.Decimal(10, 4)
  trend           String?  // IMPROVING, DECLINING, STABLE
  createdAt       DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, period, ratioType])
  @@index([companyId, period])
}

model EsgMetric {
  id           String   @id @default(uuid())
  companyId    String
  metricType   String   // CARBON_EMISSIONS, WATER_USAGE, ENERGY_CONSUMPTION, DIVERSITY_SCORE
  period       String   // 2024
  value        Decimal  @db.Decimal(20, 4)
  unit         String   // tCO2e, m³, kWh, percentage
  source       String?  // CALCULATED, REPORTED, ESTIMATED
  verification String?  // SELF_REPORTED, THIRD_PARTY, AUDITED
  verifiedAt   DateTime?
  createdAt    DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, metricType, period])
  @@index([companyId, period])
}

model TaxRate {
  id            String    @id @default(uuid())
  companyId     String
  countryId     String?   // Link to country for jurisdiction-specific rules
  jurisdictionId String? // Link to sub-national jurisdiction when applicable
  name          String
  rate          Decimal   @db.Decimal(10, 6)
  // Optional global tax attributes
  jurisdictionLevel String? // FEDERAL, STATE, COUNTY, CITY, SPECIAL
  taxType           String? // VAT, GST, SALES_TAX, WITHHOLDING, etc.
  globalTaxType     GlobalTaxType?
  thresholdAmount   Decimal? @db.Decimal(20, 4)
  exemptionAmount   Decimal? @db.Decimal(20, 4)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isCompound    Boolean   @default(false)
  createdAt     DateTime  @default(now())

  company     Company        @relation(fields: [companyId], references: [id])
  country     Country?       @relation(fields: [countryId], references: [id])
  jurisdiction TaxJurisdiction? @relation(fields: [jurisdictionId], references: [id])
  TaxCodeRate TaxCodeRate[]
  LineTax     LineTax[]

  @@index([companyId, jurisdictionId, effectiveFrom])
  @@index([countryId, jurisdictionId])
  @@index([taxType])
  @@index([globalTaxType])
  @@index([jurisdictionLevel])
  @@index([companyId, taxType, effectiveFrom])
  @@index([countryId, jurisdictionId, taxType, effectiveFrom])
}

// TaxRule: complex or JSON-based rules per country/jurisdiction
model TaxRule {
  id             String   @id @default(uuid())
  countryId      String
  jurisdictionId String?
  name           String
  description    String?
  /// JSON rules defining brackets/thresholds or other logic.
  /// Example:
  /// {
  ///   "brackets": [ { "upTo": 10000, "rate": 0.10 }, { "upTo": 50000, "rate": 0.12 }, { "upTo": null, "rate": 0.15 } ]
  /// }
  rules          Json     // Free-form rules, brackets, thresholds, etc.
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  country      Country         @relation(fields: [countryId], references: [id])
  jurisdiction TaxJurisdiction? @relation(fields: [jurisdictionId], references: [id])

  @@index([countryId, jurisdictionId])
}

model TaxCode {
  id        String        @id @default(uuid())
  companyId String
  code      String
  name      String
  isDefault Boolean       @default(false)
  createdAt DateTime      @default(now())
  rates     TaxCodeRate[]

  company         Company          @relation(fields: [companyId], references: [id])
  LineTax        LineTax[]
  TaxCodeAccount TaxCodeAccount[]

  @@unique([companyId, code])
} 

model TaxCodeRate {
  id        String  @id @default(uuid())
  taxCodeId String
  taxRateId String
  companyId String
  sequence  Int     @default(1)
  ratePct   Decimal @db.Decimal(10, 6)

  taxCode TaxCode @relation(fields: [taxCodeId], references: [id])
  taxRate TaxRate @relation(fields: [taxRateId], references: [id])
  company Company  @relation(fields: [companyId], references: [id])

  @@index([taxCodeId, taxRateId])
  @@index([companyId, taxCodeId])
} 

model LineTax {
  id                  String  @id @default(uuid())
  companyId           String
  invoiceLineId       String?
  billLineId          String?
  purchaseOrderLineId String?
  quoteLineId         String?
  taxCodeId           String
  taxRateId           String
  amount              Decimal @db.Decimal(20, 4)

  taxCode           TaxCode            @relation(fields: [taxCodeId], references: [id])
  taxRate           TaxRate            @relation(fields: [taxRateId], references: [id])
  invoiceLine       InvoiceLine?       @relation(fields: [invoiceLineId], references: [id])
  billLine          BillLine?          @relation(fields: [billLineId], references: [id])
  purchaseOrderLine PurchaseOrderLine? @relation(fields: [purchaseOrderLineId], references: [id])
  quoteLine         QuoteLine?         @relation(fields: [quoteLineId], references: [id])

  @@index([companyId, invoiceLineId, billLineId])
  @@index([companyId, purchaseOrderLineId])
  @@index([quoteLineId])
  @@index([taxCodeId, taxRateId])
  @@index([companyId, invoiceLineId])
  @@index([companyId, billLineId])
}

// --------------------
// Revenue Recognition (SaaS / Deferred Revenue)
// --------------------

model RevenueSchedule {
  id              String   @id @default(uuid())
  companyId       String
  invoiceLineId   String   // The source sale
  journalEntryId  String?  // The active recognition journal entry if processed
  totalAmount     Decimal  @db.Decimal(20, 4)
  recognizedAmount Decimal @default(0) @db.Decimal(20, 4)
  startDate       DateTime
  endDate         DateTime
  recognitionType String   @default("STRAIGHT_LINE") // STRAIGHT_LINE, MANUAL, MILESTONE
  status          String   @default("ACTIVE") // ACTIVE, COMPLETED, HOLD
  createdAt       DateTime @default(now())
  
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  invoiceLine     InvoiceLine  @relation(fields: [invoiceLineId], references: [id], onDelete: Restrict)
  journalEntry    JournalEntry? @relation("JournalEntry_RevenueSchedules", fields: [journalEntryId], references: [id])

  @@index([companyId, status])
  @@index([invoiceLineId])
}

model TaxCodeAccount {
  id        String  @id @default(uuid())
  companyId String
  taxCodeId String
  accountId String

  taxCode TaxCode @relation(fields: [taxCodeId], references: [id])
  account Account @relation(fields: [accountId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, taxCodeId, accountId])
  @@index([companyId, taxCodeId, accountId])
} 

// --------------------
// Sales Tax Filing & Remittance
// --------------------

model SalesTaxReturn {
  id          String   @id @default(uuid())
  workspaceId String   @map("tenantId")
  companyId   String
  periodStart DateTime
  periodEnd   DateTime
  status      String   @default("DRAFT") // DRAFT, FILED, AMENDED, PAID
  dueDate     DateTime?
  filedAt     DateTime?
  totalTax    Decimal  @db.Decimal(20, 4)
  createdAt   DateTime @default(now())
  filedById   String?

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  filedBy   User?     @relation(fields: [filedById], references: [id])
  lines     SalesTaxReturnLine[]
  payments  SalesTaxPayment[]

  @@index([workspaceId, periodStart, periodEnd])
  @@index([companyId, periodStart, periodEnd])
  @@index([status])
}

model SalesTaxReturnLine {
  id               String   @id @default(uuid())
  returnId         String
  taxRateId        String?
  taxJurisdictionId String?
  taxableAmount    Decimal? @db.Decimal(20, 4)
  taxAmount        Decimal  @db.Decimal(20, 4)

  taxReturn     SalesTaxReturn  @relation(fields: [returnId], references: [id], onDelete: Cascade)
  taxRate       TaxRate?        @relation(fields: [taxRateId], references: [id])
  jurisdiction  TaxJurisdiction? @relation(fields: [taxJurisdictionId], references: [id])

  @@index([returnId])
  @@index([taxRateId])
  @@index([taxJurisdictionId])
}

model SalesTaxPayment {
  id           String   @id @default(uuid())
  workspaceId  String   @map("tenantId")
  companyId    String
  returnId     String?
  paymentDate  DateTime
  amount       Decimal  @db.Decimal(20, 4)
  method       String
  referenceNumber String?
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  taxReturn SalesTaxReturn? @relation(fields: [returnId], references: [id])

  @@index([workspaceId, paymentDate])
  @@index([companyId, paymentDate])
  @@index([returnId])
}

model Role {
  id        String   @id @default(uuid())
  workspaceId  String @map("tenantId")
  name      String
  createdAt DateTime @default(now())

  workspace         Workspace           @relation(fields: [workspaceId], references: [id])
  RolePermission RolePermission[]
  @@unique([workspaceId, name])
  WorkspaceUser     WorkspaceUser[]
  invites        WorkspaceInvite[]
}

model Permission {
  id             String           @id @default(uuid())
  key            String           @unique
  desc           String?
  RolePermission RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model Approval {
  id         String   @id @default(uuid())
  workspaceId String  @map("tenantId")
  entityType String
  entityId   String
  status     String
  approverId String
  createdAt  DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, entityType, entityId])
}

model Revaluation {
  id          String   @id @default(uuid())
  workspaceId String   @map("tenantId")
  period      String
  generatedAt DateTime @default(now())
  entries     Json

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, period])
}

// --------------------
// Philippine Tax & Compliance
// --------------------

model LocalTaxTypeConfig {
  id          String   @id @default(uuid())
  countryId   String
  taxType     LocalTaxType
  description String?
  defaultRate Decimal? @db.Decimal(10, 4)
  isActive    Boolean  @default(true)

  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([countryId, taxType])
  @@index([countryId])
}

model WithholdingTaxDeduction {
  id             String   @id @default(uuid())
  companyId      String
  vendorId       String
  deductionType  WithholdingTaxType
  accountId      String?  // GL account for withholding payable
  rate           Decimal  @db.Decimal(10, 6)
  // Optional link to a TaxJurisdiction for sub-national rules
  jurisdictionId String?  // FK to TaxJurisdiction
  jurisdiction   String?  // textual jurisdiction (deprecated: use jurisdictionId)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  vendor  Vendor  @relation(fields: [vendorId], references: [contactId], onDelete: Restrict)
  account Account? @relation("WithholdingTax_Account", fields: [accountId], references: [id])
  jurisdiction TaxJurisdiction? @relation(fields: [jurisdictionId], references: [id])

  @@unique([companyId, vendorId, deductionType])
  @@index([companyId])
  @@index([jurisdictionId])
}

model FinalTaxDeduction {
  id            String   @id @default(uuid())
  companyId     String
  vendorId      String
  deductionType FinalTaxType
  accountId     String?  // GL account for final tax payable
  rate          Decimal  @db.Decimal(10, 6)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  vendor  Vendor  @relation(fields: [vendorId], references: [contactId], onDelete: Restrict)
  account Account? @relation("FinalTax_Account", fields: [accountId], references: [id])

  @@unique([companyId, vendorId, deductionType])
  @@index([companyId])
}

model PercentageTax {
  id            String   @id @default(uuid())
  companyId     String
  taxType       PercentageTaxType
  accountId     String?  // GL account for percentage tax payable
  rate          Decimal  @db.Decimal(10, 6)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  account Account? @relation("PercentageTax_Account", fields: [accountId], references: [id])

  @@unique([companyId, taxType])
  @@index([companyId])
}

model PhilippinePayrollDeduction {
  id             String   @id @default(uuid())
  companyId      String
  employeeId     String
  deductionType  PhilippinePayrollDeductionType
  employeeShare  Decimal  @db.Decimal(12, 2)
  employerShare  Decimal? @db.Decimal(12, 2)
  period         String   // YYYY-MM
  accountId      String?
  createdAt      DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  account  Account? @relation("PhilPayrollDeduction_Account", fields: [accountId], references: [id])

  @@index([companyId, employeeId, period])
  @@index([deductionType])
  // Prevent duplicate deduction entries for same company/employee/period/type
  @@unique([companyId, employeeId, period, deductionType])
}

model LocalTaxObligation {
  id             String   @id @default(uuid())
  companyId      String
  jurisdiction   String   // "Makati", "Quezon City", "Cebu"
  taxType        LocalTaxType
  dueDate        DateTime
  estimatedAmount Decimal? @db.Decimal(20, 4)
  paidAmount     Decimal  @default(0) @db.Decimal(20, 4)
  status         LocalTaxObligationStatus @default(PENDING) // PENDING, PAID, OVERDUE
  referenceNumber String?
  createdAt      DateTime @default(now())
  paidAt         DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId, jurisdiction, taxType])
  @@index([companyId, dueDate])
  @@index([companyId, status])
}

model VatLedger {
  id                   String   @id @default(uuid())
  companyId            String
  vatRegistrationId    String?
  period               String   // YYYY-MM
  openingBalance       Decimal  @default(0) @db.Decimal(20, 4)
  inputVat             Decimal  @db.Decimal(20, 4)
  outputVat            Decimal  @db.Decimal(20, 4)
  reverseChargeVat     Decimal  @default(0) @db.Decimal(20, 4)
  nonRecoverableVat    Decimal  @default(0) @db.Decimal(20, 4)
  vatPayable           Decimal  @db.Decimal(20, 4)
  vatReceivable        Decimal  @db.Decimal(20, 4)
  netPosition          Decimal  @db.Decimal(20, 4)
  creditableWithholding Decimal @db.Decimal(20, 4)
  createdAt            DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  vatRegistration VatRegistration? @relation(fields: [vatRegistrationId], references: [id])

  @@unique([companyId, vatRegistrationId, period])
  @@index([companyId, period])
  @@index([vatRegistrationId, period])
}

model VatRegistration {
  id                String   @id @default(uuid())
  companyId         String
  countryId         String
  vatNumber         String
  registrationType  String   // STANDARD, FLAT_RATE, EXEMPT, NON_RESIDENT
  vatCategory       VatCategory?
  effectiveDate     DateTime
  terminationDate   DateTime?
  isActive          Boolean  @default(true)
  filingFrequency   String   // MONTHLY, QUARTERLY, ANNUAL
  thresholdAmount   Decimal? @db.Decimal(20, 4)
  quarterlyThreshold Decimal? @db.Decimal(20, 4)
  annualThreshold    Decimal? @db.Decimal(20, 4)
  isLargeTaxpayer   Boolean  @default(false)
  createdAt         DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  country Country @relation(fields: [countryId], references: [id])
  transactions VatTransaction[]
  ledgers VatLedger[]

  @@unique([companyId, countryId, vatNumber])
  @@index([companyId, isActive])
}

model VatTransaction {
  id                String   @id @default(uuid())
  companyId         String
  vatRegistrationId String
  transactionType   String   // SALE, PURCHASE, IMPORT, EXPORT
  transactionDate   DateTime
  netAmount         Decimal  @db.Decimal(20, 4)
  vatAmount         Decimal  @db.Decimal(20, 4)
  vatRate           Decimal  @db.Decimal(10, 6)
  vatCode           String?  // STANDARD, REDUCED, ZERO, EXEMPT
  isReverseCharge   Boolean  @default(false)
  isRecoverable     Boolean  @default(true)
  sourceType        String?  // INVOICE, BILL, JOURNAL
  sourceId          String?
  createdAt         DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  vatRegistration VatRegistration @relation(fields: [vatRegistrationId], references: [id], onDelete: Restrict)

  @@index([companyId, transactionDate])
  @@index([vatRegistrationId, transactionDate])
  @@index([sourceType, sourceId])
}

model BirFormTemplate {
  id           String   @id @default(uuid())
  countryId    String
  formType     BirFormType
  description  String?
  /// JSON template defining form fields and validation rules.
  /// Example: { "fields": ["period","vatOutput","vatInput","vatDue"], "validation": { "vatOutput": "number", "period": "string" } }
  structure    Json     // Template structure for form fields
  requiredFields String[] // Array of required field names
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  country      Country          @relation(fields: [countryId], references: [id], onDelete: Restrict)
  submissions  BirFormSubmission[]

  @@unique([countryId, formType])
  @@index([countryId])
}

model BirFormSubmission {
  id            String   @id @default(uuid())
  companyId     String
  formType      BirFormType
  period        String   // YYYY-MM or YYYY-Q# or YYYY
  /// JSON payload containing filled form values. Structure must conform to the corresponding BirFormTemplate.structure.
  /// Example: { "period": "2025-Q1", "vatOutput": 120000, "vatInput": 30000, "vatDue": 90000 }
  data          Json     // Filled form data validated against template

  /// Filing status of the submission (DRAFT, READY, FILED, VOID)
  status        FilingStatus @default(DRAFT)
  filedAt       DateTime?
  birReferenceNumber String?
  efpsReferenceNumber String?
  efpsSubmissionId    String?
  efpsStatus          String?
  efpsSubmittedAt     DateTime?
  efpsResponse        Json?
  attachmentId        String?
  notes         String?  @db.Text
  createdAt     DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  attachment Attachment? @relation(fields: [attachmentId], references: [id])

  @@unique([companyId, formType, period])
  @@index([companyId, formType])
  @@index([companyId, period])
  @@index([status])
  @@index([attachmentId])
}

model Form2307 {
  id                String   @id @default(uuid())
  companyId         String
  supplierId        String
  period            String   // YYYY-Q#
  certificateNumber String
  amount            Decimal  @db.Decimal(20, 4)
  withheldAmount    Decimal  @db.Decimal(20, 4)
  issuedAt          DateTime
  receivedAt        DateTime?
  status            String   @default("ISSUED") // ISSUED, RECEIVED, APPLIED
  journalEntryId    String?

  company      Company      @relation(fields: [companyId], references: [id])
  supplier     Vendor       @relation(fields: [supplierId], references: [contactId])
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@unique([companyId, certificateNumber])
  @@index([companyId, period])
  @@index([supplierId, period])
  @@index([journalEntryId])
}

model AlphalistEntry {
  id            String   @id @default(uuid())
  companyId     String
  payeeType     String   // EMPLOYEE, CONTRACTOR, CONSULTANT
  payeeName     String
  taxId         String?
  totalIncome   Decimal  @db.Decimal(20, 4)
  withholdings  Decimal  @db.Decimal(20, 4)
  taxYear       Int
  createdAt     DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, taxId, taxYear])
  @@index([companyId, taxYear])
}

model ChartOfAccountsTemplate {
  id             String   @id @default(uuid())
  countryId      String
  name           String   // e.g., "Philippine BIR-Prescribed COA"
  structure      Json     // Account hierarchy and defaults
  description    String?
  isDefault      Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  country Country @relation(fields: [countryId], references: [id], onDelete: Restrict)

  @@unique([countryId, name])
  @@index([countryId, isDefault])
}

model CompanyChartOfAccounts {
  id         String   @id @default(uuid())
  companyId  String
  templateId String
  appliedAt  DateTime @default(now())
  version    Int      @default(1)

  company  Company              @relation(fields: [companyId], references: [id])
  template ChartOfAccountsTemplate @relation(fields: [templateId], references: [id])

  @@unique([companyId, templateId, version])
  @@index([companyId, appliedAt])
}

model DefaultAccountMapping {
  id          String   @id @default(uuid())
  companyId   String
  accountType String   // AR_CONTROL, AP_CONTROL, RETAINED_EARNINGS, etc.
  accountId   String

  company Company @relation(fields: [companyId], references: [id])
  account Account @relation(fields: [accountId], references: [id])

  @@unique([companyId, accountType])
  @@index([accountId])
}

model PhilippineFinancialStatementTemplate {
  id          String   @id @default(uuid())
  companyId   String
  statementType String // BALANCE_SHEET_PH, INCOME_STATEMENT_PH, CASH_FLOW_PH, CHANGES_IN_EQUITY_PH
  structure   Json     // PH GAAP-compliant structure
  notes       String?  @db.Text
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, statementType])
  @@index([companyId])
}

model Attachment {
  id           String    @id @default(uuid())
  workspaceId  String    @map("tenantId")
  entityType   String
  entityId     String
  fileUrl      String
  fileName     String?
  fileSize     Int?
  mimeType     String?
  isPublic     Boolean   @default(false)
  uploadedById String?
  description  String?   @db.Text
  uploadedAt   DateTime  @default(now())
  deletedAt    DateTime?

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  uploadedBy User?  @relation(fields: [uploadedById], references: [id])
  transferPricingDocuments TransferPricingDocument[]
  birFormSubmissions       BirFormSubmission[]

  @@index([workspaceId])
  @@index([workspaceId, entityType, entityId])
  @@index([isPublic])
  @@index([uploadedAt])
}

model Quote {
  id             String      @id @default(uuid())
  workspaceId    String      @map("tenantId")
  companyId      String
  quoteNumber    String?
  customerId     String
  status         QuoteStatus @default(DRAFT)
  totalAmount    Decimal     @db.Decimal(20, 4)
  issuedAt       DateTime    @default(now())
  expiryDate     DateTime?
  acceptedAt     DateTime?
  convertedToInvoiceId String? // Link to resulting invoice
  deletedAt      DateTime?

  workspace   Workspace   @relation(fields: [workspaceId], references: [id])
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  customer    Customer    @relation(fields: [customerId], references: [contactId])
  invoice     Invoice?    @relation("QuoteToInvoice", fields: [convertedToInvoiceId], references: [id])
  
  templateId  String?
  template    DocumentTemplate? @relation(fields: [templateId], references: [id])
  
  lines       QuoteLine[]

  @@index([workspaceId, status])
  @@index([companyId, customerId])
  @@index([deletedAt])
}

model QuoteLine {
  id          String   @id @default(uuid())
  quoteId     String
  companyId   String
  itemId      String?
  description String
  quantity    Decimal  @db.Decimal(12, 4)
  unitPrice   Decimal  @db.Decimal(16, 6)
  amount      Decimal  @db.Decimal(20, 4)
  
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  item      Item?    @relation(fields: [itemId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  LineTax   LineTax[]

  @@index([quoteId])
  @@index([companyId])
}

model Invoice {
  id             String    @id @default(uuid())
  workspaceId    String    @map("tenantId")
  companyId      String
  invoiceNumber  String?
  customerId     String
  status         InvoiceStatus    @default(DRAFT)
  paymentStatus  PaymentStatus @default(DRAFT)
  totalAmount    Decimal   @map("total") @db.Decimal(20, 4)
  balance        Decimal   @db.Decimal(20, 4)
  currency       String?
  exchangeRate   Decimal?  @db.Decimal(28, 12)
  baseTotal      Decimal?  @db.Decimal(20, 4)
  transactionType TransactionType?
  discountAmount Decimal?  @db.Decimal(20, 4)
  shippingAmount Decimal?  @db.Decimal(20, 4)
  otherCharges   Decimal?  @db.Decimal(20, 4)
  withholdingTaxAmount Decimal? @db.Decimal(20, 4)
  finalTaxAmount       Decimal? @db.Decimal(20, 4)
  date           DateTime  @default(now()) @map("issuedAt")
  dueDate        DateTime?
  paymentTermId  String?
  paymentTerm    PaymentTerm? @relation(fields: [paymentTermId], references: [id])
  deletedAt      DateTime?

  createdById   String?
  updatedById   String?
  createdBy     User? @relation("Invoice_createdBy", fields: [createdById], references: [id])
  updatedBy     User? @relation("Invoice_updatedBy", fields: [updatedById], references: [id])
  
  // Customization
  templateId    String?
  template      DocumentTemplate? @relation(fields: [templateId], references: [id])

  workspace                  Workspace                   @relation(fields: [workspaceId], references: [id])
  customer                   Customer                    @relation(fields: [customerId], references: [contactId])
  lines                      InvoiceLine[]
  journalEntryId             String?
  journalEntry               JournalEntry?               @relation("JournalEntry_Invoices", fields: [journalEntryId], references: [id])
  postingStatus              PostingStatus               @default(DRAFT)
  company                    Company                     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  InvoicePaymentApplication  InvoicePaymentApplication[]
  customerCreditApplications CustomerCreditApplication[] @relation("Invoice_CreditApplications")
  inventoryTransactions      InventoryTransaction[]
  quotes                     Quote[]                     @relation("QuoteToInvoice")
  writeOffs                  WriteOff[]

  @@unique([companyId, invoiceNumber])
  @@index([workspaceId, status, dueDate])
  @@index([workspaceId, date])
  @@index([workspaceId, customerId, status])
  @@index([companyId, customerId, status])
  @@index([companyId, date])
  @@index([createdById])
  @@index([updatedById])
  @@index([companyId, postingStatus, date])
  @@index([deletedAt])
  @@index([companyId, status, dueDate, deletedAt])
  @@index([companyId, dueDate, balance, status])
  @@index([companyId, status, dueDate, balance])
  @@index([companyId, paymentStatus, dueDate])
  @@index([companyId, deletedAt])
  @@index([companyId, dueDate, balance, status, deletedAt])
  @@index([companyId, customerId, dueDate, balance])
  @@index([companyId, templateId])
}  

