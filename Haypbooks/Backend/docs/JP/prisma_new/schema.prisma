  endedAt      DateTime?
  status       String   @default("PENDING") // PENDING, COMPLETED, FAILED
  rawCount     Int      @default(0)

  connection BankFeedConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  rawTransactions BankTransactionRaw[]

  @@index([connectionId, startedAt])
  @@index([status])
}

model BankTransactionRaw {
  id              String   @id @default(uuid())
  companyId        String
  importId        String
  bankFeedAccountId String
  bankAccountId   String
  externalId      String
  amount          Decimal  @db.Decimal(20, 4)
  date            DateTime
  description     String
  /// Raw transaction payload from the upstream provider
  rawPayload      Json
  bankTransactionId String?

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  import          BankFeedImport   @relation(fields: [importId], references: [id], onDelete: Cascade)
  bankFeedAccount BankFeedAccount  @relation(fields: [bankFeedAccountId], references: [id])
  bankAccount     BankAccount      @relation(fields: [bankAccountId], references: [id])
  bankTransaction BankTransaction? @relation(fields: [bankTransactionId], references: [id])

  @@unique([bankFeedAccountId, externalId])
  @@index([companyId, date])
  @@index([companyId, date, amount])
  @@index([companyId, bankAccountId, date])
  @@index([companyId, bankAccountId, amount, date, description])
  @@index([bankAccountId, date])
  @@index([bankTransactionId])
}

model BankAccount {
  id            String   @id @default(uuid())
  workspaceId   String   @map("tenantId")
  name          String
  institution   String?
  accountNumber String?
  routingNumber String?
  swiftCode     String?
  iban          String?
  isDefault     Boolean  @default(false)
  checkStartingNumber Int?
  lastCheckNumber Int?
  createdAt     DateTime @default(now())

  workspace          Workspace            @relation(fields: [workspaceId], references: [id])
  transactions       BankTransaction[]
  paymentsReceived   PaymentReceived[]
  deposits          BankDeposit[]
  customerRefunds   CustomerRefund[]
  vendorRefunds     VendorRefund[]
  cashOverShortRules CashOverShortRule[]
  BillPayment        BillPayment[]
  BankReconciliation BankReconciliation[]

  @@index([workspaceId])
  @@unique([workspaceId, institution, accountNumber])
}

model BankTransaction {
  id            String   @id @default(uuid())
  bankAccountId String
  amount        Decimal  @db.Decimal(20, 4)
  date          DateTime
  description   String
  workspaceId    String @map("tenantId")

  bankAccount            BankAccount              @relation(fields: [bankAccountId], references: [id])
  workspace              Workspace                 @relation(fields: [workspaceId], references: [id])
  BankReconciliationLine BankReconciliationLine[]

  @@index([workspaceId])
  @@index([workspaceId, date])
  @@index([bankAccountId, date, amount])
  @@index([bankAccountId, date, description])
}

model BankDeposit {
  id            String   @id @default(uuid())
  workspaceId   String   @map("tenantId")
  companyId     String
  bankAccountId String
  depositDate   DateTime @default(now())
  totalAmount   Decimal  @db.Decimal(20, 4)
  currency      String?
  exchangeRate  Decimal? @db.Decimal(28, 12)
  baseAmount    Decimal? @db.Decimal(20, 4)
  status        BankDepositStatus   @default(DRAFT) // DRAFT, POSTED, VOID
  referenceNumber String?

  workspace    Workspace   @relation(fields: [workspaceId], references: [id])
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  bankAccount  BankAccount @relation(fields: [bankAccountId], references: [id])
  lines        BankDepositLine[]
  depositSlip  DepositSlip?
  cashOverShortEntries CashOverShortEntry[]
  journalEntryId String?
  journalEntry  JournalEntry? @relation("JournalEntry_BankDeposits", fields: [journalEntryId], references: [id])

  @@index([workspaceId, depositDate])
  @@index([companyId, depositDate])
  @@index([bankAccountId])
  @@index([journalEntryId])
}

model UndepositedFundsBatch {
  id            String   @id @default(uuid())
  companyId     String
  bankAccountId String
  totalAmount   Decimal  @db.Decimal(20, 4)
  status        UndepositedFundsBatchStatus   @default(PENDING) // PENDING, DEPOSITED
  createdAt     DateTime @default(now())
  depositedAt   DateTime?

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])
  payments    PaymentReceived[]

  @@index([companyId, status])
  @@index([bankAccountId])
}

model BankDepositLine {
  id              String   @id @default(uuid())
  depositId       String
  paymentReceivedId String
  amount          Decimal  @db.Decimal(20, 4)

  deposit         BankDeposit    @relation(fields: [depositId], references: [id], onDelete: Cascade)
  paymentReceived PaymentReceived @relation(fields: [paymentReceivedId], references: [id])

  @@unique([depositId, paymentReceivedId])
  @@index([depositId])
}

model DepositSlip {
  id           String   @id @default(uuid())
  depositId    String   @unique
  slipNumber   String?
  preparedById String?
  preparedAt   DateTime @default(now())
  printedAt    DateTime?
  printCount   Int      @default(0)
  templateId   String?
  layoutConfig Json?
  lastPrintedById String?
  notes        String?

  deposit    BankDeposit @relation(fields: [depositId], references: [id], onDelete: Cascade)
  preparedBy User?       @relation(fields: [preparedById], references: [id])
  template   DocumentTemplate? @relation(fields: [templateId], references: [id])
  lastPrintedBy User?     @relation(fields: [lastPrintedById], references: [id])

  @@index([preparedById])
  @@index([lastPrintedById])
}

model CashOverShortEntry {
  id           String   @id @default(uuid())
  depositId    String
  ruleId       String?
  accountId    String?  // Optional: map to a specific GL account
  amount       Decimal  @db.Decimal(20, 4) // Positive = over, Negative = short
  reason       String?

  deposit   BankDeposit @relation(fields: [depositId], references: [id], onDelete: Cascade)
  rule      CashOverShortRule? @relation(fields: [ruleId], references: [id])
  account   Account?    @relation(fields: [accountId], references: [id])

  @@index([depositId])
  @@index([ruleId])
  @@index([accountId])
}

model CashOverShortRule {
  id            String   @id @default(uuid())
  companyId     String
  bankAccountId String?
  accountId     String? // GL account for variance
  direction     String  // OVER, SHORT, BOTH
  thresholdAmount Decimal? @db.Decimal(20, 4)
  autoPost      Boolean @default(true)
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])
  account     Account?     @relation(fields: [accountId], references: [id])
  entries     CashOverShortEntry[]

  @@index([companyId, isActive])
  @@index([bankAccountId])
  @@index([accountId])
}

// --------------------
// Cash Management
// --------------------

model PettyCashFund {
  id            String   @id @default(uuid())
  companyId     String
  custodianId   String?
  accountId     String
  location      String?
  maxAmount     Decimal  @db.Decimal(20, 4)
  currentAmount Decimal  @db.Decimal(20, 4)
  status        PettyCashStatus @default(ACTIVE)
  createdAt     DateTime @default(now())

  company   Company  @relation(fields: [companyId], references: [id])
  custodian Employee? @relation(fields: [custodianId], references: [id])
  account   Account  @relation(fields: [accountId], references: [id])
  vouchers  PettyCashVoucher[]

  @@index([companyId, status])
}

model PettyCashVoucher {
  id              String   @id @default(uuid())
  fundId          String
  voucherNumber   String
  date            DateTime
  payee           String
  description     String
  amount          Decimal  @db.Decimal(20, 4)
  accountId       String?
  approvedById    String?
  receiptAttached Boolean  @default(false)
  reconciledAt    DateTime?

  fund       PettyCashFund @relation(fields: [fundId], references: [id])
  account    Account?      @relation(fields: [accountId], references: [id])
  approvedBy User?         @relation(fields: [approvedById], references: [id])

  @@unique([fundId, voucherNumber])
  @@index([fundId, date])
  @@index([approvedById])
}

model Check {
  id             String   @id @default(uuid())
  companyId      String
  bankAccountId  String
  checkNumber    String
  payee          String
  amount         Decimal  @db.Decimal(20, 4)
  date           DateTime
  memo           String?
  status         CheckStatus @default(DRAFT)
  printedAt      DateTime?
  issuedAt       DateTime?
  clearedAt      DateTime?
  voidedAt       DateTime?
  stopPaymentAt  DateTime?
  paymentId      String?
  templateId     String?

  company     Company     @relation(fields: [companyId], references: [id])
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])
  payment     BillPayment? @relation(fields: [paymentId], references: [id])
  template    DocumentTemplate? @relation(fields: [templateId], references: [id])

  @@unique([companyId, bankAccountId, checkNumber])
  @@index([companyId, status])
  @@index([checkNumber])
  @@index([companyId, templateId])
}

// --------------------
// Accounts Payable / Purchases
// --------------------

model Bill {
  id             String    @id @default(uuid())
  companyId      String
  workspaceId    String   @map("tenantId")
  vendorId       String
  billNumber     String?
  status         BillStatus    @default(DRAFT)
  paymentStatus  PaymentStatus @default(DRAFT)
  total          Decimal   @db.Decimal(20, 4)
  balance        Decimal   @db.Decimal(20, 4)
  currency       String?
  exchangeRate   Decimal?  @db.Decimal(28, 12)
  baseTotal      Decimal?  @db.Decimal(20, 4)
  transactionType TransactionType?
  discountAmount Decimal?  @db.Decimal(20, 4)
  shippingAmount Decimal?  @db.Decimal(20, 4)
  otherCharges   Decimal?  @db.Decimal(20, 4)
  withholdingTaxAmount Decimal? @db.Decimal(20, 4)
  creditableWithholding Decimal? @db.Decimal(20, 4)
  issuedAt       DateTime  @default(now())
  dueAt          DateTime?
  paymentTermId  String?
  paymentTerm    PaymentTerm? @relation(fields: [paymentTermId], references: [id])
  description    String?
  deletedAt      DateTime?

  workspace              Workspace                @relation(fields: [workspaceId], references: [id])
  vendor                 Vendor                   @relation(fields: [vendorId], references: [contactId])
  lines                  BillLine[]
  payments               BillPayment[]
  journalEntryId         String?
  journalEntry           JournalEntry?            @relation("JournalEntry_Bills", fields: [journalEntryId], references: [id])
  postingStatus          PostingStatus            @default(DRAFT)
  company                Company                  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  BillPaymentApplication BillPaymentApplication[]
  writeOffs              WriteOff[]

  createdById      String?
  updatedById      String?
  createdBy        User?                    @relation("Bill_createdBy", fields: [createdById], references: [id])
  updatedBy        User?                    @relation("Bill_updatedBy", fields: [updatedById], references: [id])

  @@unique([companyId, vendorId, billNumber])
  @@index([createdById])
  @@index([updatedById])
  @@index([workspaceId, status])
  @@index([workspaceId, vendorId])
  @@index([workspaceId, vendorId, status])
  @@index([companyId, vendorId, status])
  @@index([companyId])
  @@index([workspaceId, issuedAt])
  @@index([deletedAt])
  @@index([companyId, status, dueAt, deletedAt])
  @@index([companyId, postingStatus, issuedAt])
  @@index([companyId, status, dueAt, balance])
  @@index([companyId, paymentStatus, dueAt])
  @@index([companyId, deletedAt])
  @@index([companyId, dueAt, balance, status, deletedAt])
  @@index([companyId, vendorId, dueAt, balance])
} 

model BillLine {
  id              String   @id @default(uuid())
