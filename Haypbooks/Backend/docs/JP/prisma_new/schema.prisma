model ConsolidationGroup {
  id           String   @id @default(uuid())
  workspaceId  String   @map("tenantId")
  name         String
  baseCurrency String   @default("USD")
  autoEliminateIntercompany Boolean @default(false)
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  members   ConsolidationGroupMember[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model ConsolidationGroupMember {
  id           String   @id @default(uuid())
  groupId      String
  companyId    String
  isParent     Boolean  @default(false)
  effectiveFrom DateTime @default(now())
  effectiveTo   DateTime?

  group   ConsolidationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  company Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([groupId, companyId])
  @@index([companyId])
}

model CompanyUser {
  companyId   String
  workspaceId String @map("tenantId")
  userId      String

  // Company-level access is granted only to workspace members
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  member      WorkspaceUser @relation(fields: [workspaceId, userId], references: [workspaceId, userId], onDelete: Cascade)

  @@id([companyId, workspaceId, userId])
  @@index([companyId])
  @@index([workspaceId, userId])
}

model PracticeUser {
  practiceId  String
  workspaceId String @map("tenantId")
  userId      String

  // Practice-level access is granted only to workspace members
  practice    Practice     @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  member      WorkspaceUser @relation(fields: [workspaceId, userId], references: [workspaceId, userId], onDelete: Cascade)

  @@id([practiceId, workspaceId, userId])
  @@index([practiceId])
  @@index([workspaceId, userId])
}

// --------------------
// Intercompany & Consolidation
// --------------------

model IntercompanyTransaction {
  id               String   @id @default(uuid())
  workspaceId      String   @map("tenantId")
  fromCompanyId    String
  toCompanyId      String
  transactionDate  DateTime @default(now())
  description      String?
  amount           Decimal  @db.Decimal(20, 4)
  currency         String?
  status           IntercompanyTransactionStatus   @default(DRAFT) // DRAFT, POSTED, VOID
  fromJournalEntryId String?
  toJournalEntryId   String?
  createdAt        DateTime @default(now())

  workspace        Workspace   @relation(fields: [workspaceId], references: [id])
  fromCompany      Company     @relation("IntercompanyFrom", fields: [fromCompanyId], references: [id], onDelete: Restrict)
  toCompany        Company     @relation("IntercompanyTo", fields: [toCompanyId], references: [id], onDelete: Restrict)
  fromJournalEntry JournalEntry? @relation("IntercompanyFromJE", fields: [fromJournalEntryId], references: [id])
  toJournalEntry   JournalEntry? @relation("IntercompanyToJE", fields: [toJournalEntryId], references: [id])

  @@index([workspaceId, transactionDate])
  @@index([fromCompanyId, transactionDate])
  @@index([toCompanyId, transactionDate])
}

model ConsolidationEntry {
  id            String   @id @default(uuid())
  workspaceId   String   @map("tenantId")
  companyId     String
  period        String   // e.g., 2024-12
  description   String?
  status        String   @default("DRAFT") // DRAFT, POSTED
  journalEntryId String?
  functionalCurrency    String?
  presentationCurrency  String?
  exchangeRate          Decimal? @db.Decimal(28, 12)
  translationMethod     String?
  translationAdjustment Decimal? @db.Decimal(20, 4)
  createdAt     DateTime @default(now())

  workspace   Workspace   @relation(fields: [workspaceId], references: [id])
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@index([workspaceId, period])
  @@index([companyId, period])
}

