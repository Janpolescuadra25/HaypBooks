model AiInsight {
  id           String   @id @default(uuid())
  workspaceId  String   @map("tenantId")
  companyId    String?
  modelId      String?

  insightType  AiInsightType
  subType      String?
  title        String
  description  String   @db.Text

  severity     AiInsightSeverity @default(MEDIUM)
  confidence   Decimal  @db.Decimal(5, 2)
  impactScore  Decimal? @db.Decimal(10, 2)

  data         Json
  analysis     Json?
  recommendations Json?

  predictedDate DateTime?
  predictedValue Decimal? @db.Decimal(20, 4)

  sourceModel   String?
  sourceVersion String?
  triggers      String[]

  status        AiInsightStatus @default(ACTIVE)
  assignedTo    String?
  actionTaken   String?
  resolvedAt    DateTime?
  dismissedAt   DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  relatedType   String?
  relatedId     String?

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  company   Company?  @relation(fields: [companyId], references: [id])
  model     AiModel?  @relation(fields: [modelId], references: [id])

  attachments  AiInsightAttachment[]
  comments     AiInsightComment[]
  metrics      AiInsightMetric[]

  @@index([workspaceId, insightType, status])
  @@index([companyId, insightType, status])
  @@index([workspaceId, severity, status])
  @@index([predictedDate])
  @@index([createdAt])
}

model AiInsightAttachment {
  id         String   @id @default(uuid())
  insightId  String
  type       String
  title      String
  content    Json
  url        String?
  createdAt  DateTime @default(now())

  insight AiInsight @relation(fields: [insightId], references: [id], onDelete: Cascade)

  @@index([insightId])
}

model AiInsightComment {
  id            String   @id @default(uuid())
  insightId     String
  userId        String
  comment       String   @db.Text
  isAiGenerated Boolean  @default(false)
  createdAt     DateTime @default(now())

  insight AiInsight @relation(fields: [insightId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id])

  @@index([insightId])
  @@index([userId])
}

model AiInsightMetric {
  id        String   @id @default(uuid())
  insightId String
  name      String
  value     Decimal? @db.Decimal(20, 4)
  unit      String?
  data      Json?

  insight AiInsight @relation(fields: [insightId], references: [id], onDelete: Cascade)

  @@index([insightId])
}

model AiModel {
  id           String   @id @default(uuid())
  workspaceId  String?  @map("tenantId")
  companyId    String?

  name         String
  description  String?
  modelType    AiModelType
  version      String
  status       AiModelStatus @default(TRAINING)

  config       Json
  features     String[]
  metrics      Json?

  modelPath    String?
  checksum     String?

  trainedAt    DateTime?
  trainedBy    String?
  trainingDataRangeStart DateTime?
  trainingDataRangeEnd   DateTime?

  deployedAt   DateTime?
  isActive     Boolean  @default(false)
  isDefault    Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  company   Company?   @relation(fields: [companyId], references: [id])
  runs      AiModelRun[]
  insights  AiInsight[]
  predictions Prediction[]
  agents     AiAgent[]

  @@unique([workspaceId, companyId, name, version])
  @@index([workspaceId, modelType, isActive])
  @@index([companyId, modelType, isActive])
}

model AiModelRun {
  id           String   @id @default(uuid())
  modelId      String
  runType      AiRunType
  status       AiRunStatus @default(PENDING)

  inputConfig  Json?
  inputDataRef String?
  output       Json?
  metrics      Json?

  startedAt    DateTime?
  completedAt  DateTime?
  durationMs   Int?

  resourceUsage Json?
  costEstimate  Decimal? @db.Decimal(10, 2)

  error        String?
  stackTrace   String?  @db.Text
  retryCount   Int      @default(0)

  createdAt    DateTime @default(now())

  model AiModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId, status])
  @@index([startedAt])
  @@index([runType, status])
}

model FeatureStore {
  id           String   @id @default(uuid())
  workspaceId  String   @map("tenantId")
  companyId    String

  name         String
  description  String?
  dataType     FeatureDataType
  category     String?

  value        Json?
  historicalValues Json?

  sourceTable  String?
  sourceField  String?
  calculation  String?
  refreshFrequency String?

  minValue     Decimal? @db.Decimal(20, 4)
  maxValue     Decimal? @db.Decimal(20, 4)
  avgValue     Decimal? @db.Decimal(20, 4)
  stdDev       Decimal? @db.Decimal(20, 4)

  version      Int      @default(1)
  isActive     Boolean  @default(true)

