# Backend API URL
# In local dev we prefer IPv4 backend origin for reliability (avoid IPv6 ::1 binding/connect issues).
# Set this to the backend origin so client-side requests hit the backend directly, or leave empty to
# use Next.js dev rewrites (ensure frontend is running in dev mode for rewrites to apply).
# For local development the usual value is:
# NEXT_PUBLIC_API_URL=http://127.0.0.1:4000
# Default to backend origin (uncomment and edit if you want explicit backend calls):
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000
