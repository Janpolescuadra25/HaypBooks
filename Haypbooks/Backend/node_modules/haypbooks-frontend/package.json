{
  "name": "haypbooks-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "node --max-old-space-size=6144 ./node_modules/jest/bin/jest.js --maxWorkers=25%",
    "test:serial": "node --max-old-space-size=6144 ./node_modules/jest/bin/jest.js --runInBand",
    "test:limited": "node --max-old-space-size=6144 ./node_modules/jest/bin/jest.js --maxWorkers=4",
    "test:coverage": "node --max-old-space-size=6144 ./node_modules/jest/bin/jest.js --maxWorkers=4 --coverage",
    "smoke": "node ./scripts/smoke.js",
    "smoke:signup": "node e2e/smoke-signup-otp.js",
    "e2e": "node ../Backend/scripts/wait-for-backend.js http://127.0.0.1:4000/api/health 60 && playwright test --project=chromium",
    "e2e:hub": "node ../Backend/scripts/wait-for-backend.js http://127.0.0.1:4000/api/health 60 && playwright test e2e/signup-role-hub.spec.ts --project=chromium",
    "e2e:full-auth": "node ../Backend/scripts/wait-for-backend.js http://127.0.0.1:4000/api/health 60 && playwright test e2e/full-auth-flow.spec.ts --project=chromium",
    "e2e:full-auth:ci": "node -e \"process.env.E2E_FULL_AUTH='true'; const { execSync } = require('child_process'); execSync('node ../Backend/scripts/wait-for-backend.js http://127.0.0.1:4000/api/health 60 && playwright test e2e/full-auth-flow.spec.ts --project=chromium --reporter=list --reporter=json', { stdio: 'inherit' })\"",
    "e2e:collect-artifacts": "node scripts/collect-e2e-artifacts.js",
    "e2e:signup:manual": "node e2e/scripts/run-signup-e2e.js",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "haypbooks-backend": "file:../Backend",
    "libphonenumber-js": "^1.12.33",
    "lucide-react": "^0.575.0",
    "motion": "^12.34.3",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.23.8",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.12",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.1.2",
    "msw": "^2.11.1",
    "playwright": "^1.57.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.7",
    "ts-jest": "^29.2.5",
    "typescript": "^5.4.5",
    "undici": "^6.19.8"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
