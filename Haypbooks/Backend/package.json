{
  "name": "haypbooks-backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "prisma:generate": "npx prisma generate --schema=prisma/schema.prisma",
    "migrate:init": "node ./scripts/migrate/init-db.js",
    "test:setup-db": "node ./scripts/test/setup-test-db.js",
    "prisma:verify:migrate": "node ./scripts/ci/prisma-migrate-verify.js",
    "db:run-idempotent-ddl": "node ./scripts/db/run-idempotent-ddl.js",
    "db:apply-rls-phase1": "node ./scripts/db/apply-rls-phase1.js",
    "db:apply-rls-phase2": "node ./scripts/db/apply-rls-phase2.js",
    "db:add-tenant-indexes": "node ./scripts/db/add-tenant-indexes-phase2.js",
    "db:apply-phase2-safe": "npm run db:add-tenant-indexes && npm run db:apply-rls-phase2",
    "db:drift-check": "node ./scripts/ci/db-drift.js",
    "migrate:run": "npm run migrate:init && node ./scripts/migrate/run-sql.js",
    "migrate:check": "node ./scripts/check-role.js",
    "db:seed:dev": "ts-node prisma/seed.ts",
    "db:seed:ap": "ts-node prisma/seed-ap-tax.ts",
    "db:seed:inventory": "ts-node prisma/seed-inventory.ts",
    "db:backfill:companyIds": "ts-node scripts/db/backfill-company-ids.ts",
    "db:squash": "node ./scripts/migrate/squash-migrations.js",
    "db:validate:company-fks": "ts-node scripts/db/validate-company-fks.ts",
    "db:check:new-tables": "ts-node scripts/db/check-new-tables.ts",
    "db:test:company-trigger": "ts-node scripts/db/test-company-trigger.ts",
    "verify:rls": "node ./scripts/ci/verify-rls.js",
    "check-rls-status": "node ./scripts/check-rls-status.js",
    "audit:tenant-fields": "ts-node ./scripts/audit-tenant-fields.ts",
    "test:rls-enforcement": "node ./scripts/ci/test-rls-enforcement.js",
    "lint:migrations:rls": "node ./scripts/ci/migration-rls-lint.js",
    "lint:migrations:tenant": "node ./scripts/ci/migration-rls-lint.js",
    "tmp:regex": "node ./scripts/tmp_regex_test.js && node ./scripts/tmp_regex_test2.js",
    "check:tenant-orphans": "node ./scripts/check-orphaned-tenantids.js",
    "inspect:tenant-types": "node ./scripts/inspect-tenant-column-types.js",
    "list:tenant-fks": "node ./scripts/list-tenant-fks.js",
    "list:tenant-fk-all": "node ./scripts/list-all-tenant-fks.js",
    "attempt:add-tenant-fks": "node ./scripts/attempt-add-tenant-fks.js",
    "check:tenant-id-type": "node ./scripts/check-tenant-id-type.js",
    "validate:tenant-ids": "node ./scripts/validate-tenant-ids.js",
    "find:tenantid-mismatch": "node ./scripts/find-tenantid-type-mismatches.js",
    "lint:db:tenant-coltypes": "node ./scripts/ci/check-tenant-coltypes.js",
    "lint:db:schema-complete": "node ./scripts/ci/schema-completeness-check.js",
    "lint:db:fail-on-backups": "cross-env FAIL_ON_BACKUP_COLUMNS=1 node ./scripts/ci/schema-completeness-check.js",
    "lint:db:schema-columns": "node ./scripts/ci/schema-completeness-check.js",
    "lint:db:tenant-indexes": "node ./scripts/ci/schema-completeness-check.js",
    "ci:db-ship-check": "node ./scripts/ci/db-ship-check.js",
    "generate:convert-tenantid-uuid-to-text": "node ./scripts/generate-convert-tenantid-uuid-to-text.sql.js",
    "generate:tenant-fk-migration": "node ./scripts/generate-add-tenant-fks-migration.js",
    "generate:expected-schema": "node ./scripts/ci/generate-expected-schema.js",
    "verify:expected-schema": "node ./scripts/ci/verify-expected-schema-up-to-date.js",
    "db:validate-unvalidated-fks": "node ./scripts/ci/validate-unvalidated-tenant-fks.js",
    "generate:cleanup-tenantid-columns": "node ./scripts/generate-cleanup-tenantid-columns.js",
    "test:e2e": "cross-env DATABASE_URL=postgresql://postgres:Ninetails45@localhost:5432/haypbooks_test npm run migrate:init && cross-env DATABASE_URL=postgresql://postgres:Ninetails45@localhost:5432/haypbooks_test node ./scripts/migrate/run-sql.js && cross-env DATABASE_URL=postgresql://postgres:Ninetails45@localhost:5432/haypbooks_test npm run db:seed:dev && cross-env DATABASE_URL=postgresql://postgres:Ninetails45@localhost:5432/haypbooks_test jest --runInBand --config jest.e2e.config.js",
    "test:serial": "cross-env DATABASE_URL=postgresql://postgres:Ninetails45@localhost:5432/haypbooks_test npx jest --runInBand --config jest.e2e.config.js",
    "test:quick-verify": "node ./scripts/test/quick-verify.js",
    "db:seed:smoke": "npm run db:seed:dev && npm run db:seed:inventory",
    "db:seed:export": "ts-node ./scripts/db/export-seed-snapshot.ts",
    "db:seed:import": "ts-node ./scripts/db/import-seed-snapshot.ts",
    "check:schema": "ts-node ./scripts/db/check-schema.ts",
    "check:migrations": "ts-node ./scripts/ci/check-migrations.ts",
    "db:smoke": "ts-node ./scripts/db/smoke-tests.ts",
    "db:reset:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/db/reset-test-db.ps1",
    "db:validate": "npm run -s check:migrations && npm run -s migrate:run && npm run -s db:smoke",
    "test:quick": "npm run migrate:init && node ./scripts/migrate/run-sql.js && npm run db:seed:dev && jest --runInBand test/payroll.unit-spec.ts",
    "db:seed": "node dist/prisma/seed.js",
    "prepare": "husky install"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm --prefix . run check:migrations && npm --prefix . run lint:migrations:rls && npm --prefix . run lint:db:tenant-coltypes && npm --prefix . run lint:db:schema-complete && npm --prefix . run verify:expected-schema && npm --prefix . run lint:db:fail-on-backups"
    }
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@prisma/client": "^4.15.0",
    "@sendgrid/mail": "^8.1.6",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.3.1",
    "haypbooks-frontend": "file:../Frontend",
    "nodemailer": "^7.0.11",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.11.1",
    "prisma": "^4.15.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "zod": "^3.22.0",
    "libphonenumber-js": "^1.12.31"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.20",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^2.0.16",
    "axios": "^1.13.2",
    "cross-env": "^7.0.3",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
