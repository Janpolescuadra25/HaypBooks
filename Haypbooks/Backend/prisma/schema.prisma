  companyId        String
  invoiceLineId    String // The source sale
  journalEntryId   String? // The active recognition journal entry if processed
  totalAmount      Decimal  @db.Decimal(19, 4)
  recognizedAmount Decimal  @default(0) @db.Decimal(19, 4)
  startDate        DateTime
