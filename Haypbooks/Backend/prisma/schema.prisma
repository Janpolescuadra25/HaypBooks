  // Matches DepreciationJournal.taxAttributeSurrenders @relation("TaxAttributeSurrenderedTo")
  surrenderedToDepreciationJournals DepreciationJournal[] @relation("TaxAttributeSurrenderedTo")

  @@index([companyId, attributeType, status])
  @@index([countryId, jurisdictionId])
}

model UncertainTaxPosition {
