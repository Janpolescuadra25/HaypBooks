  workspaceId  String
  itemId       String
  effectiveAt  DateTime
  standardCost Decimal  @db.Decimal(19, 4)
  notes        String?
  createdAt    DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, effectiveAt])
  @@index([itemId])
  @@index([workspaceId])
}

model VarianceJournal {
  id             String       @id @default(uuid())
  workspaceId    String
  type           VarianceType
  amount         Decimal      @db.Decimal(19, 4)
  period         String?
  journalEntryId String?
