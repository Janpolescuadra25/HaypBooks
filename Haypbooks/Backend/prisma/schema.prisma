  createdAt         DateTime @default(now())

  company   Company       @relation(fields: [companyId], references: [id])
  authority TaxAuthority? @relation(fields: [taxAuthorityId], references: [id])

  // Auto-added opposite relations (generated)
  taxReturns TaxReturn[]

  // Auto-added opposite relations (generated)
  depreciationJournals DepreciationJournal[]

  @@index([companyId, period])
  @@index([taxAuthorityId])
}

model TaxIncentive {
  id              String    @id @default(uuid())
