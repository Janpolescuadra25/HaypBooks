model IntercompanyTransaction {
  id                 String                        @id @default(uuid())
  workspaceId        String
  fromCompanyId      String
  toCompanyId        String
  transactionDate    DateTime                      @default(now())
  description        String?
  amount             Decimal                       @db.Decimal(19, 4)
  currency           String?
  status             IntercompanyTransactionStatus @default(DRAFT) // DRAFT, POSTED, VOID
  fromJournalEntryId String?
  toJournalEntryId   String?
  createdAt          DateTime                      @default(now())

  workspace        Workspace     @relation(fields: [workspaceId], references: [id])
  fromCompany      Company       @relation("IntercompanyFrom", fields: [fromCompanyId], references: [id], onDelete: Restrict)
  toCompany        Company       @relation("IntercompanyTo", fields: [toCompanyId], references: [id], onDelete: Restrict)
  fromJournalEntry JournalEntry? @relation("IntercompanyFromJE", fields: [fromJournalEntryId], references: [id])
  toJournalEntry   JournalEntry? @relation("IntercompanyToJE", fields: [toJournalEntryId], references: [id])

  @@index([workspaceId, transactionDate])
  @@index([fromCompanyId, transactionDate])
  @@index([toCompanyId, transactionDate])
}

model ConsolidationEntry {
  id                    String   @id @default(uuid())
  workspaceId           String
  companyId             String
  period                String // e.g., 2024-12
  description           String?
  status                String   @default("DRAFT") // DRAFT, POSTED
  journalEntryId        String?
  functionalCurrency    String?
  presentationCurrency  String?
  exchangeRate          Decimal? @db.Decimal(18, 12)
  translationMethod     String?
  translationAdjustment Decimal? @db.Decimal(19, 4)
  createdAt             DateTime @default(now())

  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@index([workspaceId, period])
  @@index([companyId, period])
}

// --------------------
// Fixed Assets
// --------------------

model FixedAssetCategory {
  id        String @id @default(uuid())
  companyId String
  name      String

  /// Optional link to a standardized category for consistent depreciation & reporting
  standardCategory          StandardFixedAssetCategory?
  /// Default useful life in months — pre-filled when adding assets in this category
  defaultUsefulLifeMonths   Int?
  /// Default depreciation method for new assets in this category
  defaultDepreciationMethod DepreciationMethod?         @default(STRAIGHT_LINE)
  /// Optional description / notes visible to users
  description               String?
  /// Soft-delete flag — inactive categories are hidden from pickers
  isActive                  Boolean                     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets  FixedAsset[]
  company Company      @relation(fields: [companyId], references: [id])

  @@unique([companyId, name])
  @@index([companyId, isActive])
  @@index([standardCategory])
}

enum DepreciationMethod {
  STRAIGHT_LINE // Equal amount each period
  DECLINING_BALANCE // Fixed % applied to net book value each period
  DOUBLE_DECLINING_BALANCE // 200% of the straight-line rate on net book value
  SUM_OF_YEARS_DIGITS // Accelerated — remaining-life fraction of total digits
  UNITS_OF_PRODUCTION // Proportional to actual output / usage units
}

enum WorkspaceType {
  OWNER
  PRACTICE
}

model FixedAsset {
  id                           String             @id @default(uuid())
  companyId                    String
  categoryId                   String?
  name                         String
  description                  String?
  acquisitionDate              DateTime
  cost                         Decimal            @db.Decimal(19, 4)
  salvageValue                 Decimal?           @db.Decimal(19, 4)
  usefulLifeMonths             Int?
  depreciationMethod           DepreciationMethod @default(STRAIGHT_LINE)
  status                       AssetStatus        @default(ACTIVE)
  assetAccountId               String?            @db.Text
  accumulatedDepreciationId    String?            @db.Text
  depreciationExpenseAccountId String?            @db.Text
  createdAt                    DateTime           @default(now())

  company                    Company                  @relation(fields: [companyId], references: [id])
  category                   FixedAssetCategory?      @relation(fields: [categoryId], references: [id])
  assetAccount               Account?                 @relation("FixedAsset_assetAccount", fields: [assetAccountId], references: [id])
  accumAccount               Account?                 @relation("FixedAsset_accumAccount", fields: [accumulatedDepreciationId], references: [id])
  depreciationExpenseAccount Account?                 @relation("FixedAsset_depreciationExpense", fields: [depreciationExpenseAccountId], references: [id])
  depreciations              FixedAssetDepreciation[]
  disposals                  AssetDisposal[]
  impairments                AssetImpairment[]
  revaluations               AssetRevaluation[]
  maintenances               AssetMaintenance[]
  insurances                 AssetInsurance[]
  // Auto-added opposite relations (generated)
  fixedAssetSchedules        FixedAssetSchedule[]
  depreciationAccounts       DepreciationAccount[]

  /// Denormalized standard category for reporting consistency (mirrors category.standardCategory)
  standardCategory StandardFixedAssetCategory?

  /// Soft-delete timestamp — null means the asset is active
  deletedAt DateTime?
  /// User id who soft-deleted this fixed asset
  deletedBy String?

  @@index([companyId])
  @@index([companyId, deletedAt])
}

model FixedAssetDepreciation {
  id          String   @id @default(uuid())
  assetId     String
  companyId   String
  scheduleId  String?
  periodStart DateTime
  periodEnd   DateTime
  amount      Decimal  @db.Decimal(19, 4)
  createdAt   DateTime @default(now())

  asset    FixedAsset          @relation(fields: [assetId], references: [id])
  schedule FixedAssetSchedule? @relation(fields: [scheduleId], references: [id])
  company  Company             @relation(fields: [companyId], references: [id])

  @@index([assetId])
  @@index([companyId])
}

model FixedAssetSchedule {
  id          String   @id @default(uuid())
  companyId   String
  assetId     String
  method      String // STRAIGHT_LINE, DB, MACRS, etc.
  startDate   DateTime
  endDate     DateTime
  totalAmount Decimal? @db.Decimal(19, 4)
  createdAt   DateTime @default(now())

  company              Company                  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  asset                FixedAsset               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  depreciations        FixedAssetDepreciation[]
  // Auto-added opposite relations (generated)
  depreciationJournals DepreciationJournal[]

  @@index([companyId])
  @@index([assetId])
}

model AssetDisposal {
  id           String              @id @default(uuid())
  companyId    String
  assetId      String
  disposalDate DateTime
  method       AssetDisposalMethod
  proceeds     Decimal?            @db.Decimal(19, 4)
  gainLoss     Decimal?            @db.Decimal(19, 4)
  description  String?
  createdAt    DateTime            @default(now())

  company Company    @relation(fields: [companyId], references: [id])
  asset   FixedAsset @relation(fields: [assetId], references: [id])

  @@index([companyId, disposalDate])
  @@index([assetId])
}

model AssetImpairment {
  id               String   @id @default(uuid())
  companyId        String
  assetId          String
  impairmentDate   DateTime
  impairmentAmount Decimal  @db.Decimal(19, 4)
  reason           String?
  createdAt        DateTime @default(now())

  company Company    @relation(fields: [companyId], references: [id])
  asset   FixedAsset @relation(fields: [assetId], references: [id])

  @@index([companyId, impairmentDate])
  @@index([assetId])
}

model AssetRevaluation {
  id                String   @id @default(uuid())
  companyId         String
  assetId           String
  revaluationDate   DateTime
  newValue          Decimal  @db.Decimal(19, 4)
  revaluationAmount Decimal  @db.Decimal(19, 4)
  description       String?
  createdAt         DateTime @default(now())

  company Company    @relation(fields: [companyId], references: [id])
  asset   FixedAsset @relation(fields: [assetId], references: [id])

  @@index([companyId, revaluationDate])
  @@index([assetId])
}

model AssetMaintenance {
  id          String    @id @default(uuid())
  companyId   String
  assetId     String
  scheduledAt DateTime
  completedAt DateTime?
  description String?
  cost        Decimal?  @db.Decimal(19, 4)
  vendor      String?
  createdAt   DateTime  @default(now())

  company Company    @relation(fields: [companyId], references: [id])
  asset   FixedAsset @relation(fields: [assetId], references: [id])

  @@index([companyId, scheduledAt])
  @@index([assetId])
}

model AssetInsurance {
  id             String    @id @default(uuid())
  companyId      String
  assetId        String
  provider       String
  policyNumber   String?
  coverageAmount Decimal?  @db.Decimal(19, 4)
  premiumAmount  Decimal?  @db.Decimal(19, 4)
  effectiveDate  DateTime
  expiryDate     DateTime?
  createdAt      DateTime  @default(now())

  company Company    @relation(fields: [companyId], references: [id])
  asset   FixedAsset @relation(fields: [assetId], references: [id])

  @@index([companyId, expiryDate])
  @@index([assetId])
}

model DepreciationAccount {
  id               String   @id @default(uuid())
  companyId        String
  assetId          String
  expenseAccountId String
  accumAccountId   String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  company        Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  asset          FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  expenseAccount Account    @relation("DepreciationAccount_expense", fields: [expenseAccountId], references: [id])
  accumAccount   Account    @relation("DepreciationAccount_accum", fields: [accumAccountId], references: [id])

  @@unique([companyId, assetId])
  @@index([companyId])
}

model DepreciationJournal {
  id             String    @id @default(uuid())
  companyId      String
  scheduleId     String
  periodStart    DateTime
  periodEnd      DateTime
  amount         Decimal   @db.Decimal(19, 4)
  journalEntryId String?
  postedAt       DateTime?

  company      Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  schedule     FixedAssetSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  journalEntry JournalEntry?      @relation(fields: [journalEntryId], references: [id])

  taxAttributeCarryforwards TaxAttributeCarryforward[]
  uncertainTaxPositions     UncertainTaxPosition[]
  taxAttributeSurrenders    TaxAttributeCarryforward[] @relation("TaxAttributeSurrenderedTo")

  @@index([companyId, periodStart])
  @@index([journalEntryId])
}

model WorkspaceUser {
  workspaceId    String
  userId         String
  // roleId is the single source of truth for workspace roles
  roleId         String
  isOwner        Boolean   @default(false)
  joinedAt       DateTime  @default(now())
  lastAccessedAt DateTime?
  invitedBy      String?
  invitedAt      DateTime?
  status         String    @default("ACTIVE")
  deletedAt      DateTime?

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  invitedByUser User?     @relation("InvitedUsers", fields: [invitedBy], references: [id])
  classId       String?
  class         Class?    @relation(fields: [classId], references: [id])
  locationId    String?
  location      Location? @relation(fields: [locationId], references: [id])
  projectId     String?
  project       Project?  @relation("Project_WorkspaceUsers", fields: [projectId], references: [id])
  user          User      @relation(fields: [userId], references: [id])
  Role          Role?     @relation(fields: [roleId], references: [id])
  // Tasks assigned to this workspace user
  assignedTasks Task[]    @relation("WorkspaceUserAssignedTasks")

  // Auto-added opposite relations (generated)
  companyUsers  CompanyUser[]
  practiceUsers PracticeUser[]

  // Composite id prevents duplicate membership
  @@id([workspaceId, userId])
  @@index([roleId])
  @@index([status])
  @@index([userId])
  @@index([workspaceId, lastAccessedAt])
}

model WorkspaceInvite {
  id           String    @id @default(uuid())
  workspaceId  String
  email        String?   @db.VarChar(320)
  roleId       String?
  invitedBy    String
  invitedAt    DateTime  @default(now())
  expiresAt    DateTime?
  acceptedAt   DateTime?
  status       String    @default("PENDING")
  isLinkInvite Boolean   @default(false)
  contactName  String?
  message      String?

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  role          Role?     @relation(fields: [roleId], references: [id])
  invitedByUser User      @relation("WorkspaceInviteInvitedBy", fields: [invitedBy], references: [id])

  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@index([email])
  @@index([status])
}

// =====================
// Tasks / To-dos
// =====================

model Task {
  id          String  @id @default(uuid())
  workspaceId String
  companyId   String?
  practiceId  String?

  title       String
  description String? @db.Text

  status   TaskStatus   @default(PENDING)
  priority TaskPriority @default(MEDIUM)

  dueDate      DateTime?
  remindAt     DateTime? // When to send reminder
  reminderSent Boolean   @default(false)

  assigneeId  String? // WorkspaceUser.userId
  createdById String

  relatedType String? // e.g., "Invoice" | "Project" | "Customer"
  relatedId   String?

  completedAt DateTime?
  archivedAt  DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // Scope rule: companyId and practiceId should not both be set (see docs/db_constraints.sql)
  company   Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  practice  Practice?      @relation("PracticeTasks", fields: [practiceId], references: [id], onDelete: SetNull)
  // Assignee relation uses the composite key on WorkspaceUser: (workspaceId, userId)
  assignee  WorkspaceUser? @relation("WorkspaceUserAssignedTasks", fields: [workspaceId, assigneeId], references: [workspaceId, userId])
  creator   User           @relation(fields: [createdById], references: [id])

  comments          TaskComment[]
  // Practice Hub back-relation
  practiceCalendars PracticeCalendar[]

  @@index([workspaceId, status])
  @@index([workspaceId, assigneeId])
  @@index([workspaceId, dueDate])
  @@index([workspaceId, priority])
  @@index([remindAt])
  @@index([workspaceId, archivedAt])
  @@index([companyId])
  @@index([practiceId])
}

