/// Structured per-field line for an AuditLog entry — captures before/after values for each changed field.
model AuditLogLine {
  id          String              @id @default(uuid())
  auditLogId  String
  fieldName   String
  /// Serialised old value (null for CREATE)
  oldValue    String?             @db.Text
  /// Serialised new value (null for DELETE)
  newValue    String?             @db.Text
  /// Type of change: CREATE | UPDATE | DELETE
  changeType  ChangeType          @default(UPDATE)
  /// Data type of the field for proper UI formatting
  dataType    AuditFieldDataType?
  /// Flag for PII or sensitive data — masked in standard audit reports
  isSensitive Boolean             @default(false)

  auditLog AuditLog @relation(fields: [auditLogId], references: [id], onDelete: Cascade)

  @@index([auditLogId])
  @@index([auditLogId, fieldName])
  @@index([fieldName, changeType])
}

/// Records every hard-delete or cascade-delete event with the full record snapshot for recovery / audit.
model DeletionLog {
  id            String     @id @default(uuid())
  workspaceId   String
  /// Optional company scope for multi-tenant company-level queries
  companyId     String?
  /// The Prisma model / table name (e.g. 'Invoice', 'DunningNotice')
  tableName     String
  /// Primary key of the deleted record
  recordId      String
  /// Full JSON snapshot of the record at the time of deletion
  deletedData   Json
  /// Free-form metadata (context, reason codes, etc.)
  metadata      Json?
  /// Deletion mode: SOFT | HARD | CASCADE | ARCHIVE
  deleteType    DeleteType @default(SOFT)
  /// User who triggered the deletion (null for system/cascade)
  deletedById   String?
  deletedAt     DateTime   @default(now())
  /// Human-readable reason for deletion
  reason        String?    @db.Text
  /// Authorization/reference number (e.g. approval ticket)
  reference     String?
  /// IP address of the requesting client
  ipAddress     String?
  userAgent     String?
  /// Recovery tracking — set when a soft-delete is reversed
  recoveredAt   DateTime?
  recoveredById String?

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  company     Company?  @relation(fields: [companyId], references: [id])
  deletedBy   User?     @relation("DeletionLog_deletedBy", fields: [deletedById], references: [id])
  recoveredBy User?     @relation("DeletionLog_RecoveredBy", fields: [recoveredById], references: [id])

  @@index([workspaceId, tableName, deletedAt])
  @@index([companyId, tableName, deletedAt])
  @@index([tableName, recordId])
  @@index([deletedById])
  @@index([recoveredById])
}

