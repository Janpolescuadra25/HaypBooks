// =====================
// Workflow Automation
// =====================

model Workflow {
  id          String         @id @default(uuid())
  workspaceId String
  companyId   String?
  practiceId  String?
  name        String
  description String?
  status      WorkflowStatus @default(ACTIVE)
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace Workspace      @relation(fields: [workspaceId], references: [id])
  company   Company?       @relation(fields: [companyId], references: [id])
  practice  Practice?      @relation(fields: [practiceId], references: [id])
  createdBy User?          @relation(fields: [createdById], references: [id])
  rules     WorkflowRule[]
  runs      WorkflowRun[]

  @@index([workspaceId, status])
  @@index([companyId])
  @@index([practiceId])
}

model WorkflowRule {
  id            String              @id @default(uuid())
  workflowId    String
  name          String
  triggerType   WorkflowTriggerType
  triggerConfig Json
  actionType    WorkflowActionType
  actionConfig  Json
  isActive      Boolean             @default(true)
  sortOrder     Int                 @default(0)
  createdAt     DateTime            @default(now())

  workflow Workflow          @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  steps    WorkflowRunStep[]

  @@index([workflowId, isActive, sortOrder])
}

model WorkflowRun {
  id          String            @id @default(uuid())
  workflowId  String
  status      WorkflowRunStatus @default(PENDING)
  context     Json?
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  createdAt   DateTime          @default(now())

  workflow Workflow          @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  steps    WorkflowRunStep[]

  @@index([workflowId, status])
  @@index([createdAt])
}

model WorkflowRunStep {
  id          String             @id @default(uuid())
  runId       String
  ruleId      String
  status      WorkflowStepStatus @default(PENDING)
  output      Json?
  startedAt   DateTime?
  completedAt DateTime?
  error       String?

  run  WorkflowRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  rule WorkflowRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([runId, status])
  @@index([ruleId])
}

/// Pre-built automation template that can be instantiated into a Workflow.
/// Allows practices and companies to share reusable workflow patterns.
model WorkflowTemplate {
  id             String   @id @default(uuid())
  workspaceId    String
  name           String
  description    String?
  /// Domain this template applies to: INVOICE, BILL, JOURNAL, EMPLOYEE, REPORT, etc.
  domain         String
  /// JSON definition of trigger + action rules (mirrors WorkflowRule shape)
  templateConfig Json
  isBuiltIn      Boolean  @default(false) // system-shipped vs user-created
  isActive       Boolean  @default(true)
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  createdBy User?     @relation("WorkflowTemplate_createdBy", fields: [createdById], references: [id])

  @@unique([workspaceId, name])
  @@index([workspaceId, domain, isActive])
  @@index([isBuiltIn])
}

model DocumentApproval {
  id           String                 @id @default(uuid())
  companyId    String
  documentType String
  documentId   String
  approverId   String
  level        Int                    @default(1)
  status       DocumentApprovalStatus @default(PENDING)
  comments     String?
  approvedAt   DateTime?
  createdAt    DateTime               @default(now())

  company  Company @relation(fields: [companyId], references: [id])
  approver User    @relation(fields: [approverId], references: [id])

  @@unique([documentType, documentId, approverId, level])
  @@index([companyId, status])
  @@index([approverId])
}

