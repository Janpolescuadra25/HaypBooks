  id          String  @id @default(uuid())
  profileId   String
  dayOffset   Int // days past due to trigger
  channel     String // EMAIL, SMS, LETTER
  templateKey String
  isActive    Boolean @default(true)

  profile DunningProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Auto-added opposite relations (generated)
  notices DunningNotice[]

  @@index([profileId])
}

model DunningRun {
  id        String           @id @default(uuid())
  profileId String
  companyId String?
  runDate   DateTime         @default(now())
  status    DunningRunStatus @default(PENDING) // PENDING, COMPLETED, FAILED
  createdAt DateTime         @default(now())

  profile DunningProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company Company?        @relation(fields: [companyId], references: [id])
  notices DunningNotice[]

  @@index([profileId, runDate])
  @@index([companyId])
}

model DunningNotice {
  id          String              @id @default(uuid())
  runId       String?
  workspaceId String
  companyId   String
  invoiceId   String
  customerId  String
  stepId      String?
  sentAt      DateTime?
  status      DunningNoticeStatus @default(PENDING) // PENDING, SENT, FAILED
  createdAt   DateTime            @default(now())
  sentById    String?

  run       DunningRun?  @relation(fields: [runId], references: [id])
  step      DunningStep? @relation(fields: [stepId], references: [id])
  workspace Workspace    @relation(fields: [workspaceId], references: [id])
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  invoice   Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  customer  Customer     @relation(fields: [customerId], references: [contactId])
  sentBy    User?        @relation(fields: [sentById], references: [id])

  @@index([workspaceId, status])
  @@index([companyId, sentAt])
  @@index([invoiceId])
  @@index([customerId])
}

model CustomerStatement {
  id          String   @id @default(uuid())
  workspaceId String
  companyId   String
  customerId  String
  periodStart DateTime
  periodEnd   DateTime
  generatedAt DateTime @default(now())
  templateId  String?
  fileUrl     String?

  workspace Workspace         @relation(fields: [workspaceId], references: [id])
  company   Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  customer  Customer          @relation(fields: [customerId], references: [contactId])
  template  DocumentTemplate? @relation(fields: [templateId], references: [id])

  @@index([workspaceId, customerId])
  @@index([companyId, periodStart, periodEnd])
  @@index([companyId, templateId])
}

model PaymentReminder {
  id          String                @id @default(uuid())
  workspaceId String
  companyId   String
  invoiceId   String
  remindAt    DateTime
  status      PaymentReminderStatus @default(PENDING) // PENDING, SENT, CANCELLED
  createdAt   DateTime              @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  invoice   Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, remindAt])
  @@index([companyId, remindAt])
}

model SubscriptionReminder {
  id             String    @id @default(uuid())
  workspaceId    String
  companyId      String?
  practiceId     String?
  subscriptionId String
  remindAt       DateTime
  status         String    @default("PENDING") // PENDING, SENT, CANCELLED
  attempts       Int       @default(0)
  sentAt         DateTime?
  errorMessage   String?
  createdAt      DateTime  @default(now())

  workspace    Workspace    @relation(fields: [workspaceId], references: [id])
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  practice     Practice?    @relation(fields: [practiceId], references: [id], onDelete: Restrict)
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([workspaceId, remindAt])
  @@index([companyId, remindAt])
  @@index([practiceId, remindAt])
  @@index([subscriptionId, remindAt])
}

model DisputeReason {
  id          String  @id @default(uuid())
  workspaceId String
  name        String
  isActive    Boolean @default(true)

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  disputes  Dispute[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Dispute {
  id          String        @id @default(uuid())
  workspaceId String
  companyId   String
  invoiceId   String
  reasonId    String?
  status      DisputeStatus @default(OPEN) // OPEN, RESOLVED, REJECTED
  amount      Decimal?      @db.Decimal(19, 4)
  openedAt    DateTime      @default(now())
  closedAt    DateTime?
  notes       String?

  workspace Workspace      @relation(fields: [workspaceId], references: [id])
  company   Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  invoice   Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  reason    DisputeReason? @relation(fields: [reasonId], references: [id])

  @@index([workspaceId, status])
  @@index([companyId, status])
  @@index([invoiceId])
}

model Chargeback {
  id          String           @id @default(uuid())
  workspaceId String
  companyId   String
  invoiceId   String
  paymentId   String?
  status      ChargebackStatus @default(OPEN) // OPEN, WON, LOST
  amount      Decimal          @db.Decimal(19, 4)
  reason      String?
  openedAt    DateTime         @default(now())
  closedAt    DateTime?

  workspace Workspace        @relation(fields: [workspaceId], references: [id])
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  invoice   Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  payment   PaymentReceived? @relation(fields: [paymentId], references: [id])

  @@index([workspaceId, status])
  @@index([companyId, status])
  @@index([invoiceId])
  @@index([paymentId])
}

model BankFeedRule {
  id        String @id @default(uuid())
  companyId String
  name      String
  priority  Int    @default(0)

  // Conditions
  matchType      String // "CONTAINS", "EXACT", "STARTS_WITH"
  matchString    String // e.g., "Starbucks"
  amountRangeMin Decimal?
  amountRangeMax Decimal?

  // Actions
  assignmentAccountId String? // Categorize to this GL Account
  assignmentPayee     String? // Set vendor/customer
  assignmentClassId   String? // Assign class/fund

  isActive Boolean @default(true)
  company  Company @relation(fields: [companyId], references: [id])

  @@index([companyId, isActive])
}

model BankFeedConnection {
  id           String    @id @default(uuid())
  workspaceId  String
  companyId    String
  provider     String // PLAID, YODLEE, MANUAL
  externalId   String? // provider item id
  status       String    @default("ACTIVE") // ACTIVE, DISCONNECTED, ERROR
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())

  workspace Workspace         @relation(fields: [workspaceId], references: [id])
  company   Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  accounts  BankFeedAccount[]
  imports   BankFeedImport[]

  @@index([workspaceId])
  @@index([companyId])
  @@index([status])
}

model BankFeedAccount {
  id                String  @id @default(uuid())
  connectionId      String
  bankAccountId     String
  externalAccountId String
  companyId         String?
  currency          String?
  nickname          String?

  connection      BankFeedConnection   @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  bankAccount     BankAccount          @relation(fields: [bankAccountId], references: [id])
  company         Company?             @relation(fields: [companyId], references: [id])
  rawTransactions BankTransactionRaw[]

  @@unique([connectionId, externalAccountId])
  @@index([bankAccountId])
  @@index([companyId])
}

model BankFeedImport {
  id           String    @id @default(uuid())
  connectionId String
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  status       String    @default("PENDING") // PENDING, COMPLETED, FAILED
  rawCount     Int       @default(0)
  companyId    String?

  connection      BankFeedConnection   @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  company         Company?             @relation(fields: [companyId], references: [id])
  rawTransactions BankTransactionRaw[]

  @@index([connectionId, startedAt])
  @@index([status])
  @@index([companyId])
}

model BankTransactionRaw {
  id                String   @id @default(uuid())
  companyId         String
  importId          String
  bankFeedAccountId String
  bankAccountId     String
  externalId        String
  amount            Decimal  @db.Decimal(19, 4)
  date              DateTime
  description       String
  /// Raw transaction payload from the upstream provider
  rawPayload        Json
  bankTransactionId String?

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  import          BankFeedImport   @relation(fields: [importId], references: [id], onDelete: Cascade)
  bankFeedAccount BankFeedAccount  @relation(fields: [bankFeedAccountId], references: [id])
  bankAccount     BankAccount      @relation(fields: [bankAccountId], references: [id])
  bankTransaction BankTransaction? @relation(fields: [bankTransactionId], references: [id])

  @@unique([bankFeedAccountId, externalId])
  @@index([companyId, date])
  @@index([companyId, date, amount])
  @@index([companyId, bankAccountId, date])
  @@index([companyId, bankAccountId, amount, date, description])
  @@index([bankAccountId, date])
  @@index([bankTransactionId])
}

model BankAccount {
  id                  String    @id @default(uuid())
  workspaceId         String
  name                String
  institution         String?
  accountNumber       String?
  routingNumber       String?
  swiftCode           String?
  iban                String?
  isDefault           Boolean   @default(false)
  checkStartingNumber Int?
  lastCheckNumber     Int?
  createdAt           DateTime  @default(now())
  /// Soft-delete — null means active account
  deletedAt           DateTime?

  workspace               Workspace               @relation(fields: [workspaceId], references: [id])
  transactions            BankTransaction[]
  rawTransactions         BankTransactionRaw[]
  paymentsReceived        PaymentReceived[]
  deposits                BankDeposit[]
  checks                  Check[]
  customerRefunds         CustomerRefund[]
  vendorRefunds           VendorRefund[]
  undepositedFundsBatches UndepositedFundsBatch[]
  cashOverShortRules      CashOverShortRule[]
  BillPayment             BillPayment[]
  BankReconciliation      BankReconciliation[]
  // Auto-added opposite relations (generated)
  bankFeedAccounts        BankFeedAccount[]
  transfersFrom           BankTransfer[]          @relation("TransferFrom")
  transfersTo             BankTransfer[]          @relation("TransferTo")

  @@unique([workspaceId, institution, accountNumber])
  @@index([workspaceId])
  @@index([workspaceId, deletedAt])
}

model BankTransaction {
  id            String                @id @default(uuid())
  bankAccountId String
  amount        Decimal               @db.Decimal(19, 4)
  date          DateTime
  description   String
  workspaceId   String
  category      String?
  memo          String?
  status        BankTransactionStatus @default(PENDING)

  bankAccount            BankAccount              @relation(fields: [bankAccountId], references: [id])
  workspace              Workspace                @relation(fields: [workspaceId], references: [id])
  BankReconciliationLine BankReconciliationLine[]
  // Auto-added opposite relations (generated)
  rawTransactions        BankTransactionRaw[]
  splits                 BankTransactionSplit[]

  @@index([workspaceId])
  @@index([workspaceId, date])
  @@index([bankAccountId, date, amount])
  @@index([bankAccountId, date, description])
  @@index([workspaceId, date, bankAccountId])
}

enum BankTransactionStatus {
  PENDING
  CATEGORIZED
  MATCHED
  SPLIT
  EXCLUDED
}

model BankTransactionSplit {
  id                String  @id @default(uuid())
  bankTransactionId String
  accountCode       String
  description       String
  amount            Decimal @db.Decimal(19, 4)
  workspaceId       String

  bankTransaction BankTransaction @relation(fields: [bankTransactionId], references: [id], onDelete: Cascade)
  workspace       Workspace       @relation(fields: [workspaceId], references: [id])

  @@index([bankTransactionId])
  @@index([workspaceId])
}

model BankTransfer {
  id                String   @id @default(uuid())
  workspaceId       String
  fromBankAccountId String
  toBankAccountId   String
  amount            Decimal  @db.Decimal(19, 4)
  date              DateTime
  memo              String?
  fromTransactionId String?  @unique
  toTransactionId   String?  @unique
  createdAt         DateTime @default(now())

  workspace       Workspace   @relation(fields: [workspaceId], references: [id])
  fromBankAccount BankAccount @relation("TransferFrom", fields: [fromBankAccountId], references: [id])
  toBankAccount   BankAccount @relation("TransferTo", fields: [toBankAccountId], references: [id])

  @@index([workspaceId])
  @@index([fromBankAccountId])
  @@index([toBankAccountId])
}

model BankDeposit {
  id              String            @id @default(uuid())
  workspaceId     String
  companyId       String
  bankAccountId   String
  depositDate     DateTime          @default(now())
  totalAmount     Decimal           @db.Decimal(19, 4)
  currency        String?
  exchangeRate    Decimal?          @db.Decimal(18, 12)
  baseAmount      Decimal?          @db.Decimal(19, 4)
  status          BankDepositStatus @default(DRAFT) // DRAFT, POSTED, VOID
  referenceNumber String?

  workspace            Workspace            @relation(fields: [workspaceId], references: [id])
  company              Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  bankAccount          BankAccount          @relation(fields: [bankAccountId], references: [id])
  lines                BankDepositLine[]
  depositSlip          DepositSlip?
  cashOverShortEntries CashOverShortEntry[]
  journalEntryId       String?
  journalEntry         JournalEntry?        @relation("JournalEntry_BankDeposits", fields: [journalEntryId], references: [id])

  @@index([workspaceId, depositDate])
  @@index([companyId, depositDate])
  @@index([bankAccountId])
  @@index([journalEntryId])
}

model UndepositedFundsBatch {
  id            String                      @id @default(uuid())
  workspaceId   String?
  companyId     String
  bankAccountId String
  totalAmount   Decimal                     @db.Decimal(19, 4)
  status        UndepositedFundsBatchStatus @default(PENDING) // PENDING, DEPOSITED
  createdAt     DateTime                    @default(now())
  depositedAt   DateTime?

  workspace   Workspace?        @relation(fields: [workspaceId], references: [id])
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  bankAccount BankAccount       @relation(fields: [bankAccountId], references: [id])
  payments    PaymentReceived[]

  @@index([workspaceId])
  @@index([companyId, status])
  @@index([bankAccountId])
}

model BankDepositLine {
  id                String  @id @default(uuid())
  depositId         String
  paymentReceivedId String
  amount            Decimal @db.Decimal(19, 4)

  deposit         BankDeposit     @relation(fields: [depositId], references: [id], onDelete: Cascade)
  paymentReceived PaymentReceived @relation(fields: [paymentReceivedId], references: [id])

  @@unique([depositId, paymentReceivedId])
  @@index([depositId])
}

model DepositSlip {
  id              String    @id @default(uuid())
  workspaceId     String?
  depositId       String    @unique
  slipNumber      String?
  preparedById    String?
  preparedAt      DateTime  @default(now())
  printedAt       DateTime?
  printCount      Int       @default(0)
  templateId      String?
  layoutConfig    Json?
  lastPrintedById String?
  notes           String?

  workspace     Workspace?        @relation(fields: [workspaceId], references: [id])
  deposit       BankDeposit       @relation(fields: [depositId], references: [id], onDelete: Cascade)
  preparedBy    User?             @relation("DepositSlip_PreparedBy", fields: [preparedById], references: [id])
  template      DocumentTemplate? @relation(fields: [templateId], references: [id])
  lastPrintedBy User?             @relation("DepositSlip_LastPrintedBy", fields: [lastPrintedById], references: [id])

  @@index([workspaceId])
  @@index([preparedById])
  @@index([lastPrintedById])
}

model CashOverShortEntry {
  id        String  @id @default(uuid())
  depositId String
  ruleId    String?
  accountId String? // Optional: map to a specific GL account
  amount    Decimal @db.Decimal(19, 4) // Positive = over, Negative = short
  reason    String?

  deposit BankDeposit        @relation(fields: [depositId], references: [id], onDelete: Cascade)
  rule    CashOverShortRule? @relation(fields: [ruleId], references: [id])
  account Account?           @relation(fields: [accountId], references: [id])

  @@index([depositId])
  @@index([ruleId])
  @@index([accountId])
}

model CashOverShortRule {
  id              String   @id @default(uuid())
  companyId       String
  bankAccountId   String?
  accountId       String? // GL account for variance
  direction       String // OVER, SHORT, BOTH
  thresholdAmount Decimal? @db.Decimal(19, 4)
  autoPost        Boolean  @default(true)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  company     Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  bankAccount BankAccount?         @relation(fields: [bankAccountId], references: [id])
  account     Account?             @relation(fields: [accountId], references: [id])
  entries     CashOverShortEntry[]

  @@index([companyId, isActive])
  @@index([bankAccountId])
  @@index([accountId])
}

// --------------------
// Cash Management
// --------------------

model PettyCashFund {
  id            String          @id @default(uuid())
  companyId     String
  custodianId   String?
  accountId     String
  location      String?
  maxAmount     Decimal         @db.Decimal(19, 4)
  currentAmount Decimal         @db.Decimal(19, 4)
  status        PettyCashStatus @default(ACTIVE)
  createdAt     DateTime        @default(now())

  company   Company            @relation(fields: [companyId], references: [id])
  custodian Employee?          @relation(fields: [custodianId], references: [id])
  account   Account            @relation(fields: [accountId], references: [id])
  vouchers  PettyCashVoucher[]

  @@index([companyId, status])
}

model PettyCashVoucher {
  id              String    @id @default(uuid())
  fundId          String
  voucherNumber   String
  date            DateTime
  payee           String
  description     String
  amount          Decimal   @db.Decimal(19, 4)
  accountId       String?
  approvedById    String?
  receiptAttached Boolean   @default(false)
  reconciledAt    DateTime?

  fund       PettyCashFund @relation(fields: [fundId], references: [id])
  account    Account?      @relation(fields: [accountId], references: [id])
  approvedBy User?         @relation(fields: [approvedById], references: [id])

  @@unique([fundId, voucherNumber])
  @@index([fundId, date])
  @@index([approvedById])
}

model Check {
  id            String      @id @default(uuid())
  companyId     String
  bankAccountId String
  checkNumber   String
  payee         String
  amount        Decimal     @db.Decimal(19, 4)
  date          DateTime
  memo          String?
  status        CheckStatus @default(DRAFT)
  printedAt     DateTime?
  issuedAt      DateTime?
  clearedAt     DateTime?
  voidedAt      DateTime?
  stopPaymentAt DateTime?
  paymentId     String?
  templateId    String?

  company     Company           @relation(fields: [companyId], references: [id])
  bankAccount BankAccount       @relation(fields: [bankAccountId], references: [id])
  payment     BillPayment?      @relation(fields: [paymentId], references: [id])
  template    DocumentTemplate? @relation(fields: [templateId], references: [id])

  @@unique([companyId, bankAccountId, checkNumber])
  @@index([companyId, status])
  @@index([checkNumber])
  @@index([companyId, templateId])
}

// --------------------
// Accounts Payable / Purchases
// --------------------

model Bill {
  id                    String           @id @default(uuid())
  companyId             String
  workspaceId           String
  vendorId              String
  billNumber            String?
  status                BillStatus       @default(DRAFT)
  paymentStatus         PaymentStatus    @default(DRAFT)
  total                 Decimal          @db.Decimal(19, 4)
  balance               Decimal          @db.Decimal(19, 4)
  currency              String?
  exchangeRate          Decimal?         @db.Decimal(18, 12)
  baseTotal             Decimal?         @db.Decimal(19, 4)
  transactionType       TransactionType?
  discountAmount        Decimal?         @db.Decimal(19, 4)
  shippingAmount        Decimal?         @db.Decimal(19, 4)
  otherCharges          Decimal?         @db.Decimal(19, 4)
  withholdingTaxAmount  Decimal?         @db.Decimal(19, 4)
  creditableWithholding Decimal?         @db.Decimal(19, 4)
  issuedAt              DateTime         @default(now())
  dueAt                 DateTime?
  paymentTermId         String?
  paymentTerm           PaymentTerm?     @relation(fields: [paymentTermId], references: [id])
  description           String?
  deletedAt             DateTime?

  workspace              Workspace                @relation(fields: [workspaceId], references: [id])
  vendor                 Vendor                   @relation(fields: [vendorId], references: [contactId])
  lines                  BillLine[]
  payments               BillPayment[]
  journalEntryId         String?
  journalEntry           JournalEntry?            @relation("JournalEntry_Bills", fields: [journalEntryId], references: [id])
  postingStatus          PostingStatus            @default(DRAFT)
  company                Company                  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  BillPaymentApplication BillPaymentApplication[]
  // Project retention schedules attached to this bill
  retentionSchedules     RetentionSchedule[]
  writeOffs              WriteOff[]

  createdById     String?
  updatedById     String?
  createdBy       User?             @relation("Bill_createdBy", fields: [createdById], references: [id])
  updatedBy       User?             @relation("Bill_updatedBy", fields: [updatedById], references: [id])
  // Auto-added opposite relations (generated)
  debitNotes      DebitNote[]
  ApprovalRequest ApprovalRequest[]

  @@unique([companyId, vendorId, billNumber])
  @@index([createdById])
  @@index([updatedById])
  @@index([workspaceId, status])
  @@index([workspaceId, vendorId])
  @@index([workspaceId, vendorId, status])
  @@index([companyId, vendorId, status])
  @@index([companyId])
  @@index([workspaceId, issuedAt])
  @@index([deletedAt])
  @@index([companyId, status, dueAt, deletedAt])
  @@index([companyId, postingStatus, issuedAt])
  @@index([companyId, status, dueAt, balance])
  @@index([companyId, paymentStatus, dueAt])
  @@index([companyId, deletedAt])
  @@index([companyId, dueAt, balance, status, deletedAt])
  @@index([companyId, vendorId, dueAt, balance])
  @@index([companyId, status, dueAt])
}

model BillLine {
  id              String   @id @default(uuid())
  companyId       String
  billId          String
  workspaceId     String
  accountId       String?
  itemId          String?
  description     String?
  quantity        Decimal  @db.Decimal(16, 6)
  rate            Decimal  @db.Decimal(8, 4)
  amount          Decimal  @db.Decimal(19, 4)
  taxCodeId       String?
  discountPercent Decimal? @db.Decimal(8, 4)
  discountAmount  Decimal? @db.Decimal(19, 4)

  bill       Bill      @relation(fields: [billId], references: [id], onDelete: Cascade)
  account    Account?  @relation(fields: [accountId], references: [id])
  item       Item?     @relation(fields: [itemId], references: [id])
  workspace  Workspace @relation(fields: [workspaceId], references: [id])
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  classId    String?
  class      Class?    @relation(fields: [classId], references: [id])
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])
  projectId  String?
  project    Project?  @relation(fields: [projectId], references: [id])
  LineTax    LineTax[]

  @@index([billId])
  @@index([workspaceId])
  @@index([companyId])
}

model PurchaseOrder {
  id                     String              @id @default(uuid())
  companyId              String
  workspaceId            String
  vendorId               String
  poNumber               String?
  status                 PurchaseOrderStatus @default(OPEN)
  postingStatus          PostingStatus       @default(DRAFT)
  total                  Decimal             @db.Decimal(19, 4)
  createdAt              DateTime            @default(now())
  expectedAt             DateTime?
  receivedAt             DateTime?
  inventoryTransactionId String?
  deletedAt              DateTime?
  templateId             String?

  workspace             Workspace              @relation(fields: [workspaceId], references: [id])
  company               Company                @relation(fields: [companyId], references: [id])
  vendor                Vendor                 @relation(fields: [vendorId], references: [contactId])
  template              DocumentTemplate?      @relation(fields: [templateId], references: [id])
  lines                 PurchaseOrderLine[]
  inventoryTransactions InventoryTransaction[]
  purchaseRequests      PurchaseRequest[]

  // Auto-added opposite relations (generated)
  letterOfCredits LetterOfCredit[]
  ApprovalRequest ApprovalRequest[]

  @@unique([workspaceId, poNumber])
  @@index([workspaceId, status])
  @@index([workspaceId, vendorId])
  @@index([companyId])
  @@index([companyId, templateId])
  @@index([deletedAt])
}

model LetterOfCredit {
  id              String   @id @default(uuid())
  companyId       String
  lcNumber        String
  issuingBank     String
  beneficiary     String
  amount          Decimal  @db.Decimal(19, 4)
  currency        String
  expiryDate      DateTime
  status          String   @default("ISSUED")
  purchaseOrderId String?

  company       Company        @relation(fields: [companyId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  @@unique([companyId, lcNumber])
