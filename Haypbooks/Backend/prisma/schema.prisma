// Landed cost support for import-heavy workflows
enum LandedCostStatus {
  PENDING
  POSTED
  VOID
}

enum LandedCostLineType {
  FREIGHT
  DUTY
  BROKERAGE
  INSURANCE
  OTHER
}

model LandedCost {
  id                String           @id @default(uuid())
  workspaceId       String
  purchaseOrderId   String?
  inventoryTxLineId String?
  totalAmount       Decimal          @db.Decimal(19, 4)
