model AiModel {
  id          String  @id @default(uuid())
  workspaceId String
  companyId   String?

  name        String
  description String?
  modelType   AiModelType
  version     String
  status      AiModelStatus @default(TRAINING)

  config   Json
  features String[]
  metrics  Json?

