// --------------------
// Non-Profit Module (Fund Accounting)
// --------------------

model Fund {
  id          String @id @default(uuid())
  workspaceId String
  companyId   String

  name String // e.g. "General Operating Fund", "Scholarship Fund"
  code String @unique // e.g., "100", "200"
  type String // UNRESTRICTED, TEMPORARILY_RESTRICTED, PERMANENTLY_RESTRICTED

  description String?
  startDate   DateTime?
  endDate     DateTime? // If grant-specific

  balance  Decimal @default(0) @db.Decimal(19, 4)
  isActive Boolean @default(true)

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  company   Company   @relation(fields: [companyId], references: [id])

  allocations FundAllocation[]
  segments    AccountSegment[] // Linking GL accounts to Funds (Fund Accounting)

  // Auto-added opposite relations (generated)
  matchedDonations Donation[]

  @@index([companyId, type])
}

model FundAllocation {
  id              String @id @default(uuid())
  fundId          String
  transactionId   String // Polymorphic (Invoice, Bill, JournalEntry)
  transactionType String // INVOICE, BILL, JOURNAL

  amount     Decimal  @db.Decimal(19, 4)
  percentage Decimal? @db.Decimal(8, 4)

  fund Fund @relation(fields: [fundId], references: [id])

  @@index([transactionId, transactionType])
  @@index([fundId])
}

model Donation {
  id          String @id @default(uuid())
  workspaceId String
  companyId   String

  donorId String // Links to Customer/Contact
  fundId  String? // Designated fund

  amount Decimal  @db.Decimal(19, 4)
  date   DateTime
  type   String // CASH, PLEDGE, IN_KIND
  status String // RECEIVED, PLEDGED, WRITTEN_OFF

  campaign    String? // e.g., "2025 Annual Appeal"
  restriction String? // Notes on restrictions

  acknowledgmentSent Boolean @default(false)
  receiptNumber      String?

  createdAt DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  company     Company   @relation(fields: [companyId], references: [id])
  donor       Customer  @relation(fields: [donorId], references: [contactId])
  matchedFund Fund?     @relation(fields: [fundId], references: [id])

  @@index([companyId, date])
  @@index([donorId])
}

model Pledge {
  id        String @id @default(uuid())
  companyId String
  donorId   String

  totalAmount     Decimal  @db.Decimal(19, 4)
  startDate       DateTime
  endDate         DateTime
  installmentFreq String // MONTHLY, QUARTERLY, ANNUALLY

  amountPaid Decimal @default(0) @db.Decimal(19, 4)
  status     String // ACTIVE, FULFILLED, CANCELLED

  company Company  @relation(fields: [companyId], references: [id])
  donor   Customer @relation(fields: [donorId], references: [contactId])

  @@index([donorId])
}

// ─── Fundraising Campaigns ─────────────────────────────────────────────

enum CampaignStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

model Campaign {
  id          String         @id @default(uuid())
  companyId   String
  name        String
  description String?        @db.Text
  goal        Decimal?       @db.Decimal(19, 4)
  startDate   DateTime
  endDate     DateTime?
  status      CampaignStatus @default(DRAFT)
  totalRaised Decimal        @default(0) @db.Decimal(19, 4)
  donorCount  Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId, status])
  @@index([companyId, startDate])
}

// --------------------
// Property Management (Real Estate)
// --------------------

model Property {
  id          String @id @default(uuid())
  workspaceId String
  companyId   String

  name    String // "Sunset Apartments"
  address String
  type    String // RESIDENTIAL, COMMERCIAL, INDUSTRIAL

  units PropertyUnit[]

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  company   Company   @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model PropertyUnit {
  id         String @id @default(uuid())
  propertyId String

  unitNumber String // "Apt 101"
  status     String // VACANT, OCCUPIED, MAINTENANCE
  marketRent Decimal @db.Decimal(19, 4)

  currentLeaseId String?

  property Property @relation(fields: [propertyId], references: [id])
  leases   Lease[]

  @@unique([propertyId, unitNumber])
}

model Lease {
  id       String @id @default(uuid())
  unitId   String
  tenantId String // Links to Customer

  startDate       DateTime
  endDate         DateTime
  rentAmount      Decimal  @db.Decimal(19, 4)
  securityDeposit Decimal  @db.Decimal(19, 4)

  status String // ACTIVE, TERMINATED, RENEWED

  unit   PropertyUnit @relation(fields: [unitId], references: [id])
  tenant Customer     @relation(fields: [tenantId], references: [contactId])

  @@index([tenantId])
  @@index([unitId])
}

// --------------------
// Construction & Project Industry Features
// --------------------

model ContractRetention {
  id          String @id @default(uuid())
  workspaceId String
  companyId   String
  projectId   String

  // The general retention policy for this project
  retentionPercent Decimal @db.Decimal(8, 4) // e.g., 10%
  totalWithheld    Decimal @default(0) @db.Decimal(19, 4)
  totalReleased    Decimal @default(0) @db.Decimal(19, 4)

  // Status
  status    String   @default("ACTIVE") // ACTIVE, CLOSED, RELEASED
  createdAt DateTime @default(now())

  workspace Workspace        @relation(fields: [workspaceId], references: [id])
  company   Company          @relation(fields: [companyId], references: [id])
  project   Project          @relation(fields: [projectId], references: [id])
  entries   RetentionEntry[]

  @@unique([projectId])
  @@index([companyId])
}

model RetentionEntry {
  id          String  @id @default(uuid())
  retentionId String
  invoiceId   String? // Source invoice (AR)
  billId      String? // Source bill (AP)

  amount      Decimal  @db.Decimal(19, 4)
  date        DateTime
  type        String // WITHHELD, RELEASED
  description String?

  retention ContractRetention @relation(fields: [retentionId], references: [id])

  @@index([retentionId])
  @@index([invoiceId])
  @@index([billId])
}

// --------------------
// Retail Industry Features
// --------------------

model GiftCard {
  id          String @id @default(uuid())
  workspaceId String
  companyId   String

  code           String // Hashed or encrypted in real app? Or last 4 + separate lookup
  initialBalance Decimal @db.Decimal(19, 4)
  currentBalance Decimal @db.Decimal(19, 4)

  issuedAt  DateTime  @default(now())
  expiresAt DateTime?
  status    String    @default("ACTIVE") // ACTIVE, REDEEMED, VOID

  recipientEmail String?

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  company   Company   @relation(fields: [companyId], references: [id])

  @@unique([companyId, code])
  @@index([companyId, status])
}

model LoyaltyProgram {
  id          String @id @default(uuid())
  workspaceId String
  companyId   String

  name            String // e.g. "Gold Rewards"
  pointsPerDollar Decimal @db.Decimal(19, 4) // Earn rate
  redemptionRatio Decimal @db.Decimal(19, 4) // Points needed for $1 off

  isActive  Boolean   @default(true)
  company   Company   @relation(fields: [companyId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  accounts LoyaltyAccount[]

  @@index([companyId])
}

model LoyaltyAccount {
  id         String @id @default(uuid())
  programId  String
  customerId String

  pointsBalance  Int     @default(0)
  lifetimePoints Int     @default(0)
  currentTier    String? // BRONZE, SILVER, GOLD

  updatedAt DateTime @updatedAt

  program  LoyaltyProgram @relation(fields: [programId], references: [id])
  customer Customer       @relation(fields: [customerId], references: [contactId])

  @@unique([programId, customerId])
}

model Currency {
  code     String  @id
  name     String
  symbol   String
  decimals Int     @default(2)
  isActive Boolean @default(true)
}

model PaymentTerm {
  id           String   @id @default(uuid())
  workspaceId  String
  name         String // e.g., "Net 30"
  dueDays      Int
  discountDays Int? // e.g., 10 (for 2/10 Net 30)
  discountPct  Decimal? @db.Decimal(8, 4)
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)

  workspace Workspace  @relation(fields: [workspaceId], references: [id])
  customers Customer[]
  vendors   Vendor[]
  invoices  Invoice[]
  bills     Bill[]

  @@index([workspaceId])
}

enum PaymentMethodType {
  CASH
  CHECK
  CARD
  BANK
  OTHER
}

model PaymentMethod {
  id          String            @id @default(uuid())
  workspaceId String
  name        String // e.g., "Check", "Wire", "Credit Card"
  type        PaymentMethodType // CASH, CHECK, CARD, BANK, OTHER
  isActive    Boolean           @default(true)

  workspace        Workspace         @relation(fields: [workspaceId], references: [id])
  paymentsReceived PaymentReceived[]

  @@index([workspaceId])
}

model ExchangeRate {
  id           String   @id @default(uuid())
  baseCurrency String
  toCurrency   String
  rate         Decimal  @db.Decimal(8, 4)
  date         DateTime
  source       String?

  @@unique([baseCurrency, toCurrency, date])
}

model ForeignCurrencyGainLoss {
  id               String    @id @default(uuid())
  companyId        String
  transactionId    String
  transactionType  String // INVOICE, BILL, PAYMENT
  originalAmount   Decimal   @db.Decimal(19, 4)
  originalCurrency String
  baseAmount       Decimal   @db.Decimal(19, 4)
  baseCurrency     String
  exchangeRate     Decimal   @db.Decimal(18, 12)
  gainLoss         Decimal   @db.Decimal(19, 4)
  realizedAt       DateTime?

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, realizedAt])
  @@index([transactionType, transactionId])
}

model AccountSubType {
  id        Int       @id @default(autoincrement())
  name      String
  typeId    Int
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  accounts  Account[]

  @@index([companyId, typeId])
}

model AccountBalance {
  id             String   @id @default(uuid())
  accountId      String
  companyId      String
  yearMonth      String
  balance        Decimal  @db.Decimal(19, 4)
  balanceForeign Decimal? @db.Decimal(19, 4)

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, accountId, yearMonth])
  @@index([companyId, yearMonth])
  @@index([companyId, yearMonth, accountId])
  @@index([companyId, yearMonth, balance])
  @@index([accountId, yearMonth])
}

model AccountBalanceAudit {
  id           String   @id @default(uuid())
  companyId    String
  accountId    String
  period       String // 2024-12
  oldBalance   Decimal  @db.Decimal(19, 4)
  newBalance   Decimal  @db.Decimal(19, 4)
  changeReason String // JOURNAL_ENTRY, ADJUSTMENT, CLOSING
  referenceId  String?
  changedBy    String?
  changedAt    DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  account Account @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([companyId, accountId, period])
}

model OpeningBalance {
  id        String   @id @default(uuid())
  companyId String
  accountId String
  amount    Decimal  @db.Decimal(19, 4)
  asOfDate  DateTime
  createdAt DateTime @default(now())
  account   Account  @relation(fields: [accountId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, accountId])
}

model Class {
  id                       String                     @id @default(uuid())
  companyId                String
  name                     String
  parentId                 String?
  isActive                 Boolean                    @default(true)
  createdAt                DateTime                   @default(now())
  BudgetLine               BudgetLine[]
  JournalEntryLine         JournalEntryLine[]
  InventoryTransactionLine InventoryTransactionLine[]
  InvoiceLine              InvoiceLine[]
  BillLine                 BillLine[]
  company                  Company                    @relation(fields: [companyId], references: [id])
  // Auto-added opposite relations (generated)
  workspaceUsers           WorkspaceUser[]
  // Versions opposites
  budgetLineVersions       BudgetLineVersion[]

  @@unique([companyId, name])
}

model Location {
  id                       String                     @id @default(uuid())
  companyId                String
  name                     String
  address                  String?
  isActive                 Boolean                    @default(true)
  JournalEntryLine         JournalEntryLine[]
  InventoryTransactionLine InventoryTransactionLine[]
  InvoiceLine              InvoiceLine[]
  BillLine                 BillLine[]
  company                  Company                    @relation(fields: [companyId], references: [id])
  // Auto-added opposite relations (generated)
  workspaceUsers           WorkspaceUser[]

  @@unique([companyId, name])
}

model Project {
  id           String    @id @default(uuid())
  companyId    String
  workspaceId  String
  customerId   String?
  name         String
  description  String?
  startDate    DateTime?
  endDate      DateTime?
  status       String    @default("ACTIVE")
  budgetAmount Decimal?  @db.Decimal(19, 4)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  timeEntries              TimeEntry[]
  JournalEntryLine         JournalEntryLine[]
  InventoryTransactionLine InventoryTransactionLine[]
  InvoiceLine              InvoiceLine[]
  BillLine                 BillLine[]
  company                  Company                    @relation(fields: [companyId], references: [id])
  workspace                Workspace                  @relation(fields: [workspaceId], references: [id])
  lines                    ProjectLine[]
  constructionProjects     ConstructionProject[]

  timerSessions         TimerSession[]
  resourceAllocations   ResourceAllocation[]
  // Auto-added opposite relations (generated)
  projectWorkspaceUsers WorkspaceUser[]      @relation("Project_WorkspaceUsers")

  // Auto-added opposite relations (generated)
  retentions ContractRetention[]

  // ProjectLine and Revenue Recognition schedule
  billings        ProjectBilling[]  @relation("ProjectBillings")
  worksInProgress WorkInProgress[]  @relation("ProjectWIP")
  retainers       ProjectRetainer[] @relation("ProjectRetainers")
  tasks           ProjectTask[]

  @@index([companyId, status])
}

// ─── Project Task Management ───────────────────────────────────────────

enum ProjectTaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

model ProjectTask {
  id           String            @id @default(uuid())
  projectId    String
  name         String
  description  String?           @db.Text
  assignedToId String? // user id — plain reference, no FK constraint
  status       ProjectTaskStatus @default(TODO)
  priority     String? // LOW, MEDIUM, HIGH
  dueDate      DateTime?
  completedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
}

model ProjectLine {
  id          String    @id @default(uuid())
  workspaceId String
  projectId   String
  sourceType  String
  sourceId    String
  amount      Decimal   @db.Decimal(19, 4)
  currency    String
  postedAt    DateTime?
  createdAt   DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([workspaceId])
  @@index([sourceType, sourceId])
}

// =====================
// Construction & Project Management (Grok 11)
// =====================

enum ProjectPhase {
  PLANNING
  DESIGN
  PRE_CONSTRUCTION
  PROCUREMENT
  CONSTRUCTION
  POST_CONSTRUCTION
  CLOSEOUT
  COMPLETED
}

enum ChangeOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  VOID
}

enum LienStatus {
  PENDING
  FILED
  RELEASED
  VOID
}

enum RetentionStatus {
  WITHHELD
  DUE
  RELEASED
  FORFEITED
}

model ConstructionProject {
  id               String       @id @default(uuid())
  companyId        String
  workspaceId      String
  projectId        String       @unique // Reference to existing Project model
  contractNumber   String?
  contractType     String? // LUMP_SUM, COST_PLUS, TIME_AND_MATERIALS
  contractAmount   Decimal      @db.Decimal(19, 4)
  estimatedCost    Decimal?     @db.Decimal(19, 4)
  actualCost       Decimal?     @db.Decimal(19, 4)
  grossProfit      Decimal?     @db.Decimal(19, 4)
  profitMargin     Decimal?     @db.Decimal(19, 4)
  startDate        DateTime?
  estimatedEndDate DateTime?
  actualEndDate    DateTime?
  currentPhase     ProjectPhase
  status           String       @default("ACTIVE")
  projectManagerId String?
  clientId         String?
  siteAddress      String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  company         Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  workspace       Workspace              @relation(fields: [workspaceId], references: [id])
  project         Project                @relation(fields: [projectId], references: [id])
  projectManager  User?                  @relation("ConstructionProjectManager", fields: [projectManagerId], references: [id])
  client          Customer?              @relation(fields: [clientId], references: [contactId])
  phases          ProjectPhaseLog[]
  changeOrders    ChangeOrder[]
  liens           Lien[]
  retentions      RetentionSchedule[]
  milestones      ProjectMilestone[]
  costCodes       ConstructionCostCode[]
  costAllocations CostCodeAllocation[]

  @@index([companyId, status])
  @@index([companyId, currentPhase])
  @@index([companyId, startDate])
  @@index([clientId])
  @@index([projectManagerId])
}

model ProjectPhaseLog {
  id          String       @id @default(uuid())
  projectId   String
  phase       ProjectPhase
  startDate   DateTime
  endDate     DateTime?
  budget      Decimal?     @db.Decimal(19, 4)
  actualCost  Decimal?     @db.Decimal(19, 4)
  status      String       @default("ACTIVE")
  completedAt DateTime?
  notes       String?      @db.Text
  createdAt   DateTime     @default(now())

  project ConstructionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, phase])
}

model ChangeOrder {
  id             String            @id @default(uuid())
  companyId      String
  projectId      String
  changeOrderNo  String
  description    String
  reason         String?
  originalScope  String?           @db.Text
  changedScope   String?           @db.Text
  amount         Decimal           @db.Decimal(19, 4)
  approvedAmount Decimal?          @db.Decimal(19, 4)
  status         ChangeOrderStatus @default(DRAFT)
  submittedDate  DateTime?
  approvedDate   DateTime?
  approvedById   String?
  impactSchedule Boolean           @default(false)
  scheduleDays   Int?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  company    Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  project    ConstructionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approvedBy User?               @relation(fields: [approvedById], references: [id])
  items      ChangeOrderItem[]

  @@unique([companyId, projectId, changeOrderNo])
  @@index([companyId, status])
  @@index([projectId, status])
  @@index([approvedById])
}

model ChangeOrderItem {
  id            String   @id @default(uuid())
  changeOrderId String
  itemType      String // LABOR, MATERIAL, EQUIPMENT, SUBCONTRACTOR
  description   String
  quantity      Decimal? @db.Decimal(16, 6)
  unit          String?
  unitCost      Decimal? @db.Decimal(19, 4)
  amount        Decimal  @db.Decimal(19, 4)
  createdAt     DateTime @default(now())

  changeOrder ChangeOrder @relation(fields: [changeOrderId], references: [id], onDelete: Cascade)

  @@index([changeOrderId])
}

model Lien {
  id              String     @id @default(uuid())
  companyId       String
  projectId       String
  lienNumber      String
  type            String // MECHANICS_LIEN, MATERIALMANS_LIEN, TAX_LIEN
  claimant        String
  amount          Decimal    @db.Decimal(19, 4)
  propertyAddress String?
  filedDate       DateTime?
  releaseDate     DateTime?
  status          LienStatus @default(PENDING)
  notes           String?    @db.Text
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  company Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  project ConstructionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([companyId, projectId, lienNumber])
  @@index([companyId, status])
  @@index([projectId, status])
}

model RetentionSchedule {
  id               String          @id @default(uuid())
  companyId        String
  projectId        String
  invoiceId        String?
  billId           String?
  retentionPercent Decimal         @db.Decimal(8, 4)
  amountWithheld   Decimal         @db.Decimal(19, 4)
  releasePercent   Decimal?        @db.Decimal(8, 4)
  releaseAmount    Decimal?        @db.Decimal(19, 4)
  dueDate          DateTime?
  releasedDate     DateTime?
  status           RetentionStatus @default(WITHHELD)
  notes            String?         @db.Text
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  company Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  project ConstructionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invoice Invoice?            @relation(fields: [invoiceId], references: [id])
  bill    Bill?               @relation(fields: [billId], references: [id])

  @@index([companyId, status])
  @@index([projectId, status])
  @@index([invoiceId])
  @@index([billId])
}

model ProjectMilestone {
  id              String    @id @default(uuid())
  companyId       String
  projectId       String
  milestoneName   String
  description     String?
  plannedDate     DateTime
  actualDate      DateTime?
  completionPct   Decimal?  @db.Decimal(8, 4)
  budgetAllocated Decimal?  @db.Decimal(19, 4)
  actualCost      Decimal?  @db.Decimal(19, 4)
  status          String    @default("PENDING")
  approvedById    String?
  approvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company    Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  project    ConstructionProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approvedBy User?               @relation(fields: [approvedById], references: [id])
  billings   ProjectBilling[]    @relation("MilestoneBillings")

  @@index([companyId, projectId])
  @@index([plannedDate])
  @@index([status])
}

model ConstructionCostCode {
  id          String   @id @default(uuid())
  companyId   String
  code        String // CSI MasterFormat or custom
  name        String
  description String?
  parentId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  company     Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  parent      ConstructionCostCode?  @relation("CostCodeHierarchy", fields: [parentId], references: [id])
  children    ConstructionCostCode[] @relation("CostCodeHierarchy")
  allocations CostCodeAllocation[]
  // Projects that reference this cost code
  projects    ConstructionProject[]

  @@unique([companyId, code])
  @@index([companyId, isActive])
  @@index([parentId])
}

model CostCodeAllocation {
  id              String   @id @default(uuid())
  companyId       String
  projectId       String
  costCodeId      String
  transactionType String // INVOICE, BILL, JOURNAL_ENTRY, TIMESHEET
  transactionId   String
  amount          Decimal  @db.Decimal(19, 4)
  quantity        Decimal? @db.Decimal(16, 6)
  unit            String?
  createdAt       DateTime @default(now())

  company  Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  project  ConstructionProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  costCode ConstructionCostCode @relation(fields: [costCodeId], references: [id], onDelete: Cascade)

  @@unique([companyId, transactionType, transactionId, costCodeId])
  @@index([companyId, projectId, costCodeId])
  @@index([transactionType, transactionId])
}

// =====================
// 1B. NON-PROFIT & GRANT MANAGEMENT
// =====================

enum GrantStatus {
  DRAFT
  SUBMITTED
  AWARDED
  ACTIVE
  COMPLETED
  CLOSED
  REJECTED
}

enum DonorTier {
  INDIVIDUAL
  CORPORATE
  FOUNDATION
  GOVERNMENT
  OTHER
}

model Grant {
  id              String      @id @default(uuid())
  companyId       String
  workspaceId     String
  grantNumber     String
  grantName       String
  funderId        String? // Link to Customer (donor)
  funderType      String?
  grantOfficer    String?
  startDate       DateTime
  endDate         DateTime
  awardAmount     Decimal     @db.Decimal(19, 4)
  spentAmount     Decimal     @default(0) @db.Decimal(19, 4)
  remainingAmount Decimal     @db.Decimal(19, 4)
  status          GrantStatus @default(DRAFT)
  reportingPeriod String? // MONTHLY, QUARTERLY, ANNUAL
  nextReportDue   DateTime?
  complianceRules Json? // JSON rules for grant compliance
  notes           String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  company   Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  workspace Workspace      @relation(fields: [workspaceId], references: [id])
  funder    Customer?      @relation(fields: [funderId], references: [contactId])
  budgets   GrantBudget[]
  expenses  GrantExpense[]
  reports   GrantReport[]

  @@unique([companyId, grantNumber])
  @@index([companyId, status])
  @@index([funderId])
  @@index([endDate])
}

model GrantBudget {
  id          String   @id @default(uuid())
  grantId     String
  category    String // SALARIES, EQUIPMENT, TRAVEL, ADMINISTRATIVE
  budgetCode  String?
  description String?
  amount      Decimal  @db.Decimal(19, 4)
  spentAmount Decimal  @default(0) @db.Decimal(19, 4)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  grant    Grant          @relation(fields: [grantId], references: [id], onDelete: Cascade)
  expenses GrantExpense[]

  @@unique([grantId, category, budgetCode])
  @@index([grantId])
}

model GrantExpense {
  id              String   @id @default(uuid())
  companyId       String
  grantId         String
  budgetId        String?
  transactionType String // INVOICE, BILL, JOURNAL_ENTRY, PAYROLL
  transactionId   String
  amount          Decimal  @db.Decimal(19, 4)
  expenseDate     DateTime
  description     String?
  isEligible      Boolean  @default(true)
  notes           String?  @db.Text
  createdAt       DateTime @default(now())

  company Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  grant   Grant        @relation(fields: [grantId], references: [id], onDelete: Cascade)
  budget  GrantBudget? @relation(fields: [budgetId], references: [id])

  @@unique([companyId, grantId, transactionType, transactionId])
  @@index([grantId, expenseDate])
  @@index([transactionType, transactionId])
}

model GrantReport {
  id             String    @id @default(uuid())
  grantId        String
  reportPeriod   String // 2024-Q1, 2024-01, etc.
  reportType     String // FINANCIAL, NARRATIVE, BOTH
  submissionDate DateTime?
  dueDate        DateTime
  status         String    @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, REJECTED
  submittedById  String?
  approvedById   String?
  approvedAt     DateTime?
  reportData     Json // JSON structure for report data
  attachmentId   String?
  notes          String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  grant       Grant       @relation(fields: [grantId], references: [id], onDelete: Cascade)
  submittedBy User?       @relation("GrantReportSubmittedBy", fields: [submittedById], references: [id])
  approvedBy  User?       @relation("GrantReportApprovedBy", fields: [approvedById], references: [id])
  attachment  Attachment? @relation(fields: [attachmentId], references: [id])

  @@unique([grantId, reportPeriod, reportType])
  @@index([grantId, dueDate])
  @@index([submittedById])
  @@index([approvedById])
}

model DonorManagement {
  id                String    @id @default(uuid())
  companyId         String
  donorId           String // Link to Customer
  donorTier         DonorTier
  givingCapacity    Decimal?  @db.Decimal(19, 4)
  firstGiftDate     DateTime?
  lastGiftDate      DateTime?
  totalGiven        Decimal   @default(0) @db.Decimal(19, 4)
  lifetimeValue     Decimal   @default(0) @db.Decimal(19, 4)
  preferredMethod   String? // CHECK, CREDIT_CARD, BANK_TRANSFER
  communicationPref Json? // JSON preferences
  notes             String?   @db.Text
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company      Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  donor        Customer           @relation(fields: [donorId], references: [contactId])
  interactions DonorInteraction[]

  @@unique([companyId, donorId])
  @@index([companyId, donorTier])
  @@index([donorId])
}

// ─── Donor Interaction Log ─────────────────────────────────────────────

model DonorInteraction {
  id                String    @id @default(uuid())
  donorManagementId String
  userId            String // who logged this interaction (plain reference, no FK)
  type              String // EMAIL, CALL, MEETING, EVENT, NOTE
  subject           String
  notes             String?   @db.Text
  occurredAt        DateTime  @default(now())
  followUpDate      DateTime?
  createdAt         DateTime  @default(now())

  donorManagement DonorManagement @relation(fields: [donorManagementId], references: [id], onDelete: Cascade)

  @@index([donorManagementId])
  @@index([occurredAt])
}

model RevenueRecognitionSchedule {
  id               String   @id @default(uuid())
  workspaceId      String
  invoiceLineId    String   @unique
  totalAmount      Decimal  @db.Decimal(19, 4)
  recognizedToDate Decimal  @default(0) @db.Decimal(19, 4)
  schedule         Json
  createdAt        DateTime @default(now())

  workspace   Workspace   @relation(fields: [workspaceId], references: [id])
  invoiceLine InvoiceLine @relation(fields: [invoiceLineId], references: [id], onDelete: Cascade)

  phases  RevenueRecognitionPhase[]
  entries RevenueRecognitionEntry[] @relation("RevRecogEntries")

  @@index([workspaceId])
  @@index([invoiceLineId])
}

// Revenue recognition phases (normalized representation of `schedule` JSON)
