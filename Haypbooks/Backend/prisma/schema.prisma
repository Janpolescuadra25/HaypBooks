// Phase 1: Authentication + OTP
// --------------------

model User {
  id               String     @id @default(uuid())
  // Unique email = login safety + implicit index for fast sign-in
  email            String     @unique
  // System-level role only (workspace roles live on WorkspaceUser)
  systemRole       SystemRole @default(USER) @map("role")
  name             String?
  password         String     @map("passwordhash")
  isEmailVerified  Boolean    @default(false) @map("isemailverified")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  // optional fields used by existing mock code
  resetToken       String?    @map("resettoken") @db.Text
  resetTokenExpiry Int?       @map("resettokenexpiry")

  sessions     Session[]
  // Preferred hub (owner vs accountant) used to route users on sign-in
  preferredHub PreferredHub?

  // Contact fields
  phone     String? @db.Text
  // HMAC of normalized phone for privacy-safe lookups
  phoneHmac String? @map("phone_hmac") @db.Text

  // Verified phone state
  isPhoneVerified Boolean   @default(false) @map("isphoneverified")
  phoneVerifiedAt DateTime? @map("phoneverifiedat")
  // Audit reviewer flag for governance workflows
  auditReviewer   Boolean   @default(false)
  // Soft-delete timestamp — null means active account
  deletedAt       DateTime?

  // === MFA Support ===
  mfaEnabled            Boolean   @default(false)
  mfaType               MfaType? // Active MFA method
  mfaSecret             String?   @db.Text // Encrypted TOTP secret
  mfaBackupCodes        String?   @db.Text // JSON array of encrypted backup codes
  mfaEnabledAt          DateTime?
  lastMfaUsedAt         DateTime?
  // === Security tracking ===
  failedLoginAttempts   Int       @default(0)
  lockedUntil           DateTime?
  passwordChangedAt     DateTime?
  requirePasswordChange Boolean   @default(false)

  // relation back to security events (optional)

  securityEvents        UserSecurityEvent[]
  ownedWorkspace        Workspace?          @relation("WorkspaceOwner")
  workspaceUsers        WorkspaceUser[]
  invitedWorkspaceUsers WorkspaceUser[]     @relation("InvitedUsers")
  sentWorkspaceInvites  WorkspaceInvite[]   @relation("WorkspaceInviteInvitedBy")
  timesheetApprovals    TimesheetApproval[]
  auditLogs             AuditLog[]
  // Tasks relations
  tasksCreated          Task[]
  createdWorkflows      Workflow[]

  // Construction project & grant relation backrefs
  constructionProjectsManaged ConstructionProject[] @relation("ConstructionProjectManager")
  approvedChangeOrders        ChangeOrder[]
  approvedMilestones          ProjectMilestone[]
  grantReportsSubmitted       GrantReport[]         @relation("GrantReportSubmittedBy")
  grantReportsApproved        GrantReport[]         @relation("GrantReportApprovedBy")
  taskComments                TaskComment[]
  aiInsightComments           AiInsightComment[]
  aiChatSessions              AiChatSession[]
  aiQueryLogs                 AiQueryLog[]
  documentApprovals           DocumentApproval[]
  pettyCashVouchersApproved   PettyCashVoucher[]
  timeOffRequestsApproved     TimeOffRequest[]
  taxCalculationAudits        TaxCalculationAudit[]
  taxPeriodLocks              TaxPeriodLock[]
  userActionAudits            UserActionAudit[]
  // Attachments uploaded by this user
  attachmentsUploaded         Attachment[]
  // Dunning and approvals
  dunningNoticesSent          DunningNotice[]

  // Auto-added opposite relations (generated)
  refundApprovals              RefundApproval[]
  risksOwned                   Risk[]
  notificationPreferences      NotificationPreference[]
  apiKeys                      ApiKey[]
  externalSystemAccessLogs     ExternalSystemAccessLog[]
  depositSlipsPrepared         DepositSlip[]                 @relation("DepositSlip_PreparedBy")
  depositSlipsLastPrinted      DepositSlip[]                 @relation("DepositSlip_LastPrintedBy")
  inventoryAdjustmentRequests  InventoryAdjustmentRequest[]
  inventoryAdjustmentApprovals InventoryAdjustmentApproval[]
  salesTaxReturnsFiled         SalesTaxReturn[]
  shortcuts                    UserShortcut[]
  timerSessions                TimerSession[]
  communicationLogs            CommunicationLog[]
  resourceAllocations          ResourceAllocation[]
  notifications                Notification[]
  dataImportJobs               DataImportJob[]

  // Audit Relations
  invoicesCreated                  Invoice[]                  @relation("Invoice_createdBy")
  invoicesUpdated                  Invoice[]                  @relation("Invoice_updatedBy")
  journalEntriesCreated            JournalEntry[]             @relation("JournalEntry_createdBy")
  journalEntriesUpdated            JournalEntry[]             @relation("JournalEntry_updatedBy")
  billsCreated                     Bill[]                     @relation("Bill_createdBy")
  billsUpdated                     Bill[]                     @relation("Bill_updatedBy")
  receivedPaymentsCreated          PaymentReceived[]          @relation("PaymentReceived_createdBy")
  receivedPaymentsUpdated          PaymentReceived[]          @relation("PaymentReceived_updatedBy")
  billPaymentsCreated              BillPayment[]              @relation("BillPayment_createdBy")
  billPaymentsUpdated              BillPayment[]              @relation("BillPayment_updatedBy")
  // Practice Hub back-relations
  practiceCalendarsCreated         PracticeCalendar[]         @relation("PracticeCalendar_createdBy")
  calendarAttendees                CalendarAttendee[]
  assignedClientRequests           ClientRequest[]            @relation("ClientRequest_assignedTo")
  clientRequestResponses           ClientRequestResponse[]
  clientRequestActivities          ClientRequestActivity[]    @relation("ClientRequestActivity_user")
  // Workflow & Journal templates
  workflowTemplatesCreated         WorkflowTemplate[]         @relation("WorkflowTemplate_createdBy")
  recurringJournalTemplatesCreated RecurringJournalTemplate[] @relation("RecurringJournalTemplate_createdBy")
  // Locale preferences
  userLocale                       UserLocale?
  // Personal preferences
  preferences                      UserPreferences?
  // Workspace settings audit trail
  localeConfigurationsUpdated      LocaleConfiguration[]      @relation("LocaleConfiguration_updatedBy")
  // Deletion audit trail
  deletionLogsTriggered            DeletionLog[]              @relation("DeletionLog_deletedBy")
  deletionsRecovered               DeletionLog[]              @relation("DeletionLog_RecoveredBy")
  // Company data retention policy setter
  companyRetentionPolicies         Company[]                  @relation("Company_RetentionPolicySetBy")
  // Workspace config audit trail
  systemConfigsUpdated             SystemConfig[]             @relation("SystemConfig_UpdatedBy")
  ApprovalRequest                  ApprovalRequest[]
  adminAuditLogs                   AdminAuditLog[]            @relation("AdminAuditLogs")
  adminNotifications               AdminNotification[]        @relation("AdminNotifications")
  adminSessions                    AdminSession[]             @relation("AdminSessions")
  adminIpWhitelists                AdminIpWhitelist[]         @relation("AdminIpWhitelists")
  adminApprovalsRequested          AdminActionApproval[]      @relation("AdminActionRequester")
  adminApprovalsReviewed           AdminActionApproval[]      @relation("AdminActionApprover")
  PracticeXpLog                    PracticeXpLog[]
  PracticeCertification            PracticeCertification[]

  @@index([phoneHmac])
  @@index([createdAt])
  @@index([email, isEmailVerified])
  @@index([phone, isPhoneVerified])
  @@index([deletedAt])
  @@index([mfaEnabled])
}

model Session {
  id           String    @id @default(uuid())
  userId       String
  refreshToken String    @unique
  ipAddress    String?   @map("ipaddress")
  userAgent    String?   @map("useragent")
  revoked      Boolean   @default(false)
  lastUsedAt   DateTime? @map("lastusedat")
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  /// Human-readable device label, e.g. "Chrome on Windows"
  deviceName      String?
  /// Why the session was revoked: LOGOUT | NEW_LOGIN | SECURITY_EVENT | EXPIRED
  revokedReason   String?
  /// Groups all refresh tokens from a single login chain — used to detect replay attacks
  tokenFamily     String?
  /// The company context the user was working in when this session was created/last used
  activeCompanyId String?

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeCompany Company? @relation("Session_ActiveCompany", fields: [activeCompanyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tokenFamily])
  @@index([userId, revoked])
}

model Otp {
  id        String     @id @default(uuid())
  email     String?    @db.VarChar(320)
  phone     String?    @db.VarChar(32)
  otpCode   String     @db.VarChar(16)
  purpose   OtpPurpose @default(RESET)
  attempts  Int        @default(0)
  createdAt DateTime   @default(now())
  expiresAt DateTime

  @@index([email])
  @@index([phone])
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  email     String   @db.VarChar(320)
  tokenHash String   @db.Text
  data      Json?
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([email])
  @@index([expiresAt])
}

enum OtpPurpose {
  RESET
  VERIFY_EMAIL
  MFA
}

model UserSecurityEvent {
  id        String   @id @default(uuid())
  userId    String?
  email     String?
  type      String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user             User?             @relation(fields: [userId], references: [id])
  approvalRequests ApprovalRequest[]

  @@index([userId])
  @@index([email])
}

model OnboardingStep {
  id         String   @id @default(uuid())
  // Exactly one of companyId or practiceId should be set (onboarding is per owner)
  companyId  String?
  practiceId String?
  step       String
  data       Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company  Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  practice Practice? @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([practiceId])
  // Enforce XOR ownership at DB layer (check constraint or trigger)
  @@index([companyId, practiceId])
}

