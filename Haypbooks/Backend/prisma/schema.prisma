}

model Revaluation {
  id          String   @id @default(uuid())
  workspaceId String
  period      String
  generatedAt DateTime @default(now())
  entries     Json

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, period])
}

