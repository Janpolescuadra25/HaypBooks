  @@index([landedCostId])
  @@index([inventoryCostLayerId])
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum PostingStatus {
  DRAFT
  REVIEWED
  APPROVED
  POSTED
  VOIDED
}

enum PeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

enum ApprovalType {
  REFUND
  WRITEOFF
}

enum PostingModule {
  JOURNAL_ENTRY
  INVOICE
  BILL
  BANK_DEPOSIT
  INVENTORY
  PAYROLL
}

model Timesheet {
  id          String          @id @default(uuid())
  workspaceId String
  employeeId  String
  weekStart   DateTime
  status      TimesheetStatus @default(DRAFT)
  notes       String?
  createdAt   DateTime        @default(now())

  entries   TimeEntry[]
  approvals TimesheetApproval[]

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  employee  Employee  @relation(fields: [employeeId], references: [id])

  @@index([workspaceId, employeeId])
}

model TimeEntry {
  id          String   @id @default(uuid())
  workspaceId String
  timesheetId String
  employeeId  String
  projectId   String?
  date        DateTime
  hours       Decimal  @db.Decimal(19, 4)
  description String?
  createdAt   DateTime @default(now())

  timesheet Timesheet @relation(fields: [timesheetId], references: [id])
  employee  Employee  @relation(fields: [employeeId], references: [id])
  project   Project?  @relation(fields: [projectId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([timesheetId])
  @@index([employeeId])
  @@index([workspaceId])
}

model TimesheetApproval {
  id          String   @id @default(uuid())
  timesheetId String
  approverId  String
  approvedAt  DateTime
  comment     String?
  createdAt   DateTime @default(now())

  timesheet   Timesheet @relation(fields: [timesheetId], references: [id])
  approver    User      @relation(fields: [approverId], references: [id])
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@index([timesheetId])
  @@index([workspaceId])
}

enum BudgetScenario {
  ACTUAL
  BUDGET
  FORECAST
  WHAT_IF
}

enum BudgetStatus {
  DRAFT
  APPROVED
  LOCKED
}

model Budget {
  id          String         @id @default(uuid())
  workspaceId String
  name        String
  scenario    BudgetScenario @default(ACTUAL)
  status      BudgetStatus   @default(DRAFT)
  fiscalYear  Int
  totalAmount Decimal?       @db.Decimal(19, 4)
  createdAt   DateTime       @default(now())

  workspace Workspace       @relation(fields: [workspaceId], references: [id])
  lines     BudgetLine[]
  // Budget versions (top-level)
  versions  BudgetVersion[]

  // Auto-added opposite relations (generated)
  comparisons BudgetActualComparison[]

  @@index([workspaceId, fiscalYear])
}

model BudgetLine {
  id          String   @id @default(uuid())
  budgetId    String
  workspaceId String
  accountId   String?
  classId     String?
  month       Int?
  amount      Decimal  @db.Decimal(19, 4)
  createdAt   DateTime @default(now())

  budget    Budget    @relation(fields: [budgetId], references: [id])
  account   Account?  @relation(fields: [accountId], references: [id])
  class     Class?    @relation(fields: [classId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([budgetId])
  @@index([accountId])
  @@index([workspaceId])
}

model BudgetVersion {
  id           String       @id @default(uuid())
  budgetId     String
  workspaceId  String
  name         String
  effectiveAt  DateTime
  status       BudgetStatus @default(DRAFT)
  createdById  String?
  approvedById String?
  createdAt    DateTime     @default(now())

  budget    Budget              @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  workspace Workspace           @relation(fields: [workspaceId], references: [id])
  lines     BudgetLineVersion[]

  @@index([workspaceId])
  @@index([budgetId])
}

model BudgetLineVersion {
  id        String   @id @default(uuid())
  versionId String
  accountId String?
  classId   String?
  month     Int?
  amount    Decimal  @db.Decimal(19, 4)
  createdAt DateTime @default(now())

  version BudgetVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  account Account?      @relation(fields: [accountId], references: [id])
  class   Class?        @relation(fields: [classId], references: [id])

  @@index([versionId])
  @@index([accountId])
}

// CurrencyRevaluation: consolidated model kept below (matching migration and current DB schema)
// (Removed duplicate definition to avoid Prisma validation conflicts)

model CurrencyRevaluationLine {
  id            String   @id @default(uuid())
  revaluationId String
  accountId     String
  debit         Decimal  @db.Decimal(19, 4)
  credit        Decimal  @db.Decimal(19, 4)
  note          String?
  createdAt     DateTime @default(now())

  revaluation CurrencyRevaluation @relation(fields: [revaluationId], references: [id], onDelete: Cascade)
  account     Account             @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([revaluationId])
  @@index([accountId])
}

model AccountingPeriod {
  id          String       @id @default(uuid())
  workspaceId String
  startDate   DateTime
  endDate     DateTime
  status      PeriodStatus
  closedAt    DateTime?
  closedBy    String?
  createdAt   DateTime     @default(now())

