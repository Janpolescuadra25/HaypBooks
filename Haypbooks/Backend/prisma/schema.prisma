// =====================================================================
// PHASE: Navigation Completeness Additions
// Bridges schema to fully support every navigation item in the app.
// =====================================================================

// ─── 1. Sales ─────────────────────────────────────────────────────────

/// Order-to-Cash workflow — created before (or instead of) a direct Invoice
model SalesOrder {
  id           String    @id @default(uuid())
  workspaceId  String
  companyId    String
  customerId   String
  orderNumber  String    @unique
  status       String    @default("DRAFT") // DRAFT | CONFIRMED | FULFILLED | CLOSED
  orderDate    DateTime  @default(now())
  shipmentDate DateTime?
  totalAmount  Decimal   @db.Decimal(19, 4)
  invoiceId    String?

  workspace Workspace        @relation(fields: [workspaceId], references: [id])
  company   Company          @relation(fields: [companyId], references: [id])
  customer  Customer         @relation(fields: [customerId], references: [contactId])
  invoice   Invoice?         @relation(fields: [invoiceId], references: [id])
  lines     SalesOrderLine[]

  @@index([companyId, status])
  @@index([workspaceId, customerId])
}

model SalesOrderLine {
  id           String  @id @default(uuid())
  salesOrderId String
  itemId       String?
  description  String
  quantity     Decimal @db.Decimal(16, 6)
  unitPrice    Decimal @db.Decimal(19, 4)
  amount       Decimal @db.Decimal(19, 4)

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  item       Item?      @relation(fields: [itemId], references: [id])

  @@index([salesOrderId])
}

/// Customer segmentation — groups multiple Customers together
model CustomerGroup {
  id          String  @id @default(uuid())
  workspaceId String
  companyId   String
  name        String
  description String?

  workspace Workspace  @relation(fields: [workspaceId], references: [id])
  company   Company    @relation(fields: [companyId], references: [id])
  customers Customer[]

  @@unique([companyId, name])
  @@index([workspaceId])
}

// ─── 2. Purchasing ────────────────────────────────────────────────────

/// Internal procurement request — precedes a PurchaseOrder
model PurchaseRequest {
  id              String    @id @default(uuid())
  workspaceId     String
  companyId       String
  requesterId     String // Employee / User submitting the request
  status          String    @default("DRAFT") // DRAFT | SUBMITTED | APPROVED | REJECTED | ORDERED
  requestDate     DateTime  @default(now())
  requiredDate    DateTime?
  totalAmount     Decimal   @db.Decimal(19, 4)
  purchaseOrderId String?

  workspace     Workspace             @relation(fields: [workspaceId], references: [id])
  company       Company               @relation(fields: [companyId], references: [id])
  purchaseOrder PurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id])
  lines         PurchaseRequestLine[]

  @@index([companyId, status])
}

model PurchaseRequestLine {
  id                 String   @id @default(uuid())
  purchaseRequestId  String
  itemId             String?
  description        String
  quantity           Decimal  @db.Decimal(16, 6)
  estimatedUnitPrice Decimal? @db.Decimal(19, 4)

  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  item            Item?           @relation(fields: [itemId], references: [id])

  @@index([purchaseRequestId])
}

// ─── 3. Inventory & Warehousing ──────────────────────────────────────

/// Shelf/aisle granularity inside a warehouse (StockLocation)
model BinLocation {
  id          String  @id @default(uuid())
  warehouseId String
  name        String // e.g., "Aisle A – Shelf 1"
  code        String?
  isActive    Boolean @default(true)

  warehouse StockLocation @relation(fields: [warehouseId], references: [id])

  @@unique([warehouseId, name])
  @@index([warehouseId])
}

/// Physical / Cycle count session
model StockCount {
  id            String   @id @default(uuid())
  workspaceId   String
  companyId     String
  warehouseId   String
  countDate     DateTime @default(now())
  status        String   @default("OPEN") // OPEN | COUNTING | REVIEWED | CLOSED
  varianceTotal Decimal? @db.Decimal(19, 4)

  warehouse StockLocation    @relation(fields: [warehouseId], references: [id])
  workspace Workspace        @relation(fields: [workspaceId], references: [id])
  company   Company          @relation(fields: [companyId], references: [id])
  lines     StockCountLine[]

  @@index([companyId, status])
}

model StockCountLine {
  id           String   @id @default(uuid())
  stockCountId String
  itemId       String
  systemQty    Decimal  @db.Decimal(16, 6)
  countedQty   Decimal? @db.Decimal(16, 6)
  variance     Decimal? @db.Decimal(19, 4)

  stockCount StockCount @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  item       Item       @relation(fields: [itemId], references: [id])

  @@index([stockCountId])
}

/// Units of Measure (Box, Kg, Pcs …)
model UnitOfMeasure {
  id           String  @id @default(uuid())
  companyId    String
  name         String // "Box", "Pcs", "Kg"
  abbreviation String // "bx", "pc", "kg"
  isActive     Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, name])
  @@index([companyId])
}

// ─── 4. HR & Recruiting ───────────────────────────────────────────────

/// Open headcount / job posting
model JobPosition {
  id          String  @id @default(uuid())
  companyId   String
  title       String
  department  String?
  headcount   Int     @default(1)
  status      String  @default("OPEN") // OPEN | CLOSED | ON_HOLD
  description String? @db.Text

  company      Company          @relation(fields: [companyId], references: [id])
  applications JobApplication[]

  @@index([companyId, status])
}

model JobApplication {
  id            String   @id @default(uuid())
  positionId    String
  applicantName String
  email         String
  resumeUrl     String?
  status        String   @default("APPLIED") // APPLIED | SCREENING | INTERVIEW | OFFERED | HIRED | REJECTED
  appliedAt     DateTime @default(now())

  position JobPosition @relation(fields: [positionId], references: [id])

  @@index([positionId, status])
}

// ─── 5. Practice Hub ─────────────────────────────────────────────────

/// Annual engagement container (e.g., "2024 Year-End Audit")
model Engagement {
  id          String    @id @default(uuid())
  practiceId  String
  companyId   String
  name        String // "2024 Year-End Audit"
  type        String // AUDIT | TAX | ADVISORY
  status      String    @default("ACTIVE") // ACTIVE | COMPLETED | ARCHIVED
  startDate   DateTime
  endDate     DateTime?
  billingType String? // FIXED | HOURLY

  practice          Practice           @relation(fields: [practiceId], references: [id])
  company           Company            @relation(fields: [companyId], references: [id])
  // Practice Hub back-relations
  practiceCalendars PracticeCalendar[]
  clientRequests    ClientRequest[]

  timeEntries EngagementTimeEntry[]
  wipLedgers  PracticeWipLedger[]
  workflows   EngagementWorkflow[]

  @@index([practiceId, status])
}

// ─── Engagement Templates & Workflows ─────────────────────────────────

model EngagementTemplate {
  id          String   @id @default(uuid())
  practiceId  String
  name        String
  type        String // AUDIT, TAX, ADVISORY, BOOKKEEPING
  description String?  @db.Text
  steps       Json // Array of default step objects [{ name, description, order }]
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  practice  Practice             @relation(fields: [practiceId], references: [id])
  workflows EngagementWorkflow[]

  @@index([practiceId, type])
  @@index([practiceId, isActive])
}

model EngagementWorkflow {
  id           String   @id @default(uuid())
  engagementId String
  templateId   String? // optional reference to a template used to seed this workflow
  steps        Json // [{ name, status, completedAt, assignedToId }]
  currentStep  Int      @default(0)
  status       String   @default("ACTIVE") // ACTIVE, COMPLETED, PAUSED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  engagement Engagement          @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  template   EngagementTemplate? @relation(fields: [templateId], references: [id])

  @@index([engagementId])
  @@index([status])
}

/// Log of calls, emails, and meetings with a client
model CommunicationLog {
  id         String   @id @default(uuid())
  practiceId String
  companyId  String
  contactId  String?
  userId     String
  type       String // EMAIL | CALL | MEETING
  subject    String
  notes      String?  @db.Text
  occurredAt DateTime @default(now())

  practice Practice @relation(fields: [practiceId], references: [id])
  company  Company  @relation(fields: [companyId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([companyId, occurredAt])
  @@index([practiceId])
}

// ─── 6. Time & Projects ───────────────────────────────────────────────

/// Live start/stop timer session — one per active user
model TimerSession {
  id          String    @id @default(uuid())
  userId      String
  workspaceId String
  projectId   String?
  startedAt   DateTime  @default(now())
  pausedAt    DateTime?
  durationSec Int       @default(0)
  isActive    Boolean   @default(true)

  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  project   Project?  @relation(fields: [projectId], references: [id])

  @@index([userId, isActive])
}

/// Resource planning — hours budgeted per person per project
model ResourceAllocation {
  id         String   @id @default(uuid())
  projectId  String
  userId     String
  hoursAlloc Decimal  @db.Decimal(19, 4)
  startDate  DateTime
  endDate    DateTime

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@index([userId])
}

// ─── 7. System & UI ───────────────────────────────────────────────────

/// User-defined quick-access shortcuts stored in the sidebar
model UserShortcut {
  id        String  @id @default(uuid())
  userId    String
  label     String
  url       String
  icon      String?
  sortOrder Int     @default(0)

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ─── 8. Last-Mile UX ──────────────────────────────────────────────────

/// In-app notification bell items (Invoice paid, Task due, etc.)
model Notification {
  id          String    @id @default(uuid())
  workspaceId String
  userId      String
  type        String // INVOICE_PAID | TASK_DUE | SYSTEM_ALERT | …
  title       String
  message     String    @db.Text
  isRead      Boolean   @default(false)
  actionUrl   String? // Deep-link, e.g. "/invoices/123"
  createdAt   DateTime  @default(now())
  readAt      DateTime?
  // Governance & priority fields
  priority    String    @default("NORMAL") // LOW | NORMAL | HIGH | URGENT
  archivedAt  DateTime?
  archivedBy  String?
  expiresAt   DateTime? // Auto-expire this notification after this timestamp
  metadata    Json? // Additional context (e.g. related entity info)

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId, isRead]) // Fast unread-count query
  @@index([workspaceId])
  @@index([priority, createdAt])
  @@index([archivedAt])
  @@index([expiresAt])
}

/// Tracks CSV / bulk-import jobs — shows progress bar & error log in UI
model DataImportJob {
  id           String    @id @default(uuid())
  workspaceId  String
  companyId    String
  userId       String
  importType   String // BANK_STATEMENT | CHART_OF_ACCOUNTS | CUSTOMERS | …
  status       String    @default("PENDING") // PENDING | PROCESSING | COMPLETED | FAILED
  fileId       String? // FK to Attachment
  rowCount     Int?
  successCount Int?
  errorCount   Int?
  errorLog     Json? // Array of per-row error messages
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  company   Company   @relation(fields: [companyId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([companyId, status])
  @@index([userId])
}

/// Allows users to attach extra fields to any entity without schema changes
model CustomFieldDefinition {
  id         String  @id @default(uuid())
  companyId  String
  name       String // "Project Phase"
  entityType String // "Invoice" | "Bill" | "Customer" | …
  fieldType  String // TEXT | NUMBER | DATE | DROPDOWN
  options    Json? // Dropdown choices: ["Phase 1", "Phase 2"]
  isRequired Boolean @default(false)
  sortOrder  Int     @default(0)

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, name, entityType])
  @@index([companyId, entityType])
}

// ═══════════════════════════════════════════════════════════════════════
// PRACTICE HUB — NEW MODELS
// Implements schema gaps identified in the Practice Hub coverage analysis
// (Practice hub.md — gaps: Calendar, Client Requests, Practice Health)
// ═══════════════════════════════════════════════════════════════════════

// ─── Practice Health Metrics ─────────────────────────────────────────

/// Snapshot of practice-level health KPIs stored daily for trend analysis
model PracticeHealthMetric {
  id         String   @id @default(uuid())
  practiceId String
  metricDate DateTime @default(now())

  // Workload
  activeTasks    Int @default(0)
  overdueTasks   Int @default(0)
  completedTasks Int @default(0)

  // Engagements
  activeEngagements Int @default(0)
  pendingReviews    Int @default(0)

  // Financial
  arBalance  Decimal? @db.Decimal(19, 4)
  apBalance  Decimal? @db.Decimal(19, 4)
  wipBalance Decimal? @db.Decimal(19, 4)

  // Efficiency / clients
  efficiencyScore Decimal? @db.Decimal(19, 4)
  activeClients   Int      @default(0)
  newClients      Int      @default(0)

  createdAt DateTime @default(now())

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@unique([practiceId, metricDate])
  @@index([practiceId, metricDate])
}

// ─── Practice Calendar ───────────────────────────────────────────────

enum PracticeCalendarEventType {
  MEETING
  DEADLINE
  REMINDER
  PERIOD_CLOSE
  ENGAGEMENT
  TAX_FILING
  OTHER
}

enum CalendarAttendeeStatus {
  PENDING
  ACCEPTED
  DECLINED
  TENTATIVE
}

/// Practice-wide calendar event (deadlines, meetings, close dates, filings)
model PracticeCalendar {
  id         String  @id @default(uuid())
  practiceId String
  companyId  String?

  title       String
  description String?
  eventType   PracticeCalendarEventType @default(OTHER)
  startAt     DateTime
  endAt       DateTime?
  isAllDay    Boolean                   @default(false)
  location    String?

  // Recurrence (iCal RRULE format)
  isRecurring    Boolean @default(false)
  recurrenceRule String?

  // External calendar integration
  externalId     String? // Google/Outlook event ID
  externalSource String? // GOOGLE | OUTLOOK

  // Optional links
  taskId       String?
  engagementId String?
  createdById  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  practice   Practice           @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  company    Company?           @relation(fields: [companyId], references: [id])
  task       Task?              @relation(fields: [taskId], references: [id])
  engagement Engagement?        @relation(fields: [engagementId], references: [id])
  createdBy  User?              @relation("PracticeCalendar_createdBy", fields: [createdById], references: [id])
  attendees  CalendarAttendee[]

  @@index([practiceId, startAt])
  @@index([companyId, startAt])
}

model CalendarAttendee {
  id             String                 @id @default(uuid())
  calendarId     String
  userId         String?
  email          String
  responseStatus CalendarAttendeeStatus @default(PENDING)

  calendar PracticeCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  user     User?            @relation(fields: [userId], references: [id])

  @@unique([calendarId, email])
  @@index([calendarId])
}

// ─── Client Requests ─────────────────────────────────────────────────

enum ClientRequestType {
  INFORMATION
  DOCUMENT
  ADJUSTMENT
  APPROVAL
  OTHER
}

enum ClientRequestPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ClientRequestStatus {
  OPEN
  IN_PROGRESS
  PENDING_CLIENT
  RESOLVED
  CLOSED
}

/// Tracks client inquiries, document requests, and information requests with SLA support
model ClientRequest {
  id         String @id @default(uuid())
  practiceId String
  companyId  String

  title       String
  description String?               @db.Text
  type        ClientRequestType     @default(OTHER)
  priority    ClientRequestPriority @default(NORMAL)
  status      ClientRequestStatus   @default(OPEN)

  // Requester info
  requesterName  String
  requesterEmail String

  // Assignment & SLA
  assignedToId    String?
  dueAt           DateTime?
  firstResponseAt DateTime?
  resolvedAt      DateTime?

  // Optional link to an engagement
  engagementId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  practice   Practice    @relation(fields: [practiceId], references: [id])
  company    Company     @relation(fields: [companyId], references: [id])
  assignedTo User?       @relation("ClientRequest_assignedTo", fields: [assignedToId], references: [id])
  engagement Engagement? @relation(fields: [engagementId], references: [id])

  responses   ClientRequestResponse[]
  attachments ClientRequestAttachment[]
  activities  ClientRequestActivity[]

  @@index([practiceId, status])
  @@index([companyId, status])
  @@index([assignedToId, status])
}

model ClientRequestResponse {
  id           String  @id @default(uuid())
  requestId    String
  userId       String?
  content      String  @db.Text
  isFromClient Boolean @default(false)

  createdAt DateTime @default(now())

  request ClientRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    User?         @relation(fields: [userId], references: [id])

  @@index([requestId])
}

model ClientRequestAttachment {
  id         String @id @default(uuid())
  requestId  String
  fileName   String
  fileSize   Int
  mimeType   String
  url        String
  uploadedBy String

  uploadedAt DateTime @default(now())

  request ClientRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

/// Activity / audit trail for a ClientRequest — status changes, assignments, notes.
model ClientRequestActivity {
  id           String   @id @default(uuid())
  requestId    String
  userId       String?
  /// Type of activity: STATUS_CHANGE, ASSIGNMENT, NOTE, ATTACHMENT, SLA_BREACH
  activityType String
  /// Human-readable description of the activity
  detail       String?
  /// Structured metadata (e.g., { from: 'OPEN', to: 'IN_PROGRESS' })
  metadata     Json?
  createdAt    DateTime @default(now())

  request ClientRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    User?         @relation("ClientRequestActivity_user", fields: [userId], references: [id])

  @@index([requestId, createdAt])
  @@index([userId])
}

// =====================
// Internationalization (i18n)
// =====================

/// Stores translated string values for any translatable entity field.
/// E.g., Item.name in EN='Chair', in TL='Silya'
model Translation {
  id          String   @id @default(uuid())
  workspaceId String
  /// Model name (e.g., 'Item', 'Account', 'Product')
  entityType  String
  entityId    String
  /// Field on the model being translated (e.g., 'name', 'description')
  field       String
  /// BCP-47 locale code: 'en', 'tl', 'ja', etc.
  locale      String
  value       String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, entityType, entityId, field, locale])
  @@index([workspaceId, entityType, locale])
  @@index([workspaceId, locale])
}

/// Per-user locale and display preferences; extends the User settings.
model UserLocale {
  id           String   @id @default(uuid())
  userId       String   @unique
  /// BCP-47 locale: 'en-PH', 'tl', etc.
  locale       String   @default("en-PH")
  timezone     String   @default("Asia/Manila")
  /// Date format preference: 'MM/DD/YYYY', 'DD/MM/YYYY', 'YYYY-MM-DD'
  dateFormat   String   @default("MM/DD/YYYY")
  /// Number format: 'en-PH' → 1,234.56 ; 'de' → 1.234,56
  numberFormat String   @default("en-PH")
  currency     String   @default("PHP")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// =====================
// Integration Marketplace
// =====================

/// Catalog of available integration connectors that workspaces can activate.
/// Separates connector metadata (global) from per-workspace ExternalSystemConfig (instance).
model IntegrationConnector {
  id           String          @id @default(uuid())
  systemType   IntegrationType @unique
  name         String // e.g., "BDO Online Banking"
  shortName    String // e.g., "BDO"
  description  String?
  logoUrl      String?
  category     String // BANKING, PAYROLL, PAYMENT, ECOMMERCE, TAX, POS
  /// JSON schema of configJson fields required for setup
  configSchema Json
  /// Documentation URL or setup guide
  docsUrl      String?
  /// Whether the connector is production-ready or in beta
  isLive       Boolean         @default(false)
  isBeta       Boolean         @default(false)
  /// Countries where this connector is available (ISO 3166-1 alpha-2)
  countries    String[]        @default(["PH"])
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([category, isLive])
  @@index([countries])
}

/// Categories for structured settings-change auditing
enum SettingsChangeCategory {
  LOCALIZATION
  CURRENCY
  FISCAL_YEAR
  TAX_DEFAULTS
  SECURITY
  DOCUMENT
  REPORTING
  AI
  OTHER
}

/// Deletion mode recorded in DeletionLog
enum DeleteType {
  SOFT // Soft-deleted via deletedAt (recoverable)
  HARD // Permanently deleted by user action
  CASCADE // Deleted as a result of a parent record deletion
  ARCHIVE // Archived before deletion (business process)
}

/// Type of field-level change recorded in AuditLogLine
enum ChangeType {
  CREATE
  UPDATE
  DELETE
  RESTORE
}

/// Method used when MFA is challenged
enum MfaType {
  TOTP // Time-based One-Time Password (authenticator app)
  SMS // SMS verification code
  EMAIL // Email verification code
  BACKUP_CODE // One-time backup recovery code
}

/// Data type of an audited field value — aids UI formatting and diff rendering
enum AuditFieldDataType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  DATE
}

// =====================
// Workspace Settings  (promoted from LocaleConfiguration — single source of truth)
// =====================

/// Comprehensive workspace-level settings: locale, tax defaults, multi-currency,
/// security, document handling, AI flags and reporting preferences.
/// Per-user overrides live in UserLocale.
model LocaleConfiguration {
  id          String @id @default(uuid())
  workspaceId String @unique

  // ── Localization ─────────────────────────────────────────────────────
  /// Primary locale for the workspace (BCP-47)
  defaultLocale   String   @default("en-PH")
  defaultTimezone String   @default("Asia/Manila")
  dateFormat      String   @default("MM/DD/YYYY")
  timeFormat      String   @default("HH:mm")
  /// Supported locales enabled for this workspace
  enabledLocales  String[] @default(["en-PH", "tl"])
  /// First day of the work week (0=Sun, 1=Mon)
  weekStartDay    Int      @default(1)

  // ── Currency & Number Formatting ─────────────────────────────────────
  defaultCurrency   String @default("PHP")
  numberFormat      String @default("en-PH")
  /// "symbol" | "code" | "name"
  currencyDisplay   String @default("symbol")
  /// "before" | "after"
  currencyPlacement String @default("before")
  decimalPlaces     Int    @default(2)
  /// HALF_UP | HALF_EVEN | CEILING | FLOOR
  roundingMode      String @default("HALF_UP")

  // ── Fiscal Calendar ───────────────────────────────────────────────────
  fiscalYearStartMonth Int @default(1) // 1=Jan … 12=Dec
  fiscalYearStartDay   Int @default(1)

  // ── Tax Defaults (Philippine-specific) ───────────────────────────────
  /// Standard VAT rate (e.g. 12.0 for 12%)
  defaultVatRate         Decimal? @db.Decimal(8, 4)
  /// Default creditable withholding tax rate
  defaultWithholdingRate Decimal? @db.Decimal(8, 4)
  /// Preferred tax agency code (e.g. "BIR")
  preferredTaxAgency     String?
  /// Enable BIR e-Filing and Payment System integration
  birEnabled             Boolean  @default(true)
  /// Enable e-invoicing / electronic invoice jurisdiction rules
  einvoicingEnabled      Boolean  @default(false)

  // ── Multi-Currency Defaults ───────────────────────────────────────────
  /// Rate source: "manual" | "bsp" | "ecb" | "openexchangerates"
  defaultExchangeSource       String  @default("manual")
  /// Automatically update exchange rates from the source
  autoUpdateRates             Boolean @default(false)
  /// GL account used for realised FX gain/loss (links to Account.id)
  realizedGainLossAccountId   String? @db.Text
  /// GL account used for unrealised FX gain/loss (links to Account.id)
  unrealizedGainLossAccountId String? @db.Text

  // ── Document & Attachment Defaults ───────────────────────────────────
  maxFileSizeMb            Int      @default(50)
  allowedFileTypes         String[] @default(["pdf", "jpg", "png", "docx", "xlsx"])
  /// Storage backend: "S3" | "local" | "google" | "azure"
  preferredStorageProvider String   @default("S3")

  // ── Security & Access Defaults ────────────────────────────────────────
  require2FA            Boolean @default(false)
  sessionTimeoutMinutes Int     @default(30)
  /// Minimum password length enforced for all workspace users
  passwordMinLength     Int     @default(12)
  /// Default role name assigned to new workspace users
  defaultUserRole       String  @default("VIEWER")

  // ── AI & Automation Flags ─────────────────────────────────────────────
  aiAutoCategorizationEnabled Boolean @default(true)
  aiAnomalyDetectionEnabled   Boolean @default(false)

  // ── Reporting Defaults ────────────────────────────────────────────────
  defaultReportCurrency   String @default("PHP")
  /// PREVIOUS_MONTH | PREVIOUS_QUARTER | PREVIOUS_YEAR | SAME_PERIOD_LAST_YEAR
  defaultComparisonPeriod String @default("PREVIOUS_MONTH")

  // ── Audit Trail ───────────────────────────────────────────────────────
  /// User id of the last person to update these settings
  updatedById    String?
  /// Structured category of the settings change (for audit filtering)
  changeCategory SettingsChangeCategory? @default(OTHER)
  /// Optional free-text reason / note for the last settings change
  changeReason   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  updatedBy User?     @relation("LocaleConfiguration_updatedBy", fields: [updatedById], references: [id])

  @@index([workspaceId])
}

// =====================================================================
// PHASE: Security & Governance additions (analysis107)
// =====================================================================

/// Workspace-scoped key-value configuration store.
/// Replaces ad-hoc JSON blobs in application code with a queryable table.
model SystemConfig {
  id          String   @id @default(uuid())
  workspaceId String
  key         String
  value       Json
  description String?
  /// Set to true when the value is stored encrypted at rest
  isEncrypted Boolean  @default(false)
  updatedById String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  updatedBy User?     @relation("SystemConfig_UpdatedBy", fields: [updatedById], references: [id])

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@map("system_config")
}

/// Tracks API/action frequency per identifier (IP or userId) to enforce rate limits.
/// Records are short-lived; expired entries are safe to prune.
model RateLimitLog {
  id           String    @id @default(uuid())
  workspaceId  String
  /// IP address or user UUID being rate-limited
  identifier   String
  /// Action being limited (e.g. "LOGIN", "EXPORT", "API_CALL")
  action       String
  attemptCount Int       @default(1)
  blockedAt    DateTime?
  /// When this rate-limit window expires (app layer sets this)
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([identifier, action])
  @@index([workspaceId, identifier])
  @@index([expiresAt])
  @@map("rate_limit_log")
}

// -----------------------------------------------------------------------------
// PHASE 4 ENHANCEMENTS: BANK RULES, INVOICE TEMPLATES, APPROVAL WORKFLOWS
// -----------------------------------------------------------------------------

model BankRule {
  id              String   @id @default(uuid())
  workspaceId     String
  name            String
  description     String?
  matchCriteria   Json // e.g. { "field": "description", "operator": "contains", "value": "STARBUCKS" }
  assignAccountId String // The account ID to auto-categorize to
  priority        Int      @default(0) // Lower number = higher priority
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace                  Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account                    Account                   @relation(fields: [assignAccountId], references: [id], onDelete: Restrict)
  ConsolidationGroupMember   ConsolidationGroupMember? @relation(fields: [consolidationGroupMemberId], references: [id])
  consolidationGroupMemberId String?

  @@index([workspaceId, isActive, priority])
}

model InvoiceTemplate {
  id           String   @id @default(uuid())
  workspaceId  String
  name         String
  fontFamily   String   @default("Inter, sans-serif")
  primaryColor String   @default("#000000")
  logoUrl      String?
  headerText   String?  @db.Text
  footerText   String?  @db.Text
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace                  Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invoices                   Invoice[]
  ConsolidationGroupMember   ConsolidationGroupMember? @relation(fields: [consolidationGroupMemberId], references: [id])
  consolidationGroupMemberId String?

  @@index([workspaceId, isDefault])
}

model ApprovalWorkflow {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  entityType  String // e.g. 'PURCHASE_ORDER', 'BILL', 'EXPENSE_CLAIM'
  steps       Json // Array of step definitions (thresholds, required roles/users)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace                  Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  approvalRequests           ApprovalRequest[]
  ConsolidationGroupMember   ConsolidationGroupMember? @relation(fields: [consolidationGroupMemberId], references: [id])
  consolidationGroupMemberId String?

  @@unique([workspaceId, entityType])
}

model ApprovalRequest {
  id               String   @id @default(uuid())
  workflowId       String
  entityId         String // The ID of the PurchaseOrder/Bill being approved
  status           String   @default("PENDING") // PENDING, APPROVED, REJECTED
  requestedById    String // The user who submitted it
  currentStepIndex Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workflow  ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  requester User             @relation(fields: [requestedById], references: [id], onDelete: Restrict)

  // Explicit relations back to potential entities requesting approval
  purchaseOrder          PurchaseOrder?        @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "fk_approval_po")
  bill                   Bill?                 @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "fk_approval_bill")
  UserSecurityEvent      UserSecurityEvent?    @relation(fields: [userSecurityEventId], references: [id])
  userSecurityEventId    String?
  AccountingValidation   AccountingValidation? @relation(fields: [accountingValidationId], references: [id])
  accountingValidationId String?

  @@index([workflowId, status])
  @@index([requestedById])
}

// -----------------------------------------------------------------------------
// PHASE 5 ENHANCEMENTS: PRACTICE MANAGEMENT (CRM, TIME & BILLING)
// -----------------------------------------------------------------------------

model PracticeRoleRate {
  id            String   @id @default(uuid())
  practiceId    String
  role          String // e.g., 'PARTNER', 'MANAGER', 'SENIOR', 'JUNIOR', 'BOOKKEEPER'
  hourlyRate    Decimal  @db.Decimal(19, 4)
  effectiveDate DateTime @default(now())
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  practice             Practice            @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  ConsolidationGroup   ConsolidationGroup? @relation(fields: [consolidationGroupId], references: [id])
  consolidationGroupId String?

  @@index([practiceId, isActive])
}

model EngagementTimeEntry {
  id                String   @id @default(uuid())
  engagementId      String
  practiceUserId    String
  date              DateTime
  hours             Decimal  @db.Decimal(19, 4)
  notes             String?  @db.Text
  isBillable        Boolean  @default(true)
  hourlyRateApplied Decimal  @db.Decimal(19, 4)
  wipStatus         String   @default("UNBILLED") // UNBILLED, BILLED, WRITTEN_OFF
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  engagement   Engagement   @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  practiceUser PracticeUser @relation(fields: [practiceUserId], references: [id], onDelete: Restrict)

  @@index([engagementId, wipStatus])
  @@index([practiceUserId, date])
}

model PracticeWipLedger {
  id             String   @id @default(uuid())
  practiceId     String
  engagementId   String
  period         String // e.g., '2026-03'
  unbilledHours  Decimal  @default(0) @db.Decimal(19, 4)
  unbilledAmount Decimal  @default(0) @db.Decimal(19, 4)
  billedAmount   Decimal  @default(0) @db.Decimal(19, 4)
  writeOffAmount Decimal  @default(0) @db.Decimal(19, 4)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  practice             Practice            @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  engagement           Engagement          @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  ConsolidationGroup   ConsolidationGroup? @relation(fields: [consolidationGroupId], references: [id])
  consolidationGroupId String?

  @@unique([engagementId, period]) // Only one summary per engagement per month
  @@index([practiceId, period])
}

model PracticeClientLead {
  id             String   @id @default(uuid())
  practiceId     String
  companyName    String
  contactName    String?
  email          String?
  phone          String?
  status         String   @default("NEW") // NEW, IN_PROGRESS, CONVERTED, LOST
  estimatedValue Decimal? @db.Decimal(19, 4)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  practice             Practice            @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  ConsolidationGroup   ConsolidationGroup? @relation(fields: [consolidationGroupId], references: [id])
  consolidationGroupId String?

  @@index([practiceId, status])
}

// -----------------------------------------------------------------------------
// PHASE 6: ADMIN DASHBOARD FOUNDATION
// -----------------------------------------------------------------------------

enum AdminActionStatus {
  SUCCESS
  FAILURE
  PENDING
}

enum AdminApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SystemRole {
  USER
  SUPPORT
  ADMIN
  SUPER_ADMIN
}

enum AdminAction {
  SUSPEND_WORKSPACE
  ACTIVATE_WORKSPACE
  UPDATE_PLAN
  RESET_USER_PASSWORD
  GRANT_ADMIN_ACCESS
  REVOKE_ADMIN_ACCESS
  MODIFY_BILLING
  EXPORT_DATA
  DELETE_DATA
  OTHER
}

enum AdminEntityType {
  WORKSPACE
  USER
  COMPANY
  PRACTICE
  SUBSCRIPTION
  BILLING_RECORD
  SYSTEM_CONFIG
}

enum PlatformMetricCategory {
  USER_GROWTH
  REVENUE
  SYSTEM_PERFORMANCE
  COMPLIANCE
  ENGAGEMENT
}

enum AdminNotificationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AdminNotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

model AdminAuditLog {
  id               String            @id @default(uuid())
  superAdminUserId String
  action           AdminAction
  entityType       AdminEntityType
  entityId         String // The ID of the affected entity
  details          Json? // Before/After state or other metadata
  ipAddress        String?
  userAgent        String?
  status           AdminActionStatus @default(SUCCESS)
  createdAt        DateTime          @default(now())

  superAdminUser User @relation("AdminAuditLogs", fields: [superAdminUserId], references: [id], onDelete: Restrict)

  @@index([superAdminUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model PlatformMetricSnapshot {
  id          String                 @id @default(uuid())
  category    PlatformMetricCategory
  metricName  String // e.g., 'total_active_workspaces'
  metricValue Decimal                @db.Decimal(19, 4)
  dimensions  Json? // e.g., { "region": "PH", "plan": "PRO" }
  recordedAt  DateTime               @default(now())

  @@index([category, metricName])
  @@index([recordedAt])
}

model AdminNotification {
  id            String                    @id @default(uuid())
  title         String
  message       String                    @db.Text
  priority      AdminNotificationPriority @default(LOW)
  status        AdminNotificationStatus   @default(UNREAD)
  assignedToId  String? // If assigned to a specific admin
  isSystemAlert Boolean                   @default(false)
  actionUrl     String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  assignedTo User? @relation("AdminNotifications", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([status, priority])
  @@index([assignedToId])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// PHASE 6: ADMIN SECURITY (SESSIONS, IP WHITELIST, APPROVALS)
// -----------------------------------------------------------------------------

model AdminSession {
  id               String   @id @default(uuid())
  superAdminUserId String
  tokenHash        String   @unique
  ipAddress        String?
  userAgent        String?
  deviceInfo       Json? // OS, Browser, etc.
  geoLocation      Json? // City, Country based on IP
  riskScore        Decimal? @db.Decimal(5, 2)
  isRevoked        Boolean  @default(false)
  expiresAt        DateTime
  lastActiveAt     DateTime @default(now())
  createdAt        DateTime @default(now())

  superAdmin User @relation("AdminSessions", fields: [superAdminUserId], references: [id], onDelete: Cascade)

  @@index([superAdminUserId])
  @@index([tokenHash])
}

model AdminIpWhitelist {
  id               String   @id @default(uuid())
  superAdminUserId String
  ipAddress        String // e.g., '203.0.113.45' or CIDR '203.0.113.0/24'
  description      String? // 'Founder Home WiFi', 'Office Network'
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  superAdmin User @relation("AdminIpWhitelists", fields: [superAdminUserId], references: [id], onDelete: Cascade)

  @@index([superAdminUserId, isActive])
  @@index([ipAddress])
}

model AdminActionApproval {
  id               String              @id @default(uuid())
  requesterId      String
  actionType       AdminAction
  targetEntityType AdminEntityType
  targetEntityId   String
  proposedChanges  Json? // Payload of what the admin wants to do
  status           AdminApprovalStatus @default(PENDING)

  approverId  String? // The second Super Admin who approved/rejected it
  reviewNotes String?   @db.Text
  reviewedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requester User  @relation("AdminActionRequester", fields: [requesterId], references: [id], onDelete: Restrict)
  approver  User? @relation("AdminActionApprover", fields: [approverId], references: [id], onDelete: SetNull)

  @@index([status, actionType])
  @@index([requesterId])
  @@index([approverId])
}

// --------------------
// Practice Hub Gamification Models
// --------------------

model PracticeUnlockedTool {
  id          String              @id @default(uuid())
  workspaceId String
  tool        PracticePremiumTool
  unlockedAt  DateTime            @default(now())
  unlockedVia ToolUnlockMethod
  expiresAt   DateTime? // Null if permanently unlocked (e.g., via active subscription)
  isActive    Boolean             @default(true) // Can be toggled false if they lose the XP/Subscription

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  Company   Company?  @relation(fields: [companyId], references: [id])
  companyId String?

  @@unique([workspaceId, tool]) // A practice can only have one active record per tool
  @@index([workspaceId])
}

model PracticeXpLog {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String // The specific accountant who earned the XP
  action      String // e.g., "Complete reconciliation"
  xpAmount    Int // Positive for earning, negative for decay/penalties
  description String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Company   Company?  @relation(fields: [companyId], references: [id])
  companyId String?

  @@index([workspaceId])
  @@index([userId])
}

model PracticeCertification {
  id             String              @id @default(uuid())
  workspaceId    String // The practice that holds the certification
  userId         String // The specific user who passed the exam
  level          CertificationLevel // e.g., LEVEL_1_CORE
  status         CertificationStatus @default(NOT_STARTED)
  score          Float? // Examination score (e.g., 85.5)
  attempts       Int                 @default(0)
  issuedAt       DateTime?
  expiresAt      DateTime? // Certifications usually expire after 1-2 years
  certificateUrl String? // Link to the generated PDF certificate

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Company   Company?  @relation(fields: [companyId], references: [id])
  companyId String?

  @@unique([userId, level]) // A user can only have one active/historical certification record per level
  @@index([workspaceId])
  @@index([userId])
}

// ─── Practice Dashboard & Client Portal Settings ───────────────────────

/// Per-user customizable dashboard layout for a practice
model PracticeDashboard {
  id         String   @id @default(uuid())
  practiceId String
  userId     String // plain reference — which user owns this config (no FK constraint)
  name       String   @default("My Dashboard")
  layout     Json? // widget grid positions [{ i, x, y, w, h }]
  widgets    Json? // [{ type, settings, isVisible }]
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id])

  @@index([practiceId])
  @@index([practiceId, userId])
}

/// Configuration for the client-facing portal exposed by a practice
model ClientPortalSettings {
  id              String   @id @default(uuid())
  practiceId      String   @unique
  isEnabled       Boolean  @default(false)
  allowedFeatures Json? // e.g. ["view_invoices", "upload_documents", "send_messages"]
  branding        Json? // { logoUrl, primaryColor, companyName, customDomain }
  welcomeMessage  String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id])
}
// ─── Email Templates ──────────────────────────────────────────────────────────
// Saved email templates per company for use in invoice/quote send flows.

model EmailTemplate {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  subject     String
  body        String   @db.Text
  tone        String   @default("professional") // professional | friendly | brief | custom
  cc          String?  @db.Text                 // comma-separated CC addresses
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, isDefault])
  @@map("email_templates")
}