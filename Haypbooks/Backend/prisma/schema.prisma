model AccountType {
  id         Int              @id @default(autoincrement())
  name       String
  category   AccountCategory?
  normalSide NormalSide       @default(DEBIT) // Normal balance side for this account type
  accounts   Account[]
}

model AccountSegment {
  id        String @id @default(uuid())
  companyId String

  segmentName  String // e.g., "Fund", "Department", "Project", "Location"
  segmentValue String // e.g., "100 - General Fund"

  // Link to core account if this is a sub-account structure
  parentAccountId String?
  parentAccount   Account? @relation(fields: [parentAccountId], references: [id])

  // For Fund Accounting
  fundId String?
  fund   Fund?   @relation(fields: [fundId], references: [id])

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, segmentName, segmentValue])
}

model Account {
  id                 String      @id @default(uuid())
  companyId          String
  code               String
  name               String
  typeId             Int
  parentId           String?
  currency           String      @default("USD")
  isActive           Boolean     @default(true)
  isSystem           Boolean     @default(false)
  isFromTemplate     Boolean     @default(false)
  cashFlowType       String? // OPERATING, INVESTING, FINANCING
  cashFlowCategoryId String?
  normalSide         NormalSide? // optional override of the AccountType normalSide
  balance            Decimal     @default(0) @db.Decimal(19, 4)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  company                         Company                    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  type                            AccountType                @relation(fields: [typeId], references: [id], onDelete: Restrict)
  cashFlowCategory                CashFlowCategory?          @relation(fields: [cashFlowCategoryId], references: [id])
  children                        Account[]                  @relation("acct_children")
  parent                          Account?                   @relation("acct_children", fields: [parentId], references: [id], onDelete: SetNull)
  journalLines                    JournalEntryLine[]
  AccountSubType                  AccountSubType?            @relation(fields: [accountSubTypeId], references: [id])
  accountSubTypeId                Int?
  OpeningBalance                  OpeningBalance[]
  TaxCodeAccount                  TaxCodeAccount[]
  BillLine                        BillLine[]
  VendorCreditLine                VendorCreditLine[]
  BudgetLine                      BudgetLine[]
  CustomerCreditLine              CustomerCreditLine[]
  fixedAssetAsAssetAccount        FixedAsset[]               @relation("FixedAsset_assetAccount")
  fixedAssetAsAccumAccount        FixedAsset[]               @relation("FixedAsset_accumAccount")
  fixedAssetAsDepreciationExpense FixedAsset[]               @relation("FixedAsset_depreciationExpense")
  // Auto-added opposite relations (generated)
  depreciationAccounts            DepreciationAccount[]      @relation("DepreciationAccount_expense")
  depreciationAccounts1           DepreciationAccount[]      @relation("DepreciationAccount_accum")
  accountBalanceAudits            AccountBalanceAudit[]
  currencyRevaluationEntries      CurrencyRevaluationEntry[]
  yearEndCloses                   YearEndClose[]             @relation("YearEndClose_RE")
  yearEndCloses1                  YearEndClose[]             @relation("YearEndClose_IS")
  equityAccounts                  EquityAccount[]
  // Settings
  settings                        AccountSettings?
  payrollTaxLiabilities           PayrollTaxLiability[]
  accrualSchedules                AccrualSchedule[]          @relation("AccrualSchedule_Account")
  accrualSchedules1               AccrualSchedule[]          @relation("AccrualSchedule_OffsetAccount")
  accountSegments                 AccountSegment[]
  items                           Item[]                     @relation("Item_cogsAccount")
  items1                          Item[]                     @relation("Item_inventoryReserve")
  payrollAccruals                 PayrollAccrual[]
  productionRuns                  ProductionRun[]
  deferredTaxs                    DeferredTax[]
  withholdingTaxDeductions        WithholdingTaxDeduction[]  @relation("WithholdingTax_Account")
  // Explicit opposites for versioning/lines
  budgetLineVersions              BudgetLineVersion[]
  currencyRevaluationLines        CurrencyRevaluationLine[]
  finalTaxDeductions              FinalTaxDeduction[]        @relation("FinalTax_Account")
  percentageTaxs                  PercentageTax[]            @relation("PercentageTax_Account")
  philippinePayrollDeductions     PayrollDeduction[]         @relation("PayrollDeduction_Account")
  defaultAccountMappings          DefaultAccountMapping[]
  expenseClaimLines               ExpenseClaimLine[]
  expenseSubCategoryConfigs       ExpenseSubCategoryConfig[] @relation("ExpenseSubCategoryConfig_account")
  cashOverShortEntries            CashOverShortEntry[]
  cashOverShortRules              CashOverShortRule[]
  pettyCashFunds                  PettyCashFund[]
  pettyCashVouchers               PettyCashVoucher[]
  writeOffs                       WriteOff[]
  subsidiaryLedgers               SubsidiaryLedger[]
  budgetActualComparisons         BudgetActualComparison[]

  // ── Classification enhancements (report Sprint 2-3) ──────────────────
  /// Liquidity classification for automated balance sheet current/non-current grouping
  liquidityType    LiquidityType?      @default(CURRENT)
  /// Identifies special account behaviour (contra, control, suspense, etc.)
  specialType      AccountSpecialType? @default(NONE)
  /// Header accounts are grouping/totals only — no direct journal postings
  isHeader         Boolean             @default(false)
  /// Soft-disable for new entries while keeping history intact
  isActiveForEntry Boolean             @default(true)

  /// Soft-delete timestamp — null means the record is active
  deletedAt DateTime?
  /// User id who soft-deleted this account
  deletedBy String?
  BankRule  BankRule[]

  @@unique([companyId, code])
  @@index([companyId, name])
  @@index([companyId, deletedAt])
}

model JournalEntry {
  id            String        @id @default(uuid())
  workspaceId   String
  companyId     String
  entryNumber   String?       @unique
  date          DateTime
  description   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  createdById   String?
  updatedById   String?
  createdBy     User?         @relation("JournalEntry_createdBy", fields: [createdById], references: [id])
  updatedBy     User?         @relation("JournalEntry_updatedBy", fields: [updatedById], references: [id])
  postingStatus PostingStatus @default(DRAFT)
  currency      String?
  exchangeRate  Decimal?      @db.Decimal(18, 12)
  baseTotal     Decimal?      @db.Decimal(19, 4)
  deletedAt     DateTime?
  /// Monotonically increasing version counter for optimistic concurrency
  version       Int           @default(1)
  /// References the immediately preceding version of this entry
  previousId    String?

  // Approval / review workflow (tightly scoped; optional)
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNotes   String?
  approvedById  String?
  approvedAt    DateTime?
  approvalNotes String?

  workspace             Workspace              @relation(fields: [workspaceId], references: [id])
  lines                 JournalEntryLine[]
  company               Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  invoices              Invoice[]              @relation("JournalEntry_Invoices")
  bills                 Bill[]                 @relation("JournalEntry_Bills")
  paymentsReceived      PaymentReceived[]      @relation("JournalEntry_PaymentsReceived")
  billPayments          BillPayment[]          @relation("JournalEntry_BillPayments")
  inventoryTransactions InventoryTransaction[] @relation("JournalEntry_InventoryTransactions")
  revenueSchedules      RevenueSchedule[]      @relation("JournalEntry_RevenueSchedules")
  bankDeposits          BankDeposit[]          @relation("JournalEntry_BankDeposits")
  customerRefunds       CustomerRefund[]       @relation("JournalEntry_CustomerRefunds")
  vendorRefunds         VendorRefund[]         @relation("JournalEntry_VendorRefunds")
  writeOffs             WriteOff[]             @relation("JournalEntry_WriteOffs")

  // Auto-added opposite relations (generated)
  intercompanyFromTransactions IntercompanyTransaction[] @relation("IntercompanyFromJE")
  intercompanyToTransactions   IntercompanyTransaction[] @relation("IntercompanyToJE")
  consolidationEntries         ConsolidationEntry[]
  depreciationJournals         DepreciationJournal[]
  currencyRevaluations         CurrencyRevaluation[]
  closingEntries               ClosingEntry[]
  yearEndCloses                YearEndClose[]
  dividends                    Dividend[]
  payrollTaxPayments           PayrollTaxPayment[]
  accrualEntries               AccrualEntry[]
  payrollAccruals              PayrollAccrual[]
  cOGSRecognitions             COGSRecognition[]
  // Added relations for revenue recognition phases and variance journals
  revenueRecognitionPhases     RevenueRecognitionPhase[]
  varianceJournals             VarianceJournal[]
  productionRuns               ProductionRun[]
  form2307s                    Form2307[]
  creditNotes                  CreditNote[]
  debitNotes                   DebitNote[]
  /// Version chain: each entry may point to its predecessor
  previousVersion              JournalEntry?             @relation("JournalVersion", fields: [previousId], references: [id])
  nextVersions                 JournalEntry[]            @relation("JournalVersion")

  @@index([workspaceId, date])
  @@index([companyId, date])
  @@index([companyId, postingStatus])
  @@index([companyId, postingStatus, date])
  @@index([deletedAt])
  @@index([companyId, date, postingStatus, deletedAt])
  @@index([createdById])
  @@index([updatedById])
  @@index([reviewedById])
  @@index([approvedById])
  @@index([version])
  @@index([previousId])
}

model JournalEntryLine {
  id           String  @id @default(uuid())
  journalId    String
  companyId    String
  accountId    String
  debit        Decimal @default(0) @db.Decimal(19, 4)
  credit       Decimal @default(0) @db.Decimal(19, 4)
  description  String?
  workspaceId  String
  costCenterId String? // optional link to cost center for job-costing

  journal    JournalEntry @relation(fields: [journalId], references: [id])
  account    Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)
  workspace  Workspace    @relation(fields: [workspaceId], references: [id])
  company    Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  classId    String?
  class      Class?       @relation(fields: [classId], references: [id])
  locationId String?
  location   Location?    @relation(fields: [locationId], references: [id])

  // Relations
  bankReconciliationLines BankReconciliationLine[]
  projectId               String?
  project                 Project?                 @relation(fields: [projectId], references: [id])

  @@index([journalId])
  @@index([workspaceId])
  @@index([workspaceId, accountId])
  @@index([workspaceId, accountId, journalId])
  @@index([companyId, accountId, journalId])
  @@index([companyId, accountId])
}

model Contact {
  id          String    @id @default(uuid())
  workspaceId String
  type        String
  displayName String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  /// Soft-delete timestamp — null means the contact is active
  deletedAt   DateTime?
  /// User id who soft-deleted this contact
  deletedBy   String?

  workspace     Workspace      @relation(fields: [workspaceId], references: [id])
  customer      Customer?
  vendor        Vendor?
  contactEmails ContactEmail[]
  contactPhones ContactPhone[]

  @@index([workspaceId, id])
  @@index([workspaceId, deletedAt])
}

model ContactEmail {
  id        String   @id @default(uuid())
  contactId String
  email     String   @db.VarChar(320)
  type      String   @default("WORK")
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id])

  @@unique([contactId, email])
  @@index([contactId])
}

model ContactPhone {
  id        String   @id @default(uuid())
  contactId String
  phone     String
  type      String   @default("WORK")
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id])

  @@index([contactId])
}

model Customer {
  contactId     String       @id
  workspaceId   String
  // terms            String? -- Deprecated, use paymentTermId
  paymentTermId String?
  paymentTerm   PaymentTerm? @relation(fields: [paymentTermId], references: [id])
  priceListId   String?
  priceList     PriceList?   @relation(fields: [priceListId], references: [id])

  creditLimit      Decimal?           @db.Decimal(19, 4)
  groupId          String?
  /// Soft-delete — null means active; set to mark as deleted without removing data
  deletedAt        DateTime?
  contact          Contact            @relation(fields: [contactId], references: [id])
  group            CustomerGroup?     @relation(fields: [groupId], references: [id])
  Invoice          Invoice[]
  salesOrders      SalesOrder[]
  PaymentReceived  PaymentReceived[]
  RecurringInvoice RecurringInvoice[]
  CustomerCredit   CustomerCredit[]

  workspace                  Workspace             @relation(fields: [workspaceId], references: [id])
  // Auto-added opposite relations (generated)
  donations                  Donation[]
  fundedGrants               Grant[]
  donorManagements           DonorManagement[]
  // Client/donor relations
  clientConstructionProjects ConstructionProject[]
  pledges                    Pledge[]
  leases                     Lease[]
  loyaltyAccounts            LoyaltyAccount[]
  quotes                     Quote[]
  creditNotes                CreditNote[]
  dunningNotices             DunningNotice[]
  customerStatements         CustomerStatement[]
  customerRefunds            CustomerRefund[]

  @@index([workspaceId])
  @@index([workspaceId, deletedAt])
}

model Vendor {
  contactId   String @id
  workspaceId String

  paymentTermId String?
  paymentTerm   PaymentTerm? @relation(fields: [paymentTermId], references: [id])

  contact             Contact                   @relation(fields: [contactId], references: [id])
  Bill                Bill[]
  PurchaseOrder       PurchaseOrder[]
  VendorCredit        VendorCredit[]
  VendorPaymentMethod VendorPaymentMethod[]
  // Philippine-specific withholding tax relations
  withholdingTaxes    WithholdingTaxDeduction[]
  finalTaxes          FinalTaxDeduction[]

  // New vendor flags
  isNonResident      Boolean   @default(false)
  defaultWithholding Decimal?  @db.Decimal(19, 4)
  /// Soft-delete — null means active
  deletedAt          DateTime?

  workspace                  Workspace                   @relation(fields: [workspaceId], references: [id])
  // Auto-added opposite relations (generated)
  contractors                Contractor[]
  contractorPayments         ContractorPayment[]
  withholdingTaxCertificates WithholdingTaxCertificate[]
  form2307s                  Form2307[]
  debitNotes                 DebitNote[]
  vendorRefunds              VendorRefund[]

  @@index([workspaceId])
  @@index([workspaceId, deletedAt])
}

// --------------------
// Contractors & 1099 (US)
// --------------------

model Contractor {
  id          String   @id @default(uuid())
  workspaceId String
  companyId   String
  vendorId    String
  taxId       String?  @db.VarChar(50)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  workspace Workspace           @relation(fields: [workspaceId], references: [id])
  company   Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  vendor    Vendor              @relation(fields: [vendorId], references: [contactId])
  payments  ContractorPayment[]
  forms     Form1099[]

  @@unique([companyId, vendorId])
  @@index([workspaceId])
}

model ContractorPayment {
  id              String   @id @default(uuid())
  workspaceId     String
  companyId       String
  contractorId    String
  vendorId        String
  billPaymentId   String?
  paymentDate     DateTime
  amount          Decimal  @db.Decimal(19, 4)
  taxYear         Int
  method          String?
  referenceNumber String?
  createdAt       DateTime @default(now())

  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  contractor  Contractor   @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  vendor      Vendor       @relation(fields: [vendorId], references: [contactId])
  billPayment BillPayment? @relation(fields: [billPaymentId], references: [id])

  @@index([companyId, paymentDate])
  @@index([contractorId, taxYear])
  @@index([vendorId])
}

model Form1099 {
  id           String         @id @default(uuid())
  workspaceId  String
  companyId    String
  contractorId String
  taxYear      Int
  formType     String         @default("1099-NEC") // 1099-NEC, 1099-MISC
  status       Form1099Status @default(DRAFT) // DRAFT, FILED, VOID
  filedAt      DateTime?
  totalAmount  Decimal        @db.Decimal(19, 4)
  createdAt    DateTime       @default(now())

  workspace  Workspace     @relation(fields: [workspaceId], references: [id])
  company    Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  contractor Contractor    @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  boxes      Form1099Box[]

  @@unique([companyId, contractorId, taxYear, formType])
  @@index([workspaceId, taxYear])
}

model Form1099Box {
  id        String  @id @default(uuid())
  formId    String
  boxNumber String // e.g., "1", "4", "7"
  amount    Decimal @db.Decimal(19, 4)

  form Form1099 @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([formId, boxNumber])
}

model Item {
  id                 String   @id @default(uuid())
  companyId          String
  sku                String?
  name               String
  type               String
  salesPrice         Decimal? @db.Decimal(19, 4) // Base sales price
  purchaseCost       Decimal? @db.Decimal(19, 4) // Base purchase cost
  standardCost       Decimal? @db.Decimal(19, 4) // Standard cost for variance analysis
  discountAllowed    Boolean  @default(true)
  maxDiscountPercent Decimal? @db.Decimal(8, 4)

  trackingType              String?                    @default("NONE") // NONE, SERIAL, LOT
  createdAt                 DateTime                   @default(now())
  inventoryAssetAccountId   String?
  cogsAccountId             String?
  inventoryReserveAccountId String?
  costMethod                String?                    @default("FIFO")
  InvoiceLine               InvoiceLine[]
  BillLine                  BillLine[]
  PurchaseOrderLine         PurchaseOrderLine[]
  stockLevels               StockLevel[]
  inventoryLines            InventoryTransactionLine[]
  costLayers                InventoryCostLayer[]
  priceListItems            PriceListItem[]
  // Assembly relations
  assemblyBuilds            AssemblyBuild[]            @relation("ItemBuilt")

  // Auto-added opposite relations (generated)
  quoteLines              QuoteLine[]
  assemblyComponents      AssemblyComponent[] @relation("ItemComponent")
  cogsAccount             Account?            @relation("Item_cogsAccount", fields: [cogsAccountId], references: [id])
  inventoryReserveAccount Account?            @relation("Item_inventoryReserve", fields: [inventoryReserveAccountId], references: [id])
  company                 Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  // Auto-added opposite relations (generated)
  inventoryReserves       InventoryReserve[]
  cOGSRecognitions        COGSRecognition[]
  productionRuns          ProductionRun[]

  // Standard costing
  standardCostVersions StandardCostVersion[]
  // Navigation-completeness additions
  salesOrderLines      SalesOrderLine[]
  purchaseRequestLines PurchaseRequestLine[]
  stockCountLines      StockCountLine[]

  /// Soft-delete timestamp — null means the item is active
  deletedAt DateTime?
  /// User id who soft-deleted this item
  deletedBy String?

  @@index([companyId])
  @@index([companyId, deletedAt])
}

model PriceList {
  id          String  @id @default(uuid())
  workspaceId String
  name        String // e.g., "Wholesale", "Retail"
  currency    String
  isDefault   Boolean @default(false)

  workspace Workspace        @relation(fields: [workspaceId], references: [id])
  items     PriceListItem[]
  entries   PriceListEntry[] @relation("PriceListEntries")
  customers Customer[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model PriceListItem {
  id          String  @id @default(uuid())
  priceListId String
  itemId      String
  price       Decimal @db.Decimal(19, 4)

  priceList PriceList @relation(fields: [priceListId], references: [id])
  item      Item      @relation(fields: [itemId], references: [id])

  @@unique([priceListId, itemId])
}

model InventoryCostLayer {
  id                String   @id @default(uuid())
  companyId         String
  itemId            String
  inventoryTxLineId String? // link back to the transaction line that created this layer
  quantity          Decimal  @db.Decimal(16, 6)
  remainingQty      Decimal  @db.Decimal(16, 6)
  unitCost          Decimal  @db.Decimal(19, 4)
  createdAt         DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id])

  // Landed cost lines allocated to this cost layer
  landedCostLines LandedCostLine[]
  txLine          InventoryTransactionLine? @relation("tx_line_costlayers", fields: [inventoryTxLineId], references: [id])
  company         Company                   @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId, itemId])
}

model StockLocation {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  stockLevels      StockLevel[]
  transactionLines InventoryTransactionLine[]
  binLocations     BinLocation[]
  stockCounts      StockCount[]
  company          Company                    @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId, name])
}

// --------------------
// Payroll (Phase 1 MVP - US)
// --------------------

model Employee {
  id              String    @id @default(uuid())
  companyId       String
  contactId       String? // optional link to Contact
  employeeNumber  String?
  firstName       String
  lastName        String
  taxId           String?
  ssnHash         String?   @db.Text
  hireDate        DateTime?
  terminationDate DateTime?
  payRate         Decimal?  @db.Decimal(8, 4) // default hourly/salary rate
  payType         String? // SALARY | HOURLY
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  managerId       String? // Self-relation for Org Chart
  /// Soft-delete timestamp — null means the employee is active
  deletedAt       DateTime?
  /// User id who soft-deleted this employee record
  deletedBy       String?

  company                        Company                         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  manager                        Employee?                       @relation("EmployeeManager", fields: [managerId], references: [id])
  directReports                  Employee[]                      @relation("EmployeeManager")
  // back-references for payroll relations
  payrollRunEmployees            PayrollRunEmployee[]
  paychecks                      Paycheck[]
  // Time tracking back-relations
  timesheets                     Timesheet[]
  timeEntries                    TimeEntry[]
  taxInfo                        EmployeeTaxInfo?
  i9Form                         FormI9?
  // Philippine-specific deductions
  payrollDeductions              PayrollDeduction[]
  employeeLoans                  EmployeeLoan[]
  loanPayments                   EmployeeLoanPayment[]
  timeOffBalances                TimeOffBalance[]
  timeOffRequests                TimeOffRequest[]
  thirteenthMonthPays            ThirteenthMonthPay[]
  governmentContributionPayments GovernmentContributionPayment[]
  // Auto-added opposite relations (generated)
  payrollAccruals                PayrollAccrual[]
  expenseClaims                  ExpenseClaim[]
  pettyCashFunds                 PettyCashFund[]

  @@unique([companyId, employeeNumber])
  @@unique([companyId, taxId])
  @@unique([companyId, ssnHash])
  @@index([companyId])
  @@index([companyId, deletedAt])
}

model PaySchedule {
  id        String           @id @default(uuid())
  companyId String
  name      String
  frequency PayrollFrequency
  createdAt DateTime         @default(now())

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  payrollRuns PayrollRun[]

  @@index([companyId])
}

model PayrollRun {
  id            String           @id @default(uuid())
  companyId     String
  payScheduleId String?
  startDate     DateTime
  endDate       DateTime
  status        PayrollRunStatus @default(DRAFT) // DRAFT | SUBMITTED | POSTED | VOID
  createdAt     DateTime         @default(now())
  submittedAt   DateTime?
  deletedAt     DateTime?

  company       Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  paySchedule   PaySchedule?         @relation(fields: [payScheduleId], references: [id])
  employees     PayrollRunEmployee[]
  paychecks     Paycheck[]
  postingStatus PostingStatus        @default(DRAFT)

  @@unique([companyId, startDate, endDate])
  @@index([companyId, status])
  @@index([deletedAt])
}

model PayrollRunEmployee {
  id           String   @id @default(uuid())
  companyId    String
  payrollRunId String
  employeeId   String
  grossAmount  Decimal  @db.Decimal(19, 4)
  netAmount    Decimal  @db.Decimal(19, 4)
  createdAt    DateTime @default(now())

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id])
  employee   Employee   @relation(fields: [employeeId], references: [id])

  @@index([companyId])
  @@index([employeeId])
}

model Paycheck {
  id           String    @id @default(uuid())
  companyId    String
  payrollRunId String?
  taxInfoId    String?
  i9FormId     String?
  employeeId   String
  checkNumber  String?
  date         DateTime
  grossAmount  Decimal   @db.Decimal(19, 4)
  netAmount    Decimal   @db.Decimal(19, 4)
  createdAt    DateTime  @default(now())
  postedAt     DateTime?
  deletedAt    DateTime?
  templateId   String?

  company    Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  taxInfo    EmployeeTaxInfo?  @relation(fields: [taxInfoId], references: [id], map: "Paycheck_taxInfo_fkey")
  i9Form     FormI9?           @relation(fields: [i9FormId], references: [id], map: "Paycheck_i9Form_fkey")
  payrollRun PayrollRun?       @relation(fields: [payrollRunId], references: [id])
  employee   Employee          @relation(fields: [employeeId], references: [id])
  template   DocumentTemplate? @relation(fields: [templateId], references: [id])

  paycheckLines PaycheckLine[]
  paycheckTaxes PaycheckTax[]
  expenseClaims ExpenseClaim[]

  @@index([companyId, employeeId])
  @@index([companyId, templateId])
  @@index([deletedAt])
}

// (Payroll reverse relations are defined on the original Employee model)

model PaycheckLine {
  id          String  @id @default(uuid())
  paycheckId  String
  lineType    String // EARNING, DEDUCTION, TAX
  description String?
  amount      Decimal @db.Decimal(19, 4)
  companyId   String

  paycheck Paycheck @relation(fields: [paycheckId], references: [id])
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([paycheckId])
  @@index([companyId])
}

model PaycheckTax {
  id         String   @id @default(uuid())
  paycheckId String
  companyId  String
  amount     Decimal  @db.Decimal(19, 4)
  createdAt  DateTime @default(now())

  paycheck Paycheck @relation(fields: [paycheckId], references: [id])
  company  Company  @relation(fields: [companyId], references: [id])

  @@index([paycheckId])
  @@index([companyId])
}

model EmployeeLoan {
  id              String    @id @default(uuid())
  companyId       String
  employeeId      String
  loanNumber      String
  principalAmount Decimal   @db.Decimal(19, 4)
  interestRate    Decimal?  @db.Decimal(8, 4)
  startDate       DateTime
  endDate         DateTime?
  balance         Decimal   @db.Decimal(19, 4)
  status          String    @default("ACTIVE") // ACTIVE, CLOSED, DEFAULTED
  createdAt       DateTime  @default(now())

  company    Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee   Employee                @relation(fields: [employeeId], references: [id])
  payments   EmployeeLoanPayment[]
  repayments EmployeeLoanRepayment[] @relation("LoanRepayments")

  @@unique([companyId, loanNumber])
  @@index([companyId, status])
  @@index([employeeId])
}

model EmployeeLoanPayment {
  id              String   @id @default(uuid())
  companyId       String
  employeeId      String
  loanId          String
  paymentDate     DateTime
  amount          Decimal  @db.Decimal(19, 4)
  interestAmount  Decimal? @db.Decimal(19, 4)
  principalAmount Decimal? @db.Decimal(19, 4)
  createdAt       DateTime @default(now())

  company  Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee Employee     @relation(fields: [employeeId], references: [id])
  loan     EmployeeLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([companyId, employeeId, paymentDate])
  @@index([loanId])
}

model TimeOffBalance {
  id          String      @id @default(uuid())
  companyId   String
  employeeId  String
  timeOffType TimeOffType
  balance     Decimal     @db.Decimal(19, 4)
  accrualRate Decimal?    @db.Decimal(8, 4)
  updatedAt   DateTime    @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([companyId, employeeId, timeOffType])
  @@index([companyId, employeeId])
}

model TimeOffRequest {
  id          String               @id @default(uuid())
  companyId   String
  employeeId  String
  timeOffType TimeOffType
  startDate   DateTime
  endDate     DateTime
  hours       Decimal?             @db.Decimal(19, 4)
  status      TimeOffRequestStatus @default(PENDING)
  requestedAt DateTime             @default(now())
  approvedAt  DateTime?
  approverId  String?

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee Employee @relation(fields: [employeeId], references: [id])
  approver User?    @relation(fields: [approverId], references: [id])

  @@index([companyId, status])
  @@index([employeeId, status])
  @@index([approverId])
}

model ThirteenthMonthPay {
  id         String    @id @default(uuid())
  companyId  String
  employeeId String
  taxYear    Int
  amount     Decimal   @db.Decimal(19, 4)
  releasedAt DateTime?
  createdAt  DateTime  @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([companyId, employeeId, taxYear])
  @@index([companyId, taxYear])
}

model GovernmentContributionPayment {
  id               String                     @id @default(uuid())
  companyId        String
  employeeId       String?
  contributionType GovernmentContributionType
  period           String
  amount           Decimal                    @db.Decimal(19, 4)
  paidAt           DateTime?
  referenceNumber  String?
  createdAt        DateTime                   @default(now())

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee Employee? @relation(fields: [employeeId], references: [id])

  @@index([companyId, period, contributionType])
  @@index([employeeId])
}

model PayrollAccrual {
  id             String   @id @default(uuid())
  companyId      String
  employeeId     String
  type           String // WAGES, PTO, BONUS, COMMISSION
  periodStart    DateTime
  periodEnd      DateTime
  amount         Decimal  @db.Decimal(19, 4)
  accountId      String?
  status         String // ACCRUED, PAID
  journalEntryId String?
  createdAt      DateTime @default(now())

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee     Employee      @relation(fields: [employeeId], references: [id])
  account      Account?      @relation(fields: [accountId], references: [id])
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@index([companyId, periodEnd])
  @@index([employeeId])
  @@index([journalEntryId])
}

model StockLevel {
  id              String   @id @default(uuid())
  companyId       String?
  itemId          String
  stockLocationId String
  quantity        Decimal  @db.Decimal(16, 6)
  reserved        Decimal  @default(0) @db.Decimal(19, 4)
  updatedAt       DateTime @updatedAt

  company       Company?      @relation(fields: [companyId], references: [id])
  item          Item          @relation(fields: [itemId], references: [id])
  stockLocation StockLocation @relation(fields: [stockLocationId], references: [id])

  @@unique([companyId, itemId, stockLocationId])
  @@index([companyId, itemId])
}

model InventoryTransaction {
  id                String    @id @default(uuid())
  workspaceId       String
  companyId         String?
  transactionNumber String?
  type              String // RECEIPT, SHIPMENT, TRANSFER, ADJUSTMENT
  reference         String?
  createdAt         DateTime  @default(now())
  deletedAt         DateTime?

  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  workspace                   Workspace                    @relation(fields: [workspaceId], references: [id])
  lines                       InventoryTransactionLine[]
  postingStatus               PostingStatus                @default(DRAFT)
  company                     Company?                     @relation(fields: [companyId], references: [id])
  journalEntryId              String?
  journalEntry                JournalEntry?                @relation("JournalEntry_InventoryTransactions", fields: [journalEntryId], references: [id])
  invoiceId                   String?
  invoice                     Invoice?                     @relation(fields: [invoiceId], references: [id])
  // Auto-added opposite relations (generated)
  inventoryAdjustmentRequests InventoryAdjustmentRequest[]

  @@index([workspaceId, transactionNumber])
  @@index([workspaceId, createdAt])
  @@index([journalEntryId])
  @@index([deletedAt])
}

model InventoryTransactionLine {
  id              String    @id @default(uuid())
  workspaceId     String
  companyId       String?
  transactionId   String
  itemId          String
  stockLocationId String?
  qty             Decimal   @db.Decimal(16, 6)
  unitCost        Decimal?  @db.Decimal(19, 4)
  lineType        String?
  serialNumber    String?
  lotNumber       String?
  expirationDate  DateTime?

  workspace        Workspace            @relation(fields: [workspaceId], references: [id])
  transaction      InventoryTransaction @relation(fields: [transactionId], references: [id])
  item             Item                 @relation(fields: [itemId], references: [id])
  stockLocation    StockLocation?       @relation(fields: [stockLocationId], references: [id])
  costLayers       InventoryCostLayer[] @relation("tx_line_costlayers")
  company          Company?             @relation(fields: [companyId], references: [id])
  classId          String?
  class            Class?               @relation(fields: [classId], references: [id])
  locationId       String?
  location         Location?            @relation(fields: [locationId], references: [id])
  projectId        String?
  project          Project?             @relation(fields: [projectId], references: [id])
  // Auto-added opposite relations (generated)
  cOGSRecognitions COGSRecognition[]

  @@unique([itemId, serialNumber], name: "item_serial_unique")
  @@index([workspaceId, itemId])
  @@index([workspaceId, transactionId])
  @@index([companyId, itemId])
  @@index([itemId, stockLocationId])
  @@index([transactionId, itemId])
  @@index([serialNumber])
  @@index([lotNumber])
  @@index([expirationDate])
}

model InventoryReserve {
  id          String   @id @default(uuid())
  companyId   String
  itemId      String?
  reserveType String // OBSOLETE, SLOW_MOVING, DAMAGED
  amount      Decimal  @db.Decimal(19, 4)
  reason      String?
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  item    Item?   @relation(fields: [itemId], references: [id])

  @@index([companyId, itemId])
}

model COGSRecognition {
  id                String   @id @default(uuid())
  companyId         String
  invoiceLineId     String?
  inventoryTxLineId String?
  itemId            String
  quantity          Decimal  @db.Decimal(16, 6)
  unitCost          Decimal  @db.Decimal(19, 4)
  totalCost         Decimal  @db.Decimal(19, 4)
  journalEntryId    String?
  recognizedAt      DateTime @default(now())

  company         Company                   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  invoiceLine     InvoiceLine?              @relation(fields: [invoiceLineId], references: [id])
  inventoryTxLine InventoryTransactionLine? @relation(fields: [inventoryTxLineId], references: [id])
  item            Item                      @relation(fields: [itemId], references: [id])
  journalEntry    JournalEntry?             @relation(fields: [journalEntryId], references: [id])

  @@index([companyId, recognizedAt])
  @@index([invoiceLineId])
  @@index([inventoryTxLineId])
  @@index([journalEntryId])
}

model InventoryAdjustmentRequest {
  id            String                    @id @default(uuid())
  workspaceId   String
  companyId     String
  transactionId String?
  requestedById String
  reason        String?
  status        InventoryAdjustmentStatus @default(PENDING) // PENDING, APPROVED, REJECTED
  requestedAt   DateTime                  @default(now())

  workspace   Workspace                     @relation(fields: [workspaceId], references: [id])
  company     Company                       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  transaction InventoryTransaction?         @relation(fields: [transactionId], references: [id])
  requestedBy User                          @relation(fields: [requestedById], references: [id])
  approvals   InventoryAdjustmentApproval[]

  @@index([workspaceId, status])
  @@index([companyId, status])
  @@index([transactionId])
}

model InventoryAdjustmentApproval {
  id         String                    @id @default(uuid())
  requestId  String
  approverId String
  status     InventoryAdjustmentStatus @default(PENDING) // PENDING, APPROVED, REJECTED
  note       String?
  createdAt  DateTime                  @default(now())

  request  InventoryAdjustmentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approver User                       @relation(fields: [approverId], references: [id])

  @@index([requestId])
  @@index([approverId])
}

// --------------------
// Manufacturing / Assembly
// --------------------

model AssemblyBuild {
  id            String   @id @default(uuid())
  companyId     String
  inventoryTxId String? // Links to the Stock adjustment (InventoryTransaction)
  itemId        String // The item being built (e.g., "Bike")
  quantity      Decimal  @db.Decimal(16, 6)
  date          DateTime @default(now())
  status        String   @default("COMPLETED") // PENDING, COMPLETED, VOID

  company    Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  item       Item                @relation("ItemBuilt", fields: [itemId], references: [id])
  components AssemblyComponent[]

  @@index([companyId])
  @@index([itemId])
}

model AssemblyComponent {
  id              String  @id @default(uuid())
  assemblyBuildId String
  itemId          String // Raw material (e.g., "Wheel")
  quantityUsed    Decimal @db.Decimal(16, 6)

  assemblyBuild AssemblyBuild @relation(fields: [assemblyBuildId], references: [id], onDelete: Cascade)
  item          Item          @relation("ItemComponent", fields: [itemId], references: [id])

  @@index([assemblyBuildId])
  @@index([itemId])
}

model ProductionRun {
  id                String   @id @default(uuid())
  companyId         String
  itemId            String
  quantity          Decimal  @db.Decimal(16, 6)
  standardCost      Decimal? @db.Decimal(19, 4)
  actualCost        Decimal? @db.Decimal(19, 4)
  varianceAmount    Decimal? @db.Decimal(19, 4)
  varianceAccountId String?
  status            String   @default("COMPLETED") // PLANNED, IN_PROGRESS, COMPLETED, VOID
  journalEntryId    String?
  createdAt         DateTime @default(now())

  company         Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  item            Item          @relation(fields: [itemId], references: [id])
  varianceAccount Account?      @relation(fields: [varianceAccountId], references: [id])
  journalEntry    JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@index([companyId, itemId])
  @@index([journalEntryId])
}

// NOTE: legacy alias models removed; code should prefer `tenant` and `account` models.

// --------------------
// Taxation & Jurisdictions
// --------------------

model TaxJurisdiction {
  id        String   @id @default(uuid())
  countryId String
  name      String
  region    String? // state/province
  code      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  country  Country   @relation(fields: [countryId], references: [id])
  taxRates TaxRate[]

  // Auto-added opposite relations (generated)
  taxReturnLines            TaxReturnLine[]
  taxAttributeCarryforwards TaxAttributeCarryforward[]
  taxRules                  TaxRule[]
  salesTaxReturnLines       SalesTaxReturnLine[]
  withholdingTaxDeductions  WithholdingTaxDeduction[]

  @@unique([countryId, region, code])
  @@index([countryId])
}

model TaxAuthority {
  id               String                       @id @default(uuid())
  countryId        String
  name             String // e.g., BIR, IRS, HMRC
  code             String?
  jurisdictionType TaxAuthorityJurisdictionType
  contactInfo      Json?
  filingMethods    TaxFilingMethod[]
  isActive         Boolean                      @default(true)
  createdAt        DateTime                     @default(now())

  country                  Country                     @relation(fields: [countryId], references: [id])
  returns                  TaxReturn[]
  communications           TaxAuthorityCommunication[]
  obligations              TaxObligation[]
  auditCases               TaxAuditCase[]
  advancePricingAgreements AdvancePricingAgreement[]
  uncertainTaxPositions    UncertainTaxPosition[]
  taxClearanceCertificates TaxClearanceCertificate[]

  @@unique([countryId, name])
  @@index([countryId])
}

model TaxObligation {
  id          String              @id @default(uuid())
  companyId   String
  authorityId String
  formType    String
  periodStart DateTime
  periodEnd   DateTime
  dueDate     DateTime
  status      TaxObligationStatus @default(PENDING)
  filedAt     DateTime?
  paidAt      DateTime?
  taxReturnId String?
  createdAt   DateTime            @default(now())

  company   Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  authority TaxAuthority @relation(fields: [authorityId], references: [id])
  taxReturn TaxReturn?   @relation(fields: [taxReturnId], references: [id])

  @@unique([companyId, authorityId, formType, periodStart])
  @@index([companyId, dueDate, status])
  @@index([authorityId, status])
}

model TaxAuditCase {
  id          String         @id @default(uuid())
  companyId   String
  authorityId String
  taxReturnId String?
  caseNumber  String?
  scope       String?
  periodStart DateTime?
  periodEnd   DateTime?
  status      TaxAuditStatus @default(OPEN)
  openedAt    DateTime       @default(now())
  closedAt    DateTime?
  notes       String?        @db.Text
  createdAt   DateTime       @default(now())

  company   Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  authority TaxAuthority @relation(fields: [authorityId], references: [id])
  taxReturn TaxReturn?   @relation(fields: [taxReturnId], references: [id])

  @@index([companyId, status])
  @@index([authorityId, status])
}

model TaxAuthorityCommunication {
  id          String                          @id @default(uuid())
  companyId   String
  authorityId String
  type        TaxAuthorityCommunicationType
  subject     String
  content     Json
  sentAt      DateTime?
  receivedAt  DateTime?
  status      TaxAuthorityCommunicationStatus @default(DRAFT)
  createdAt   DateTime                        @default(now())

  company   Company      @relation(fields: [companyId], references: [id])
  authority TaxAuthority @relation(fields: [authorityId], references: [id])

  @@index([companyId, authorityId])
  @@index([authorityId, status])
}

model TaxOptimizationSuggestion {
  id               String                        @id @default(uuid())
  companyId        String
  suggestionType   TaxOptimizationSuggestionType
  description      String
  potentialSavings Decimal                       @db.Decimal(19, 4)
  confidence       Decimal                       @db.Decimal(19, 4)
  status           TaxOptimizationStatus         @default(PENDING)
  createdAt        DateTime                      @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, status])
}

model TaxRiskScore {
  id           String   @id @default(uuid())
  companyId    String
  period       String // 2024-Q4
  overallScore Decimal  @db.Decimal(19, 4)
  components   Json // { transferPricing: 85, vatCompliance: 92, ... }
  createdAt    DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, period])
  @@index([companyId, period])
}

model TaxReturn {
  id                 String           @id @default(uuid())
  companyId          String
  authorityId        String
  formType           String // 2550Q, 941, VAT100, GST-7
  philForm           BirFormType? // Philippine-specific form enum (optional)
  periodStart        DateTime
  periodEnd          DateTime
  filingDeadline     DateTime
  status             FilingStatus     @default(DRAFT)
  filedAt            DateTime?
  dueDate            DateTime?
  totalTax           Decimal          @db.Decimal(19, 4)
  totalPenalty       Decimal?         @db.Decimal(19, 4)
  totalInterest      Decimal?         @db.Decimal(19, 4)
  paymentDeadline    DateTime?
  referenceNumber    String?
  efilingReference   String?
  efilingStatus      String?
  efilingSubmittedAt DateTime?
  efilingResponse    Json?
  attachmentId       String?
  filingMethod       TaxFilingMethod?
  notes              String?          @db.Text
  createdAt          DateTime         @default(now())

  company    Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  authority  TaxAuthority         @relation(fields: [authorityId], references: [id])
  attachment Attachment?          @relation("TaxReturn_attachment", fields: [attachmentId], references: [id])
  lines      TaxReturnLine[]
  payments   TaxPayment[]
  amendments TaxReturnAmendment[]

  // Auto-added opposite relations (generated)
  obligations           TaxObligation[]
  auditCases            TaxAuditCase[]
  uncertainTaxPositions UncertainTaxPosition[]

  @@unique([companyId, authorityId, formType, periodStart])
  @@index([companyId, periodStart, periodEnd])
  @@index([filingDeadline])
  @@index([attachmentId])
}

model TaxReturnLine {
  id             String   @id @default(uuid())
  taxReturnId    String
  taxRateId      String?
  jurisdictionId String?
  taxableAmount  Decimal? @db.Decimal(19, 4)
  taxAmount      Decimal  @db.Decimal(19, 4)

  taxReturn    TaxReturn        @relation(fields: [taxReturnId], references: [id], onDelete: Cascade)
  taxRate      TaxRate?         @relation(fields: [taxRateId], references: [id])
  jurisdiction TaxJurisdiction? @relation(fields: [jurisdictionId], references: [id])

  @@index([taxReturnId])
  @@index([taxRateId])
  @@index([jurisdictionId])
}

model TaxPayment {
  id              String   @id @default(uuid())
  taxReturnId     String
  paymentDate     DateTime
  amount          Decimal  @db.Decimal(19, 4)
  method          String?
  referenceNumber String?
  createdAt       DateTime @default(now())

  taxReturn TaxReturn @relation(fields: [taxReturnId], references: [id], onDelete: Cascade)

  @@index([taxReturnId, paymentDate])
}

model TaxReturnAmendment {
  id              String    @id @default(uuid())
  taxReturnId     String
  amendmentNumber Int       @default(1)
  reason          String
  changes         Json
  filedAt         DateTime?
  createdAt       DateTime  @default(now())

  taxReturn TaxReturn @relation(fields: [taxReturnId], references: [id], onDelete: Cascade)

  @@unique([taxReturnId, amendmentNumber])
}

model TaxCalculationAudit {
  id              String   @id @default(uuid())
  companyId       String
  calculationId   String
  calculationType String // INVOICE_TAX, WITHHOLDING, VAT
  inputs          Json
  rulesApplied    Json
  result          Json
  calculatedAt    DateTime @default(now())
  calculatedById  String?

  company      Company @relation(fields: [companyId], references: [id])
  calculatedBy User?   @relation(fields: [calculatedById], references: [id])

  @@index([companyId, calculatedAt])
  @@index([calculationType, calculationId])
  @@index([calculatedById])
}

model TaxPeriodLock {
  id         String   @id @default(uuid())
  companyId  String
  countryId  String
  taxType    String // VAT, INCOME_TAX, WITHHOLDING
  period     String // 2024-Q1
  lockedAt   DateTime @default(now())
  lockedById String?
  reason     String?

  company  Company @relation(fields: [companyId], references: [id])
  country  Country @relation(fields: [countryId], references: [id])
  lockedBy User?   @relation(fields: [lockedById], references: [id])

  @@unique([companyId, countryId, taxType, period])
  @@index([companyId, period])
  @@index([countryId, taxType, period])
}

model TaxFilingPackage {
  id                    String    @id @default(uuid())
  companyId             String
  filingId              String
  packageType           String // PRIMARY, AMENDMENT, SUPPORTING_DOCS
  documents             Json
  generatedAt           DateTime  @default(now())
  submittedAt           DateTime?
  acknowledgementNumber String?

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, submittedAt])
  @@index([companyId, packageType])
}

model WithholdingTaxCertificate {
  id                String    @id @default(uuid())
  companyId         String
  vendorId          String
  certificateType   String // 2307, 2316
  certificateNumber String
  periodCovered     String
  amount            Decimal   @db.Decimal(19, 4)
  dateIssued        DateTime
  dateReceived      DateTime?
  status            String

  company Company @relation(fields: [companyId], references: [id])
  vendor  Vendor  @relation(fields: [vendorId], references: [contactId])

  @@unique([companyId, certificateNumber])
  @@index([vendorId, periodCovered])
