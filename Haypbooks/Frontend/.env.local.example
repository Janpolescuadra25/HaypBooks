# Toggle in-browser mock backend (Mock Backend First)
# When true (in development), the client-side api() will serve responses from src/lib/mock-api.ts
NEXT_PUBLIC_USE_MOCK_API=true

# Enable Tags UI (filters on invoices, bills, transactions)
# When true, tag selector appears and persists filter state.
NEXT_PUBLIC_ENABLE_TAGS=true

# Base site URL for SSR helpers and tests (optional)
# Used by src/lib/server-url.ts when request headers are unavailable
# Example for local dev:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
